FROM python:3.11-alpine

WORKDIR /app

# The agent needs GCC to compile potential low-level packages it decides to write
RUN apk add --no-cache gcc musl-dev linux-headers

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the actual brain and telemetry
COPY actuators.py agent_core.py telemetry_wrapper.py ./

# Crucial for ASI: The agent must be able to overwrite its own components
RUN chmod -R 777 /app

# The execution is wrapped by the Telemetry Maxwell Demon
CMD ["python", "telemetry_wrapper.py"]
