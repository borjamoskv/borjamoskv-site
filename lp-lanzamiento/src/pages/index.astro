---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Borja Moskv | 21-EDO</title>
  </head>
  <body>
    <div class="container">
      <h1>21-EDO ALGORITHM</h1>
      <p>La fricción cognitiva transformada en exergía absoluta. El primer ecosistema auditivo que se retroalimenta de tu interacción.</p>
      <a href="#extract" class="cta-button" id="trigger-exergy">INICIAR SÍNTESIS</a>
    </div>
    <script>
      if (import.meta.env.PROD) {
        window.__DOM_INTEGRITY__ = {
          h1Count: document.querySelectorAll("h1").length,
          missingLabels: Array.from(document.querySelectorAll('input, button, a')).filter(el => 
            !el.getAttribute('aria-label') && !el.textContent?.trim() && !el.id
          ).length
        }
      }
    </script>
  </body>
</html>
