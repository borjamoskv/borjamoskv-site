---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} — Borja Moskv`}>
  <!-- Legacy CSS & Cortex Fonts -->
  <link rel="stylesheet" href="/article.css" />
  <link rel="stylesheet" href="/cortex-terminal.css" />

  <style>
    /* ═══════════════════════════════════════════════════
       ARTICLE LAYOUT HOLISTIC ALIGNMENTS
       ═══════════════════════════════════════════════════ */
    :root {
      --blue: var(--color-yinmn, #2B3BE5);
      --paper: var(--color-parchment, #F3F4F6);
      --soft: var(--color-muted, rgba(255, 255, 255, 0.55));
      --line: rgba(255, 255, 255, 0.06);
      --line-strong: rgba(255, 255, 255, 0.12);
    }

    .article-page-container {
      padding-top: 6rem;
      padding-bottom: 8rem;
    }

    /* Adjust Back Button below sticky header */
    .article-back {
      position: fixed;
      top: 6rem;
      left: 2rem;
      background: rgba(10, 10, 10, 0.75);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 4px;
      font-weight: 700;
    }

    /* Refine Hero Header to float on WebGL fluid background */
    .article-hero {
      background: transparent;
      min-height: 50vh;
      padding-top: 6rem;
      padding-bottom: 4rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .hero-title {
      font-family: var(--font-primary);
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    .hero-title :global(span) {
      background: linear-gradient(135deg, var(--color-yinmn), var(--color-amber));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Refine main body card to feel like a high-performance HUD window */
    .article-layout {
      background: rgba(10, 10, 10, 0.45);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 8px;
      padding: 4rem 3rem;
      margin-bottom: 4rem;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    .article-body {
      font-family: var(--font-primary);
      font-size: 1.1rem;
      line-height: 1.8;
      color: var(--color-parchment);
    }

    .article-body :global(h2), .article-body :global(h3) {
      font-family: var(--font-primary);
      font-weight: 800;
      color: var(--color-parchment);
      letter-spacing: -0.02em;
    }

    .article-body :global(code) {
      background: rgba(255, 255, 255, 0.04) !important;
      border-color: rgba(255, 255, 255, 0.08) !important;
      font-family: var(--font-secondary) !important;
    }

    .article-body :global(pre) {
      background: rgba(5, 5, 5, 0.85) !important;
      border-color: rgba(255, 255, 255, 0.06) !important;
    }

    .article-body :global(a) {
      color: var(--color-amber) !important;
      border-bottom: 1px dashed rgba(255, 159, 28, 0.4) !important;
    }

    .article-body :global(a:hover) {
      color: #FFF !important;
      border-bottom: 1px solid #FFF !important;
    }

    .article-footer {
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 2rem;
      margin-top: 4rem;
    }

    .article-tag {
      font-family: var(--font-secondary);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      border-radius: 2px;
      background: rgba(43, 59, 229, 0.08);
      border: 1px solid rgba(43, 59, 229, 0.2);
      color: var(--color-yinmn);
    }
  </style>

  <div class="content-layer">
    <div class="article-page-container">
      <!-- Back Navigation -->
      <a aria-label="Volver al blog" class="article-back" href="/blog">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 12H5m0 0l7 7m-7-7l7-7" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
        </svg>
        Blog
      </a>

      <!-- HERO -->
      <header class="article-hero">
        <span class="hero-label">Artículo</span>
        <h1 class="hero-title" set:html={entry.data.title}></h1>
        {entry.data.description && <p class="hero-subtitle">{entry.data.description}</p>}
        <div class="hero-meta">
          <span class="hero-author">Borja Moskv</span>
          <span class="hero-divider"></span>
          <span class="hero-date">{entry.data.pubDate}</span>
          <span class="hero-divider"></span>
          <span class="hero-reading-time" id="readingTime">— min de lectura</span>
        </div>
      </header>

      <!-- MAIN CONTAINER -->
      <div class="article-layout">
        <main class="article-body">
          <Content />
        </main>

        <footer class="article-footer">
          <div class="article-tags">
            {entry.data.tags?.map(tag => (
              <span class="article-tag">#{tag}</span>
            ))}
          </div>
          <p class="article-copyright">© 2026 Borja Moskv. Todos los derechos reservados.</p>
        </footer>
      </div>
    </div>
  </div>

  <script is:inline>
    // ── Simple reading time calculation ──
    const initReadingTime = () => {
      const text = document.querySelector('.article-body')?.textContent || '';
      const words = text.trim().split(/\s+/).length;
      const minutes = Math.ceil(words / 225); // average reading speed
      const readingTimeSpan = document.getElementById('readingTime');
      if (readingTimeSpan) {
        readingTimeSpan.textContent = `${minutes} min de lectura`;
      }
    };

    document.addEventListener('astro:page-load', initReadingTime);
    initReadingTime();
  </script>
</Layout>
