                    osc.frequency.setValueAtTime(f, now);
                    
                    gain.gain.setValueAtTime(gains[i], now);
                    gain.gain.exponentialRampToValueAtTime(0.0001, now + decays[i]);
                    
                    osc.connect(gain);
                    gain.connect(audioCtx.destination);
                    
                    osc.start();
