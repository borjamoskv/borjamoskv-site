            { speaker: "Manolo", text: "Pardo fecal. Como o color da terra de Cuenca despois da choiva.", time: 1035 },
            { speaker: "Narrador", text: "Gon sonrió. Era la segunda vez que sonreía en su vida. La primera fue cuando su madre le dijo de pequeño que podía ser lo que quisiera, y él dijo fotocopiador.", time: 1045 },
            { speaker: "Narrador", text: "Gon sigue tocando cada noche en Lehendakari Aguirre. Manolo sigue diciendo que es de Cuenca. Nadie le cree. A nadie le importa. Le dejan quedarse porque trae tortilla. Ane paró un penalti el domingo siguiente. Dijo que oyó la frecuencia del balón antes del disparo. Su entrenador apuntó comillas, intuición, cerrar comillas. Ramoncín sacó un EP de 3 temas. Se llama Endodonzia Punk. Suena a un hombre de 70 años con la mandíbula dormida que ha visto la verdad. Jokin publicó su paper. Se titula: Efectos psicoacústicos de intervalos no temperados en la activación de electrodomésticos residenciales. Un estudio de campo en el Gran Bilbao. Tiene 6 citas. 4 son suyas. El perro sigue ahí. Come txistorra con la dignidad de quien ha volado sobre Fantasía y ha decidido que Lehendakari Aguirre es mejor porque aquí la txistorra es real. Y la farola del portal 47 sigue fundida. Pero algunas noches, si pasas por ahí a las 3 47 y el aire está lo bastante húmedo, puedes oír a un saxo tocando una nota que no está en ningún afinador. Y a un hombre comiendo tortilla diciendo que eso en Cuenca es completamente normal. Mañana puede que suene distinta.", time: 1060 },
            { speaker: "Manolo", text: "Home, en Cuenca sempre soa distinta.", time: 1150 }
        ];

        // Generate script list nodes dynamically
        const scriptContainer = document.getElementById('scriptContainer');
        DIALOGS.forEach((node, idx) => {
            const div = document.createElement('div');
            div.className = 'dialog-node';
            div.id = `node-${idx}`;
            div.onclick = () => {
                const aud = document.getElementById('mainAudio');
                aud.currentTime = node.time;
                if (aud.paused) {
                    togglePlay();
                }
            };
            
            const formatTime = (sec) => {
                const m = Math.floor(sec / 60);
                const s = Math.floor(sec % 60);
                return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
            };

            div.innerHTML = `
                <div class="dialog-meta">
                    <span class="dialog-speaker">${node.speaker}</span>
                    <span class="dialog-time">${formatTime(node.time)}</span>
                </div>
                <p class="dialog-text">${node.text}</p>
            `;
            scriptContainer.appendChild(div);
        });

        // --- Main Audio Sync & Custom Visualizer ---
        const aud = document.getElementById('mainAudio');
        const playBtn = document.getElementById('playBtn');
        const progressBar = document.getElementById('progressBar');
        const timelineTime = document.getElementById('timeline-time');
        const canvas = document.getElementById('oscilloscope');
        const ctx = canvas.getContext('2d');

        let volumeEnvelope = [];
        let animationFrameId;
        let vizMode = 'waveform';

        // Load precompiled volume envelope
        fetch('volume_envelope.json')
            .then(res => res.json())
            .then(data => {
                volumeEnvelope = data;
                console.log(`Envelope loaded successfully: ${volumeEnvelope.length} frames.`);
            })
            .catch(err => {
                console.warn("Could not load volume_envelope.json, falling back to simulated visuals.", err);
            });

        // Set high resolution canvas
        function resizeCanvas() {
            const rect = canvas.getBoundingClientRect();
            canvas.width = rect.width * (window.devicePixelRatio || 1);
            canvas.height = rect.height * (window.devicePixelRatio || 1);
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        function setVizMode(mode) {
            vizMode = mode;
            document.querySelectorAll('.viz-opt').forEach(btn => {
                if (btn.innerText.toLowerCase().includes(mode.substring(0, 4))) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });
        }

        function togglePlay() {
            initAudioCtx();
            if (aud.paused) {
                aud.play();
                playBtn.innerText = "‖";
                playBtn.style.borderColor = "var(--accent-copper)";
                playBtn.style.boxShadow = "0 0 20px var(--accent-copper)";
                drawLoop();
            } else {
                aud.pause();
                playBtn.innerText = "▶";
                playBtn.style.borderColor = "var(--accent-blue)";
                playBtn.style.boxShadow = "0 0 10px rgba(43, 59, 229, 0.2)";
                cancelAnimationFrame(animationFrameId);
            }
        }

        function setVolume(val) {
            aud.volume = val;
        }

        function seekTrack(event) {
            const rect = document.getElementById('progressBarContainer').getBoundingClientRect();
            const posX = (event.clientX - rect.left) / rect.width;
            aud.currentTime = posX * aud.duration;
            updateProgress();
        }

        function updateProgress() {
            const pct = (aud.currentTime / aud.duration) * 100;
            progressBar.style.width = `${pct}%`;
            
            const formatTime = (sec) => {
                if (isNaN(sec)) return "00:00";
                const m = Math.floor(sec / 60);
                const s = Math.floor(sec % 60);
                return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
            };
            timelineTime.innerText = `TIME: ${formatTime(aud.currentTime)} / ${formatTime(aud.duration)}`;

            // Sync Dialog Highlighter
            let currentIdx = 0;
            for (let i = 0; i < DIALOGS.length; i++) {
                if (aud.currentTime >= DIALOGS[i].time) {
                    currentIdx = i;
                } else {
                    break;
                }
            }

            document.querySelectorAll('.dialog-node').forEach((node, idx) => {
                if (idx === currentIdx) {
                    if (!node.classList.contains('current')) {
                        node.classList.add('current');
                        node.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    }
                } else {
                    node.classList.remove('current');
                }
            });
        }

        aud.addEventListener('timeupdate', updateProgress);
        aud.addEventListener('ended', () => {
            playBtn.innerText = "▶";
            cancelAnimationFrame(animationFrameId);
        });

        // --- Real-time Draw Visualizer Loop ---
        let lfoTime = 0;
        function drawLoop() {
            animationFrameId = requestAnimationFrame(drawLoop);
            
            const w = canvas.width;
            const h = canvas.height;
            
            // CRT fade effect
            ctx.fillStyle = 'rgba(2, 2, 8, 0.16)';
            ctx.fillRect(0, 0, w, h);

            // Get current RMS amplitude from precompiled JSON envelope or simulate
            let amp = 0;
            if (volumeEnvelope.length > 0) {
                const fps = 30;
                const frame = Math.floor(aud.currentTime * fps);
                amp = volumeEnvelope[frame % volumeEnvelope.length] || 0;
            } else {
                amp = aud.paused ? 0 : 0.15 + 0.1 * Math.sin(aud.currentTime * 5);
            }

            // Update LUFS HUD readout
            const lufs = -30 + amp * 22;
            document.getElementById('lufs-val').innerText = `LUFS: ${lufs.toFixed(1)}`;

            lfoTime += 0.05 + amp * 0.1;

            if (vizMode === 'waveform') {
                // CRT Oscilloscope trace
                ctx.strokeStyle = `rgba(43, 59, 229, ${0.55 + amp * 0.45})`;
                ctx.lineWidth = 2.5 + amp * 2;
                ctx.shadowBlur = 10 + amp * 15;
                ctx.shadowColor = "rgba(43, 59, 229, 0.8)";
                
                ctx.beginPath();
                for (let x = 0; x < w; x++) {
                    const progress = x / w;
                    const sinVal = Math.sin(progress * 15 + lfoTime * 2) * Math.cos(progress * Math.PI - Math.PI / 2);
                    const noise = (Math.random() - 0.5) * 4 * amp;
                    const y = (h / 2) + sinVal * h * 0.3 * amp + noise;
                    
                    if (x === 0) {
                        ctx.moveTo(x, y);
                    } else {
                        ctx.lineTo(x, y);
                    }
                }
                ctx.stroke();
                ctx.shadowBlur = 0;

            } else if (vizMode === 'spiral') {
                // 21-EDO Spiral visualization
                ctx.strokeStyle = `rgba(138, 94, 60, ${0.45 + amp * 0.55})`;
                ctx.lineWidth = 1.5 + amp * 3;
                ctx.shadowBlur = 8 + amp * 12;
                ctx.shadowColor = "rgba(138, 94, 60, 0.8)";
                
                const centerX = w / 2;
                const centerY = h / 2;
                const maxRadius = Math.min(w, h) * 0.45;
                
                ctx.beginPath();
                const totalPoints = 300;
                for (let i = 0; i < totalPoints; i++) {
                    // Spiral angle stepped to 21 EDO points
                    const theta = (i / 21) * Math.PI * 2 + lfoTime * 0.2;
                    const radius = (i / totalPoints) * maxRadius * (0.8 + amp * 0.4);
                    
                    const x = centerX + Math.cos(theta) * radius;
                    const y = centerY + Math.sin(theta) * radius;
                    
                    if (i === 0) {
                        ctx.moveTo(x, y);
                    } else {
                        ctx.lineTo(x, y);
                    }
                }
                ctx.stroke();
                ctx.shadowBlur = 0;

            } else if (vizMode === 'lissajous') {
                // Lissajous curve
                ctx.strokeStyle = `rgba(255, 255, 255, ${0.5 + amp * 0.5})`;
                ctx.lineWidth = 2 + amp * 2;
                ctx.shadowBlur = 12;
                ctx.shadowColor = "rgba(43, 59, 229, 0.8)";
                
                const centerX = w / 2;
                const centerY = h / 2;
                const scale = Math.min(w, h) * 0.35 * (0.8 + amp * 0.4);
                
                ctx.beginPath();
                const steps = 400;
                for (let i = 0; i < steps; i++) {
                    const t = (i / steps) * Math.PI * 2;
                    const x = centerX + Math.sin(3 * t + lfoTime) * scale;
                    const y = centerY + Math.sin(4 * t + lfoTime * 1.5) * scale;
                    
                    if (i === 0) {
                        ctx.moveTo(x, y);
                    } else {
                        ctx.lineTo(x, y);
                    }
                }
                ctx.stroke();
                ctx.shadowBlur = 0;
            }

            // Grid lines overlay
            ctx.strokeStyle = 'rgba(43, 59, 229, 0.05)';
            ctx.lineWidth = 1;
            const gridCells = 8;
            for (let i = 1; i < gridCells; i++) {
                // Vertical lines
                ctx.beginPath();
                ctx.moveTo((w / gridCells) * i, 0);
                ctx.lineTo((w / gridCells) * i, h);
                ctx.stroke();
                // Horizontal lines
                ctx.beginPath();
                ctx.moveTo(0, (h / gridCells) * i);
                ctx.lineTo(w, (h / gridCells) * i);
                ctx.stroke();
            }
        }

            // Expose methods to global window for inline event handlers
            window.playEdoNote = playEdoNote;
            window.playCharSynth = playCharSynth;
            window.togglePlay = togglePlay;
            window.seekTrack = seekTrack;
            window.setVizMode = setVizMode;

            // Initializations
            resizeCanvas();
            setVizMode('waveform');
            drawLoop();
        });
    </script>
</Layout>
