                osc1.type = 'sine';
                osc1.frequency.setValueAtTime(rootFreq, now);
                
                osc2.type = 'sine';
                osc2.frequency.setValueAtTime(rootFreq * 2.2, now); // Metallic disharmony
                
                gain.gain.setValueAtTime(0.2, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 2.5);
                
                osc1.connect(gain);
                osc2.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc1.start();
                osc2.start();
                osc1.stop(now + 2.6);
                osc2.stop(now + 2.6);
