---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="GON Y EL INTERVALO PROHIBIDO // 21-EDO Substrate">
    <style>
        :root {
        --bg-base: #0A0A0A;
        --bg-panel: rgba(10, 10, 10, 0.75);
        --accent-blue: #2B3BE5;
        --accent-blue-glow: rgba(43, 59, 229, 0.4);
        --accent-copper: #8A5E3C;
        --accent-pardo: #6B4226; /* Pardo Fecal™ */
        --text-primary: #F3F4F6;
        --text-secondary: #8E8E93;
        --border-dim: rgba(43, 59, 229, 0.15);
        --crt-glow: 0 0 20px rgba(43, 59, 229, 0.25);
    }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-base);
            color: var(--text-primary);
            font-family: 'Outfit', sans-serif;
            overflow-x: hidden;
            position: relative;
        }

        /* Analog Film Grain Overlay */
        .analog-grain {
            position: fixed;
            top: 0; left: 0; bottom: 0; right: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.03;
            pointer-events: none;
            z-index: 1000;
        }

        /* Scanlines Overlay */
        body::after {
            content: " ";
            display: block;
            position: fixed;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(43, 59, 229, 0.03), rgba(0, 255, 0, 0.01), rgba(138, 94, 60, 0.03));
            z-index: 999;
            background-size: 100% 4px, 6px 100%;
            pointer-events: none;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            grid-template-rows: auto 1fr auto;
            gap: 2rem;
        }

        /* Header styling */
        header {
            grid-column: 1 / -1;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-dim);
            padding-bottom: 1.5rem;
        }

        .logo-group {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo-symbol {
            font-family: 'Outfit', sans-serif;
            font-weight: 900;
            font-size: 2.5rem;
            background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-copper) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: var(--crt-glow);
        }

        .logo-text h1 {
            font-size: 1.8rem;
            font-weight: 900;
            letter-spacing: -0.03em;
            text-transform: uppercase;
        }

        .logo-text span {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-secondary);
            letter-spacing: 0.1em;
        }

        .system-status {
            text-align: right;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
        }

        .site-nav-custom {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }

        .site-nav-custom a {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-secondary);
            text-decoration: none;
            position: relative;
            padding: 4px 0;
            letter-spacing: 0.05em;
            transition: color 0.2s ease;
        }

        .site-nav-custom a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--accent-blue);
            transition: width 0.2s ease;
        }

        .site-nav-custom a:hover, .site-nav-custom a.active {
            color: var(--text-primary);
        }

        .site-nav-custom a.active::after, .site-nav-custom a:hover::after {
            width: 100%;
        }

        @media (max-width: 768px) {
            header {
                flex-direction: column;
                gap: 1rem;
                align-items: flex-start;
            }
            .site-nav-custom {
                width: 100%;
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 0.75rem;
            }
            .system-status {
                width: 100%;
                text-align: left;
            }
        }

        .status-indicator {
            display: inline-block;
            width: 8px;
            height: 8px;
            background-color: #00FF66;
            border-radius: 50%;
            margin-right: 0.5rem;
            box-shadow: 0 0 8px #00FF66;
            animation: pulse 1.5s infinite alternate;
        }

        @keyframes pulse {
            from { opacity: 0.4; }
            to { opacity: 1; }
        }

        /* Main panels layout */
        .workspace {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        /* CRT Screen Panel */
        .crt-panel {
            background: var(--bg-panel);
            border: 1px solid var(--border-dim);
            border-radius: 12px;
            padding: 1.5rem;
            position: relative;
            overflow: hidden;
            box-shadow: var(--crt-glow);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
        }

        .crt-screen-wrapper {
            width: 100%;
            height: 380px;
            background: #020208;
            border: 10px solid #1c1c1c;
            border-radius: 8px;
            position: relative;
            overflow: hidden;
            box-shadow: inset 0 0 30px rgba(0,0,0,0.9);
        }

        .crt-screen-wrapper::after {
            content: " ";
            display: block;
            position: absolute;
            top: 0; left: 0; bottom: 0; right: 0;
            background: radial-gradient(circle, transparent 60%, rgba(0,0,0,0.4) 100%);
            pointer-events: none;
        }

        canvas#oscilloscope {
            width: 100%;
            height: 100%;
            display: block;
        }

        .crt-hud {
            position: absolute;
            top: 15px; left: 15px; right: 15px;
            display: flex;
            justify-content: space-between;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: rgba(43, 59, 229, 0.85);
            pointer-events: none;
            text-shadow: 0 0 4px rgba(43, 59, 229, 0.5);
        }

        .crt-hud-bottom {
            position: absolute;
            bottom: 15px; left: 15px; right: 15px;
            display: flex;
            justify-content: space-between;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: rgba(138, 94, 60, 0.85);
            pointer-events: none;
            text-shadow: 0 0 4px rgba(138, 94, 60, 0.5);
        }

        /* Controls card */
        .controls-card {
            background: var(--bg-panel);
            border: 1px solid var(--border-dim);
            border-radius: 12px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
        }

        .player-bar {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .play-btn {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: 2px solid var(--accent-blue);
            background: transparent;
            color: var(--text-primary);
            font-size: 1.5rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            box-shadow: 0 0 10px rgba(43, 59, 229, 0.2);
        }

        .play-btn:hover {
            background: var(--accent-blue);
            box-shadow: 0 0 20px var(--accent-blue);
            transform: scale(1.05);
        }

        .track-info {
            flex-grow: 1;
        }

        .track-title {
            font-size: 1.1rem;
            font-weight: 700;
        }

        .track-meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .progress-container {
            width: 100%;
            height: 6px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 3px;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-copper));
            width: 0%;
            transition: width 0.1s linear;
        }

        /* 21-EDO Microtonal Synth Keyboard */
        .keyboard-panel {
            background: var(--bg-panel);
            border: 1px solid var(--border-dim);
            border-radius: 12px;
            padding: 1.5rem;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
        }

        .panel-heading {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-secondary);
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
        }

        .keyboard {
            display: flex;
            gap: 4px;
            height: 140px;
            padding: 4px;
            background: #020202;
            border-radius: 8px;
            overflow-x: auto;
        }

        .key-edo {
            flex: 1;
            min-width: 32px;
            background: #111;
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 4px;
            cursor: pointer;
            position: relative;
            transition: background 0.15s, transform 0.1s;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: center;
            padding-bottom: 10px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            color: rgba(255,255,255,0.25);
        }

        .key-edo:hover {
            background: #1a1a24;
            color: var(--text-primary);
        }

        .key-edo.active {
            background: var(--accent-blue);
            color: white;
            box-shadow: 0 0 15px var(--accent-blue-glow);
            transform: translateY(2px);
        }

        .key-edo.scale-root {
            border-bottom: 3px solid var(--accent-copper);
        }

        /* Character Soundboard */
        .character-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 1rem;
        }

        .char-btn {
            background: #111;
            border: 1px solid var(--border-dim);
            border-radius: 8px;
            padding: 1rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }

        .char-btn:hover {
            border-color: var(--accent-copper);
            background: rgba(138, 94, 60, 0.05);
            transform: translateY(-2px);
        }

        .char-btn.active {
            border-color: var(--accent-blue);
            background: rgba(43, 59, 229, 0.1);
            box-shadow: var(--crt-glow);
        }

        .char-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: #222;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            color: var(--text-secondary);
            border: 1px solid var(--border-dim);
            transition: all 0.3s ease;
        }

        .char-btn:hover .char-avatar {
            color: var(--accent-copper);
            border-color: var(--accent-copper);
        }

        .char-btn.active .char-avatar {
            color: var(--text-primary);
            border-color: var(--accent-blue);
            background: var(--accent-blue);
        }

        .char-name {
            font-size: 0.85rem;
            font-weight: 700;
        }

        .char-role {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.6rem;
            color: var(--text-secondary);
        }

        /* Script Sidebar Panel */
        .script-panel {
            background: var(--bg-panel);
            border: 1px solid var(--border-dim);
            border-radius: 12px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            height: 750px;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
        }

        .script-container {
            flex-grow: 1;
            overflow-y: auto;
            padding-right: 0.5rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* Custom Scrollbar */
        .script-container::-webkit-scrollbar {
            width: 4px;
        }
        .script-container::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.1);
        }
        .script-container::-webkit-scrollbar-thumb {
            background: var(--accent-blue);
            border-radius: 2px;
        }

        .dialog-node {
            border-left: 2px solid var(--border-dim);
            padding-left: 1rem;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .dialog-node:hover {
            border-color: var(--accent-copper);
            background: rgba(255, 255, 255, 0.01);
        }

        .dialog-node.current {
            border-color: var(--accent-blue);
            background: rgba(43, 59, 229, 0.03);
            padding-left: 1.25rem;
        }

        .dialog-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            margin-bottom: 0.25rem;
        }

        .dialog-speaker {
            font-weight: 700;
            text-transform: uppercase;
            color: var(--accent-copper);
        }

        .dialog-node.current .dialog-speaker {
            color: var(--text-primary);
        }

        .dialog-time {
            color: var(--text-secondary);
        }

        .dialog-text {
            font-size: 0.9rem;
            line-height: 1.5;
            color: var(--text-secondary);
        }

        .dialog-node.current .dialog-text {
            color: var(--text-primary);
        }

        /* Footer styling */
        footer {
            grid-column: 1 / -1;
            text-align: center;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border-dim);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        /* Switch selector styling */
        .viz-switch {
            display: flex;
            background: #000;
            border-radius: 6px;
            padding: 2px;
            border: 1px solid var(--border-dim);
        }

        .viz-opt {
            padding: 0.25rem 0.75rem;
            font-size: 0.7rem;
            font-family: 'JetBrains Mono', monospace;
            border: none;
            background: transparent;
            color: var(--text-secondary);
            cursor: pointer;
            border-radius: 4px;
            transition: all 0.2s ease;
        }

        .viz-opt.active {
            background: var(--accent-blue);
            color: white;
        }

        /* Responsive Layout fixes */
        @media (max-width: 1024px) {
            .container {
                grid-template-columns: 1fr;
            }
            .script-panel {
                height: 500px;
            }
            .character-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }
    </style>

    <!-- Back Navigation -->
    <a href="/blog" class="article-back" aria-label="Volver al blog" style="position: fixed; top: 6rem; left: 2rem; background: rgba(10, 10, 10, 0.75); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 4px; padding: 0.5rem 1rem; color: #fff; text-decoration: none; display: flex; align-items: center; gap: 0.5rem; font-weight: 700; z-index: 999;">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width: 16px; height: 16px;"><path d="M19 12H5m0 0l7 7m-7-7l7-7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Blog
    </a>

    <div class="container" style="padding-top: 8rem;">
        <!-- Header -->
        <header style="margin-bottom: 2rem;">
            <div class="logo-group">
                <div class="logo-symbol">Ω</div>
                <div class="logo-text">
                    <h1>GON Y EL INTERVALO PROHIBIDO</h1>
                    <span>SUSTRATO DE PERSISTENCIA MUSICAL 21-EDO</span>
                </div>
            </div>
            <div class="system-status">
                <span class="status-indicator"></span>
                C5-REAL // STABLE // OSCILLOSCOPE ACTIVE
            </div>
        </header>

        <!-- Left column: Workspace -->
        <div class="workspace">
            <!-- CRT Panel -->
            <section class="crt-panel">
                <div class="panel-heading">
                    <span>[ VECTORSCOPE / FREQUENCY ENVELOPE ]</span>
                    <div class="viz-switch">
                        <button class="viz-opt active" onclick="setVizMode('waveform')">CRT WAVE</button>
                        <button class="viz-opt" onclick="setVizMode('spiral')">21-EDO SPIRAL</button>
                        <button class="viz-opt" onclick="setVizMode('lissajous')">LISSAJOUS</button>
                    </div>
                </div>
                <div class="crt-screen-wrapper">
                    <div class="crt-hud">
                        <span>TRACE 1A // DETECTOR LOCK</span>
                        <span id="lufs-val">LUFS: -14.2</span>
                    </div>
                    <canvas id="oscilloscope"></canvas>
                    <div class="crt-hud-bottom">
                        <span id="timeline-time">TIME: 00.0s / 919.5s</span>
                        <span>REALITY LEVEL: C5-REAL</span>
                    </div>
                </div>
            </section>

            <!-- Control Card -->
            <section class="controls-card">
                <div class="player-bar">
                    <button class="play-btn" id="playBtn" onclick="togglePlay()">▶</button>
                    <div class="track-info">
                        <div class="track-title">Gon y el Intervalo Prohibido (Director's Cut)</div>
                        <div class="track-meta">FILE: gon_v2_subnormal.wav (44.1kHz / 16-bit)</div>
                    </div>
                    <div class="volume-container" style="display:flex; align-items:center; gap: 8px;">
                        <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;">VOL:</span>
                        <input type="range" id="volumeSlider" min="0" max="1" step="0.05" value="0.8" oninput="setVolume(this.value)" style="width: 80px; accent-color: var(--accent-blue);">
                    </div>
                </div>
                <div class="progress-container" id="progressBarContainer" onclick="seekTrack(event)">
                    <div class="progress-bar" id="progressBar"></div>
                </div>
            </section>

            <!-- Character Soundboard -->
            <section class="keyboard-panel">
                <div class="panel-heading">
                    <span>[ CARÁCTERES Y SINTESIS DE INSTRUMENTOS (VIRTUAL INSTRUMENT) ]</span>
                    <span>CLICK/HOVER PARA DISPARAR NOTAS</span>
                </div>
                <div class="character-grid">
                    <button class="char-btn" onmouseenter="playCharSynth('gon')" onclick="playCharSynth('gon')">
                        <div class="char-avatar">🎷</div>
                        <span class="char-name">Gon</span>
                        <span class="char-role">Saxo 21-EDO</span>
                    </button>
                    <button class="char-btn" onmouseenter="playCharSynth('manolo')" onclick="playCharSynth('manolo')">
                        <div class="char-avatar">🌬️</div>
                        <span class="char-name">Manolo</span>
                        <span class="char-role">Silbido Celta</span>
                    </button>
                    <button class="char-btn" onmouseenter="playCharSynth('txema')" onclick="playCharSynth('txema')">
                        <div class="char-avatar">🎚️</div>
                        <span class="char-name">Txema</span>
                        <span class="char-role">Oscilador Sub</span>
                    </button>
                    <button class="char-btn" onmouseenter="playCharSynth('ane')" onclick="playCharSynth('ane')">
                        <div class="char-avatar">🥅</div>
                        <span class="char-name">Ane</span>
                        <span class="char-role">Larguero Resonance</span>
                    </button>
                    <button class="char-btn" onmouseenter="playCharSynth('koldo')" onclick="playCharSynth('koldo')">
                        <div class="char-avatar">🔔</div>
                        <span class="char-name">Koldo</span>
                        <span class="char-role">Campana Existencial</span>
                    </button>
                </div>
            </section>

            <!-- 21-EDO Keyboard -->
            <section class="keyboard-panel">
                <div class="panel-heading">
                    <span>[ TECLADO CROMÁTICO 21-EDO // AFINACIÓN DE RAINBOWS ]</span>
                    <span id="noteFreqDisplay">FREQ: -- Hz</span>
                </div>
                <div class="keyboard" id="keyboardEdo">
                    <!-- JS generated keys -->
                </div>
            </section>
        </div>

        <!-- Right column: Script Panel -->
        <aside class="script-panel">
            <div class="panel-heading">
                <span>[ TRANSCRIPCIÓN E INTERIORIZACIÓN HISTÓRICA ]</span>
                <span>ESCENAS: 16</span>
            </div>
            <div class="script-container" id="scriptContainer">
                <!-- JS generated nodes -->
            </div>
        </aside>

        <!-- Footer -->
        <footer>
            ∴ "En Cuenca la tortilla se come así, con babas." // C5-REAL // INDUSTRIAL NOIR // DESIGN MASTERPIECE 2026
        </footer>
    </div>

    <!-- Audio Element -->
    <audio id="mainAudio" src="gon_v2_subnormal.wav" preload="auto"></audio>

    <script is:inline>
        document.addEventListener('astro:page-load', () => {
        // --- 21-EDO Frequency Computation ---
        const BASE_FREQ = 220.0; // A3 root
        function get21EdoFreq(step) {
            return BASE_FREQ * Math.pow(2, step / 21.0);
        }

        // --- Audio Context and Synthesis Engine ---
        let audioCtx;
        function initAudioCtx() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        }

        // --- Play Note EDO ---
        function playEdoNote(step) {
            initAudioCtx();
            const freq = get21EdoFreq(step);
            document.getElementById('noteFreqDisplay').innerText = `FREQ: ${freq.toFixed(2)} Hz (Paso ${step})`;

            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            
            // Rich square / triangle hybrid spectrum
            osc.type = step % 2 === 0 ? 'triangle' : 'sawtooth';
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            
            gainNode.gain.setValueAtTime(0.12, audioCtx.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 1.2);
            
            osc.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            
            osc.start();
            osc.stop(audioCtx.currentTime + 1.25);
        }

        // --- Play Character Sounds (Generative Audio Synthesis) ---
        function playCharSynth(character) {
            initAudioCtx();
            const now = audioCtx.currentTime;
            
            if (character === 'gon') {
                // Generates Microtonal Saxophone timbre
                const rootFreq = get21EdoFreq(7); // A step 7
                const osc1 = audioCtx.createOscillator();
                const osc2 = audioCtx.createOscillator();
                const filter = audioCtx.createBiquadFilter();
                const gain = audioCtx.createGain();
                
                osc1.type = 'sawtooth';
                osc1.frequency.setValueAtTime(rootFreq, now);
                osc1.frequency.linearRampToValueAtTime(rootFreq * 1.01, now + 0.5); // vibrato LFO
                
                osc2.type = 'triangle';
                osc2.frequency.setValueAtTime(rootFreq * 2, now); // Octave overtone
                
                filter.type = 'lowpass';
                filter.frequency.setValueAtTime(900, now);
                filter.frequency.exponentialRampToValueAtTime(400, now + 1.0);
                
                gain.gain.setValueAtTime(0.18, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 1.4);
                
                osc1.connect(filter);
                osc2.connect(filter);
                filter.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc1.start();
                osc2.start();
                osc1.stop(now + 1.4);
                osc2.stop(now + 1.4);
                
            } else if (character === 'manolo') {
                // Celtic Conquense whistle
                const rootFreq = get21EdoFreq(12);
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                
                osc.type = 'triangle';
                // Tremolo / LFO vibrato
                const lfo = audioCtx.createOscillator();
                const lfoGain = audioCtx.createGain();
                
                lfo.frequency.value = 6.8; // Fast celtic vibrato
                lfoGain.gain.value = 8;
                
                lfo.connect(lfoGain);
                lfoGain.connect(osc.frequency);
                
                osc.frequency.setValueAtTime(rootFreq * 1.5, now);
                
                gain.gain.setValueAtTime(0.1, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 1.8);
                
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                lfo.start();
                osc.start();
                lfo.stop(now + 1.8);
                osc.stop(now + 1.8);
                
            } else if (character === 'txema') {
                // Deep lowpass sub bass note
                const rootFreq = 55.0; // low sub bass
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                
                osc.type = 'sine';
                osc.frequency.setValueAtTime(rootFreq, now);
                
                gain.gain.setValueAtTime(0.35, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 1.6);
                
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc.start();
                osc.stop(now + 1.6);
                
            } else if (character === 'ane') {
