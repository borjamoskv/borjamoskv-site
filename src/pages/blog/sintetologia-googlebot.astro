    <link rel="stylesheet" href="https://substackcdn.com/bundle/theme/color_links.c9908948e2f4e05476e6.css" />
    
    <style>
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 8rem 2rem 4rem; /* padded to clear top navigation */
            color: #E0E0E0;
        }
        
        /* Ensure the substack theme does not override the global dark background */
        .main.typography.use-theme-bg, .pubTheme-yiXxQA, .available-content, article.post {
            background: transparent !important;
            color: #E0E0E0 !important;
        }

        .post-title {
            font-size: clamp(2.5rem, 6vw, 4.5rem) !important;
            font-weight: 900 !important;
            letter-spacing: -0.04em !important;
            color: #fff !important;
            margin-bottom: 1rem !important;
        }

        .subtitle {
            color: var(--color-amber) !important;
            font-family: var(--font-secondary) !important;
            font-size: 1.1rem !important;
            margin-bottom: 2rem !important;
        }

        .body.markup p, .body.markup blockquote p {
            font-family: 'Inter', system-ui, sans-serif !important;
            color: rgba(243, 244, 246, 0.85) !important;
            font-size: 1.05rem !important;
            line-height: 1.7 !important;
            margin-bottom: 1.5rem !important;
        }

        .body.markup blockquote {
            border-left: 4px solid var(--color-yinmn) !important;
            padding-left: 1.5rem !important;
            margin: 2rem 0 !important;
            background: rgba(43, 59, 229, 0.05) !important;
            padding: 1.5rem !important;
            border-radius: 4px;
        }

        .byline-wrapper, .post-ufi, .footer-wrap, .main-menu {
            display: none !important; /* hide substack generic elements */
        }
    </style>

