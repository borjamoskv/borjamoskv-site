  <script>
    // Tab Toggling & Header Scroll Controller
    document.addEventListener('DOMContentLoaded', () => {
      // ── Site Header Scroll ──────────────────────────
      const header = document.getElementById('header');
      if (header) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 50) {
            header.classList.add('is-scrolled');
          } else {
            header.classList.remove('is-scrolled');
          }
        });
      }

      const tabEp1 = document.getElementById('tab-ep1');
      const tabEp2 = document.getElementById('tab-ep2');
      const contentEp1 = document.getElementById('content-ep1');
      const contentEp2 = document.getElementById('content-ep2');

      if (tabEp1 && tabEp2 && contentEp1 && contentEp2) {
        tabEp1.addEventListener('click', () => {
          tabEp1.classList.add('active');
          tabEp2.classList.remove('active');
          contentEp1.classList.remove('hidden');
          contentEp2.classList.add('hidden');
          
          // Re-trigger scroll reveal calculation
          window.dispatchEvent(new Event('scroll'));
        });

        tabEp2.addEventListener('click', () => {
          tabEp2.classList.add('active');
          tabEp1.classList.remove('active');
          contentEp2.classList.remove('hidden');
          contentEp1.classList.add('hidden');
          
          // Re-trigger scroll reveal calculation
          window.dispatchEvent(new Event('scroll'));
        });
      }
    });
  </script>
