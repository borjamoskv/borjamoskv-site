---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BORJA MOSKV — Música · Síntesis C5-REAL">
  <style is:global>
    :root {
      --color-bg-musica: #050508;
      --color-surface-musica: #0a0a0f;
      --color-cyber-cyan: #00f0ff;
      --color-cyber-pink: #ff0055;
    }
    
    .musica-container {
      min-height: 100vh;
      background-color: var(--color-bg-musica);
      color: #ffffff;
      padding-top: 8rem;
      padding-bottom: 10rem;
    }

    .musica-header {
      text-align: center;
      margin-bottom: 5rem;
      padding: 0 1rem;
    }

    .musica-title {
      font-size: clamp(3.5rem, 8vw, 8rem);
      font-weight: 900;
      letter-spacing: -0.05em;
      line-height: 0.9;
      text-transform: uppercase;
      background: linear-gradient(135deg, var(--color-cyber-cyan), #7b2cbf, var(--color-cyber-pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 1.5rem;
      filter: drop-shadow(0 0 30px rgba(0, 240, 255, 0.2));
    }

    .musica-subtitle {
      font-family: var(--font-secondary);
      font-size: clamp(0.75rem, 2vw, 1rem);
      letter-spacing: 0.3em;
      color: var(--color-cyber-cyan);
      text-transform: uppercase;
      opacity: 0.8;
    }

    .track-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2.5rem;
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--gutter);
    }

    .track-card {
      background: var(--color-surface-musica);
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      overflow: hidden;
      cursor: pointer;
      position: relative;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .track-card:hover {
      transform: translateY(-8px);
      border-color: rgba(0, 240, 255, 0.5);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8), 0 0 25px rgba(0, 240, 255, 0.15);
    }

    .track-cover-container {
      aspect-ratio: 1 / 1;
      background: #000;
      position: relative;
      overflow: hidden;
    }

    .track-cover-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .track-card:hover .track-cover-img {
      transform: scale(1.08);
    }

    .track-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .track-card:hover .track-overlay {
      opacity: 1;
    }

    .track-play-btn {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: var(--color-cyber-cyan);
      color: #000000;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      cursor: pointer;
      box-shadow: 0 0 20px rgba(0, 240, 255, 0.4);
      transition: all 0.3s ease;
    }

    .track-play-btn:hover {
      background: #ffffff;
      transform: scale(1.1);
    }

    .track-info {
      padding: 1.5rem;
    }

    .track-title-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.5rem;
    }

    .track-card-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: #ffffff;
    }

    .track-card-artist {
      color: var(--color-cyber-cyan);
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .track-card-meta {
      display: flex;
      gap: 1.5rem;
      font-size: 0.75rem;
      color: var(--color-muted);
      font-family: var(--font-secondary);
    }

    .track-card-tag {
      background: rgba(0, 240, 255, 0.08);
      border: 1px solid rgba(0, 240, 255, 0.2);
      padding: 0.2rem 0.8rem;
      border-radius: 100px;
      color: var(--color-cyber-cyan);
    }

    /* Fixed Bottom Player */
    .cyber-player {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(5, 5, 8, 0.95);
      border-top: 1px solid rgba(0, 240, 255, 0.3);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      z-index: 9999;
      padding: 1.2rem 2rem;
      transition: all 0.4s ease;
      transform: translateY(100%);
    }

    .cyber-player.active {
      transform: translateY(0);
    }

    .player-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .player-cover {
      width: 50px;
      height: 50px;
      background: #111;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid rgba(0, 240, 255, 0.2);
      flex-shrink: 0;
    }

    .player-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .player-info {
      flex: 0 1 200px;
      min-width: 0;
    }

    .player-track-title {
      font-size: 0.9rem;
      font-weight: 700;
      color: #fff;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .player-track-artist {
      font-size: 0.75rem;
      color: var(--color-cyber-cyan);
    }

    .player-controls {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .player-btn {
      background: none;
      border: none;
      color: var(--color-cyber-cyan);
      cursor: pointer;
      padding: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }

    .player-btn:hover {
      color: #fff;
      text-shadow: 0 0 8px var(--color-cyber-cyan);
    }

    .player-play-btn {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--color-cyber-cyan);
      color: #000;
    }

    .player-play-btn:hover {
      background: #ffffff;
      transform: scale(1.05);
    }

    .player-timeline {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.7rem;
      font-family: var(--font-secondary);
      color: var(--color-muted);
    }

    .progress-bar-container {
      flex: 1;
      height: 4px;
      background: #222;
      border-radius: 10px;
      cursor: pointer;
      position: relative;
    }

    .progress-bar-fill {
      height: 100%;
      width: 0%;
      background: var(--color-cyber-cyan);
      border-radius: 10px;
      position: absolute;
      top: 0;
      left: 0;
    }

    .player-volume-container {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .volume-slider {
      width: 80px;
      height: 4px;
      background: #222;
      border-radius: 10px;
      cursor: pointer;
      position: relative;
    }

    .volume-slider-fill {
      height: 100%;
      width: 80%;
      background: var(--color-cyber-cyan);
      border-radius: 10px;
    }

    @media (max-width: 768px) {
      .player-inner {
        flex-wrap: wrap;
        gap: 1rem;
      }
      .player-timeline {
        order: 4;
        flex: 1 0 100%;
      }
      .player-volume-container {
        display: none;
      }
    }
  </style>

  <main class="musica-container">
    <div class="musica-header">
      <h1 class="musica-title">Música</h1>
      <p class="musica-subtitle">SÍNTESIS C5-REAL • VIBRACIONES INERCIALES</p>
    </div>

    <div class="track-grid" id="track-grid">
      <!-- Tracks loaded via script -->
    </div>

    <!-- ─── 06/06 MOSKVLOGIA / SOTA REFERENCE ─── -->
    <div class="musica-header" style="margin-top: 8rem; margin-bottom: 3rem;">
      <h2 class="musica-title" style="font-size: clamp(2rem, 5vw, 4rem);">MOSKVLOGIA</h2>
      <p class="musica-subtitle">CURATED SOTA REFERENCE • C5-REAL</p>
    </div>
    <div class="track-grid" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
      <div style="background: var(--color-surface-musica); border: 1px solid var(--glass-border); border-radius: 16px; padding: 1.5rem; transition: all 0.4s ease;" onmouseover="this.style.borderColor='rgba(0, 240, 255, 0.5)'; this.style.boxShadow='0 10px 30px rgba(0, 0, 0, 0.8), 0 0 20px rgba(0, 240, 255, 0.15)';" onmouseout="this.style.borderColor='var(--glass-border)'; this.style.boxShadow='none';">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <h3 style="font-size: 1.2rem; font-weight: 700; color: #fff;">MOSKVLOGIA</h3>
          <span style="font-family: var(--font-secondary); font-size: 0.65rem; color: var(--color-cyber-cyan); letter-spacing: 0.1em; padding: 0.2rem 0.6rem; border: 1px solid rgba(0, 240, 255, 0.3); border-radius: 4px; background: rgba(0, 240, 255, 0.05);">PLAYLIST</span>
        </div>
        <iframe data-testid="embed-iframe" style="border-radius:12px" src="https://open.spotify.com/embed/playlist/6WHIabEaqEd6cFPad3gSrx?utm_source=generator&theme=0" width="100%" height="352" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
      </div>
      
      <div style="background: var(--color-surface-musica); border: 1px solid var(--glass-border); border-radius: 16px; padding: 1.5rem; transition: all 0.4s ease;" onmouseover="this.style.borderColor='rgba(0, 240, 255, 0.5)'; this.style.boxShadow='0 10px 30px rgba(0, 0, 0, 0.8), 0 0 20px rgba(0, 240, 255, 0.15)';" onmouseout="this.style.borderColor='var(--glass-border)'; this.style.boxShadow='none';">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <h3 style="font-size: 1.2rem; font-weight: 700; color: #fff;">SOTA REFERENCE</h3>
          <span style="font-family: var(--font-secondary); font-size: 0.65rem; color: var(--color-cyber-pink); letter-spacing: 0.1em; padding: 0.2rem 0.6rem; border: 1px solid rgba(255, 0, 85, 0.3); border-radius: 4px; background: rgba(255, 0, 85, 0.05);">ÁLBUM</span>
        </div>
        <iframe style="border-radius:12px" src="https://open.spotify.com/embed/album/7ETLYPz4eggr9WNwyIqsML?utm_source=generator&theme=0" width="100%" height="352" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
      </div>
    </div>
  </main>

  <script>
    const tracks = [
      {
        id: 1,
        title: "Ecos del Cosmos",
        artist: "Borja Moskv",
        cover: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=400&q=80",
        genre: "Ambient / Sci-Fi",
        duration: "6:12"
      },
      {
        id: 2,
        title: "Glitch in the Mirror",
        artist: "Borja Moskv",
        cover: "https://images.unsplash.com/photo-1579546929518-9e396f3cc809?auto=format&fit=crop&w=400&q=80",
        genre: "Experimental / Glitch",
        duration: "4:32"
      },
      {
        id: 3,
        title: "32 Y Pico",
        artist: "Borja Moskv",
        cover: "https://images.unsplash.com/photo-1550684848-fac1c5b4e853?auto=format&fit=crop&w=400&q=80",
        genre: "Electronic",
        duration: "5:04"
      },
      {
        id: 4,
        title: "Patadas",
        artist: "Borja Moskv",
        cover: "https://images.unsplash.com/photo-1614850523459-c2f4c699c52e?auto=format&fit=crop&w=400&q=80",
        genre: "Electronic",
        duration: "3:45"
      },
      {
        id: 5,
        title: "4 Drogas",
        artist: "Borja Moskv",
        cover: "https://images.unsplash.com/photo-1557672172-298e090bd0f1?auto=format&fit=crop&w=400&q=80",
        genre: "Techno",
        duration: "4:15"
      },
      {
        id: 6,
        title: "Antes de las Guerras",
        artist: "Borja Moskv",
        cover: "https://images.unsplash.com/photo-1507608869274-d3177c8bb4c7?auto=format&fit=crop&w=400&q=80",
        genre: "Ambient",
        duration: "7:20"
      },
      {
        id: 7,
        title: "Void Cascade",
        artist: "Borja Moskv",
        cover: "https://images.unsplash.com/photo-1541701494587-cb58502866ab?auto=format&fit=crop&w=400&q=80",
        genre: "Ambient / Sci-Fi",
        duration: "5:58"
      }
    ];

    const renderCards = () => {
      const trackGrid = document.getElementById('track-grid');
      if (!trackGrid) return;
      
      trackGrid.innerHTML = tracks.map((track, index) => `
        <div class="track-card" data-index="${index}">
          <div class="track-cover-container">
            <img class="track-cover-img" src="${track.cover}" alt="Carátula de ${track.title}" loading="lazy" />
            <div class="track-overlay">
              <button class="track-play-btn" aria-label="Reproducir ${track.title}">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
              </button>
            </div>
          </div>
          <div class="track-info">
            <div class="track-title-row">
              <h3 class="track-card-title">${track.title}</h3>
            </div>
            <p class="track-card-artist">${track.artist}</p>
            <div class="track-card-meta">
              <span class="track-card-tag">${track.genre}</span>
              <span>${track.duration}</span>
            </div>
          </div>
        </div>
      `).join('');

      document.querySelectorAll('.track-card').forEach(card => {
        card.addEventListener('click', () => {
          const index = parseInt(card.getAttribute('data-index'));
          if (window.CyberAudioStore) {
             window.CyberAudioStore.playTrack(index);
          }
        });
      });
    };

    document.addEventListener('astro:page-load', renderCards);
    renderCards();
  </script>
</Layout>
