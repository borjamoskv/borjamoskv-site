<script>
    document.addEventListener('DOMContentLoaded', () => {
      // ── Site Header Scroll ──────────────────────────
      const header = document.getElementById('header');
      if (header) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 50) {
            header.classList.add('is-scrolled');
          } else {
            header.classList.remove('is-scrolled');
          }
        });
      }

      if (window.MOSKV?.chat?.init) window.MOSKV.chat.init();

      // ── Filter bar ──────────────────────────────────
      const filterBtns = document.querySelectorAll('.filter-btn');
      const cards      = document.querySelectorAll('.blog-card[data-category]');

      filterBtns.forEach(btn => {
        btn.setAttribute('aria-pressed', btn.classList.contains('active') ? 'true' : 'false');
        btn.addEventListener('click', () => {
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          filterBtns.forEach(b => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
          const filter = btn.dataset.filter;
          cards.forEach(card => {
            const match = filter === 'all' || card.dataset.category === filter;
            card.dataset.hidden = match ? 'false' : 'true';
          });
        });
      });



      // ── Substack RSS ───────────────────────────────
      (async function loadParagraphPosts() {
        const grid = document.getElementById('paragraphGrid');
        try {
          const res  = await fetch('https://api.rss2json.com/v1/api.json?rss_url=https://borjamoskv.substack.com/feed');
          const data = await res.json();
          if (data.status === 'ok' && data.items?.length) {
            grid.innerHTML = '';
            
            // Map Substack slugs to local HTML pages
            const slugMap = {
              'substack-mafia-autopsia-estructural': 'substack-mafia-autopsia-estructural.html',
              'ultramap-substrate': 'ultramap-substrate.html',
              'operacion-espejo': 'operacion-espejo.html',
              'substack-mafia-credibility-machine': 'substack-mafia-credibility-machine.html',
              'trazabilidad-narrativa-economica-social': 'trazabilidad-narrativa-economica-social.html',
              'bebes-en-africa-pajas-grupales-y-el-marron-con-hacienda': 'bebes-en-africa-pajas-grupales-y-el-marron-con-hacienda.html',
              'la-edad-de-la-friccion-el-ultimo': 'la-edad-de-la-friccion-el-ultimo.html',
              'hackear-la-atencion-por-que-pusimos': 'hackear-la-atencion-por-que-pusimos.html',
              'el-protocolo-rollins-a-great-day': 'el-protocolo-rollins-a-great-day.html',
              'la-solucion-intentada-es-el-problema': 'la-solucion-intentada-es-el-problema.html',
              'autopoiesis-de-un-domingo-por-la': 'autopoiesis-de-un-domingo-por-la.html',
              'autodidact-claude-opus-48-full-sota': 'autodidact-claude-opus-48-full-sota.html',
              'alcala-norte-we-need-to-talk': 'alcala-norte-we-need-to-talk.html',
              'hito-cortex-cruza-el-umbral-de-auto': 'hito-cortex-cruza-el-umbral-de-auto.html',
              'que-es-un-agente-historia-ia-cortex': 'que-es-un-agente-historia-ia-cortex.html',
              'sintetologia-agentica': 'sintetologia-agentica.html',
              'limerencia-epistemica': 'limerencia-epistemica.html',
              'cortex-persist-registro-de-hitos': 'cortex-persist-registro-de-hitos.html',
              'catarsis-colectiva-los-20-pilares': 'catarsis-colectiva.html',
              'idioma-nativo-progreso': 'idioma-nativo-progreso.html',
              'putos-gurus': 'gurus.html',
              'gon-y-el-intervalo-prohibido': 'gon-intervalo.html'
            };

            data.items.slice(0, 3).forEach(item => {
              const date = item.pubDate.split(' ')[0];
              let link = item.link;
              const matches = link.match(/\/p\/([a-z0-9-]+)/);
              let isLocal = false;
              if (matches && matches[1]) {
                const slug = matches[1];
                if (slugMap[slug]) {
                  link = slugMap[slug];
                  isLocal = true;
                }
              }

              const card = document.createElement('a');
              card.href  = link;
              if (!isLocal) {
                card.target = '_blank';
                card.rel    = 'noopener';
              }
              card.className = 'blog-card blog-card--third';
              card.innerHTML = `
                <div class="card-meta">
                  <span class="card-tag card-tag--paragraph">${isLocal ? 'Diario' : 'Substack'}</span>
                  <span class="card-date">${date}</span>
                </div>
                <h2 class="card-title" style="font-size:1.1rem">${item.title}</h2>
                <span class="card-cta">${isLocal ? 'Leer artículo →' : 'Leer en Substack →'}</span>
              `;
              grid.appendChild(card);
            });
          } else {
            grid.innerHTML = `<p style="color:rgba(224,224,224,0.3);font-size:0.85rem;padding:1rem 0;">No se encontraron entradas en Substack.</p>`;
          }
        } catch (e) {
          grid.innerHTML = `<p style="color:rgba(224,224,224,0.3);font-size:0.85rem;padding:1rem 0;">Error cargando Substack.</p>`;
        }
      })();
    });
  </script>
