    }

    .section-label {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(224, 224, 224, 0.25);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(224, 224, 224, 0.06);
    }

    .paragraph-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .paragraph-loader {
      grid-column: span 3;
      text-align: center;
      font-family: 'Orbitron', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: var(--accent-primary, #2E5090);
      padding: 2rem;
    }

    /* ── Divider ── */
    .blog-divider {
      max-width: 1200px;
      margin: 0 auto 2rem;
      padding: 0 2rem;
      border: none;
      height: 1px;
      background: rgba(224, 224, 224, 0.04);
    }

    /* ── Hidden filter state ── */
    .blog-card[data-hidden="true"] {
      display: none;
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .blog-card--featured { grid-column: span 12; }
      .blog-card--side      { grid-column: span 6; }
      .blog-card--half      { grid-column: span 6; }
      .blog-card--third     { grid-column: span 6; }
    }

    @media (max-width: 640px) {
      .blog-grid { gap: 1rem; }
      .blog-card--featured,
      .blog-card--side,
      .blog-card--half,
      .blog-card--third { grid-column: span 12; }
      .blog-hero { padding: 8rem 1.5rem 3rem; }
      .blog-filters { padding: 0 1.5rem 2rem; }
      .blog-grid,
      .paragraph-section { padding-left: 1.5rem; padding-right: 1.5rem; }
    }

    /* ── RITXIE HAWTING CHATQUITO (Industrial Noir Glassmorphism) ── */
    .chatquito-open-btn {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 1000;
      background: #0A0A0A;
      color: #FFF;
      border: 1px solid #2B3BE5;
      padding: 0.8rem 1.5rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      font-weight: 700;
      cursor: pointer;
      border-radius: 4px;
      box-shadow: 0 4px 20px rgba(43, 59, 229, 0.15), inset 0 0 10px rgba(43, 59, 229, 0.1);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .chatquito-open-btn:hover {
      background: #2B3BE5;
      box-shadow: 0 4px 25px rgba(43, 59, 229, 0.4);
      transform: translateY(-2px);
    }

    .chatquito-open-btn.hidden {
      opacity: 0;
      pointer-events: none;
      transform: scale(0.9) translateY(10px);
    }

    .chatquito {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      width: 380px;
      height: 520px;
      max-height: calc(100vh - 6rem);
      max-width: calc(100vw - 4rem);
      z-index: 1001;
      background: rgba(10, 10, 10, 0.85);
      backdrop-filter: blur(25px) saturate(180%);
      -webkit-backdrop-filter: blur(25px) saturate(180%);
      border: 1px solid rgba(43, 59, 229, 0.3);
      border-radius: 8px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 30px rgba(43, 59, 229, 0.05);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transform: translateY(20px) scale(0.95);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .chatquito.visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    .chatquito-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 1.25rem;
      background: rgba(43, 59, 229, 0.08);
      border-bottom: 1px solid rgba(43, 59, 229, 0.2);
    }

    .chatquito-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: #FFF;
      text-shadow: 0 0 8px rgba(43, 59, 229, 0.5);
    }

    .chatquito-controls {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .chatquito-voice-btn {
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.85rem;
      cursor: pointer;
      transition: color 0.2s ease, transform 0.2s ease;
      padding: 0.2rem;
    }

    .chatquito-voice-btn:hover {
      color: #2B3BE5;
      transform: scale(1.1);
    }

    .chatquito-voice-btn.muted {
      color: rgba(255, 255, 255, 0.2);
    }

    .chatquito-close {
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.9rem;
      cursor: pointer;
      transition: color 0.2s ease;
      padding: 0.2rem;
    }

    .chatquito-close:hover {
      color: #2B3BE5;
    }

    .chatquito-body {
      flex: 1;
      overflow-y: auto;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      scroll-behavior: smooth;
    }

    /* Custom Scrollbar for Chat Body */
    .chatquito-body::-webkit-scrollbar {
      width: 4px;
    }
    .chatquito-body::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.02);
    }
    .chatquito-body::-webkit-scrollbar-thumb {
      background: rgba(43, 59, 229, 0.3);
      border-radius: 2px;
    }
    .chatquito-body::-webkit-scrollbar-thumb:hover {
      background: #2B3BE5;
    }

    .chat-msg {
      max-width: 85%;
      padding: 0.75rem 1rem;
      border-radius: 6px;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 0.85rem;
      line-height: 1.4;
      opacity: 0;
      animation: chatquito-message-appear 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      will-change: transform, opacity;
    }

    @keyframes chatquito-message-appear {
      from {
        opacity: 0;
        transform: translateY(8px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .chat-msg.bot {
      align-self: flex-start;
      background: rgba(255, 255, 255, 0.04);
      color: #E0E0E0;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-top-left-radius: 0;
    }

    .chat-msg.user {
      align-self: flex-end;
      background: #2B3BE5;
      color: #FFF;
      border-top-right-radius: 0;
      box-shadow: 0 4px 12px rgba(43, 59, 229, 0.2);
    }

    .chatquito-input {
      padding: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(10, 10, 10, 0.5);
    }

    .chatquito-input input {
      width: 100%;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 4px;
      padding: 0.75rem 1rem;
      color: #FFF;
      font-family: inherit;
      font-size: 0.85rem;
      outline: none;
      transition: all 0.3s ease;
    }

    .chatquito-input input:focus {
      border-color: #2B3BE5;
      background: rgba(255, 255, 255, 0.05);
      box-shadow: 0 0 10px rgba(43, 59, 229, 0.2);
    }

    /* WASM Search Result Styles */
    .search-results-header {
      font-size: 0.75rem;
      color: #888;
      margin-bottom: 0.5rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding-bottom: 0.25rem;
    }

    .search-results-header strong {
      color: #2B3BE5;
    }

    .search-results-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      max-height: 280px;
      overflow-y: auto;
      padding-right: 4px;
    }

    .search-track-item {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 4px;
      padding: 0.6rem;
      transition: all 0.2s ease;
    }

    .search-track-item:hover {
      background: rgba(43, 59, 229, 0.05);
      border-color: rgba(43, 59, 229, 0.3);
    }

    .track-main-info {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.5rem;
      margin-bottom: 0.15rem;
    }

    .track-title {
      font-weight: 600;
      color: #FFF;
      font-size: 0.8rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 65%;
    }

    .track-artist {
      font-size: 0.7rem;
      color: #aaa;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 35%;
    }

    .track-sub-info {
      display: flex;
      justify-content: space-between;
      font-size: 0.65rem;
      color: #666;
      margin-bottom: 0.4rem;
    }

    .track-metrics {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .metric-bar-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .metric-label {
      font-size: 0.6rem;
      color: #888;
      min-width: 50px;
    }

    .metric-bar-bg {
      flex: 1;
      height: 3px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 2px;
      overflow: hidden;
    }

    .metric-bar-fill {
      height: 100%;
      border-radius: 2px;
    }

    .metric-bar-fill.valence {
      background: #2B3BE5;
    }

    /* ── Full card (spans 12 cols) ── */
    .blog-card--full {
      grid-column: span 12;
      padding: 3rem;
      min-height: 280px;
      background: rgba(43, 59, 229, 0.04);
      border-color: rgba(43, 59, 229, 0.15);
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      text-decoration: none;
      color: inherit;
      transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1),
                  border-color 0.3s ease,
                  background 0.3s ease;
    }

    .blog-card--full::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, transparent, var(--accent-primary, #FF0055), transparent);
      transform: scaleX(0);
      transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .blog-card--full:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 0, 85, 0.35);
      background: rgba(255, 0, 85, 0.04);
    }

    .blog-card--full:hover::before {
      transform: scaleX(1);
    }

    .blog-card--full .card-cta {
      margin-top: auto;
    }

    /* ── Excerpt Organizers ── */
    .excerpt-image {
      display: block;
      color: #E0E0E0;
      font-weight: 500;
      margin-bottom: 0.25rem;
    }
    
    .excerpt-context {
      display: block;
      color: rgba(224, 224, 224, 0.45);
      font-size: 0.85rem;
    }

    /* ── Subscription Card ── */
    .sub-section {
      max-width: 1200px;
      margin: 0 auto 3rem;
      padding: 0 2rem;
    }

    .sub-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .sub-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 50%, rgba(255, 0, 85, 0.08) 0%, transparent 60%);
      pointer-events: none;
    }

    .sub-content {
      flex: 1;
      max-width: 500px;
    }

    .sub-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 2.2rem;
      font-weight: 800;
      line-height: 1.1;
      color: #E0E0E0;
      margin-bottom: 0.75rem;
      letter-spacing: -0.03em;
    }

    .sub-description {
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      line-height: 1.6;
      color: rgba(224, 224, 224, 0.6);
      margin: 0;
    }

    .sub-form {
      display: flex;
      gap: 1rem;
      flex: 1;
      max-width: 480px;
      position: relative;
      z-index: 2;
    }

    .sub-input {
      flex: 1;
      background: rgba(10, 10, 10, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      color: #FFF;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s ease;
    }

    .sub-input:focus {
      border-color: #FF0055;
      box-shadow: 0 0 15px rgba(255, 0, 85, 0.25);
      background: rgba(10, 10, 10, 0.8);
    }

    .sub-btn {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: #FF0055;
      color: #FFF;
      border: none;
      border-radius: 8px;
      padding: 1rem 2rem;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 4px 15px rgba(255, 0, 85, 0.3);
    }

    .sub-btn:hover {
      background: #e6004c;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255, 0, 85, 0.5);
    }

    .sub-btn:active {
      transform: translateY(0);
    }


    /* ── Recommendations Block ── */
    .recommendations-section {
      max-width: 1200px;
      margin: 4rem auto 6rem;
      padding: 0 2rem;
    }

    .recommendations-heading {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.8rem;
      font-weight: 800;
      color: #E0E0E0;
      margin-bottom: 2rem;
      text-align: center;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
    }

    .recommendations-heading::before,
    .recommendations-heading::after {
      content: '';
      flex: 1;
      height: 1px;
      max-width: 150px;
      background: rgba(255, 255, 255, 0.08);
    }

    .recommendations-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .recommendation-card {
      background: rgba(255, 255, 255, 0.015);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 12px;
      padding: 2rem;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: all 0.3s ease;
    }

    .recommendation-card::before {
      content: '“';
      position: absolute;
      top: 1rem;
      left: 1.5rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 5rem;
      color: rgba(255, 0, 85, 0.1);
      line-height: 1;
      pointer-events: none;
    }

    .recommendation-quote {
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      line-height: 1.65;
      color: rgba(224, 224, 224, 0.7);
      margin-bottom: 1.5rem;
      position: relative;
      z-index: 1;
      font-style: italic;
    }

    .recommendation-author {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: #FF0055;
      text-transform: uppercase;
      margin: 0;
    }

    .recommendation-card:hover {
      border-color: rgba(43, 59, 229, 0.2);
      background: rgba(43, 59, 229, 0.02);
      transform: translateY(-2px);
    }

    /* ── Footer Overrides ── */
    .site-footer {
      background: rgba(12, 5, 20, 0.85) !important;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding: 6rem 2rem 4rem !important;
      margin-top: 6rem;
    }

    .footer-social-platforms {
      margin-top: 1.5rem;
      font-size: 0.7rem;
      color: rgba(224, 224, 224, 0.3);
      width: 100%;
      text-align: center;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .footer-social-platforms a {
      color: rgba(224, 224, 224, 0.4) !important;
      text-decoration: none !important;
      transition: color 0.2s ease;
      margin: 0 0.5rem;
    }

    .footer-social-platforms a:hover {
      color: #FF0055 !important;
    }

    /* ── Mobile adjustments & Mobile contrast/weight ── */
    @media (max-width: 1024px) {
      .recommendations-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .sub-card {
        flex-direction: column;
        align-items: stretch;
        padding: 2rem;
        text-align: center;
        gap: 2rem;
      }
      .sub-content {
        max-width: 100%;
      }
      .sub-form {
        max-width: 100%;
      }
      .recommendations-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .sub-form {
        flex-direction: column;
      }
      .sub-title {
        font-size: 1.8rem !important;
        font-weight: 900 !important;
      }
      .card-title {
        font-size: 1.5rem !important;
        font-weight: 800 !important;
      }
      .sub-btn, .filter-btn, .card-cta, .archive-btn {
        font-weight: 800 !important;
        font-size: 0.75rem !important;
      }
    }

    .metric-bar-fill.energy {
      background: #9D2BE5;
    }
  </style>
</head>
<body class="blog-page">
<!-- BOOT LOADER -->
<div class="loader" id="loader">
<div class="spinner"></div>
<div class="loader-text pulse-text">Cargando Diario...</div>
</div>
<!-- NAVIGATION -->
<header class="site-header" id="header">
<a class="brand" href="/">
      BORJA MOSKV <span class="brand-suffix">// EXERGIA-Ω</span>
</a>
<nav aria-label="Navegación Principal" class="site-nav">
<a class="nav-link" href="index.html#control-deck">DECK</a>
<a class="nav-link" href="index.html#discography">OBRAS</a>
<a class="nav-link" href="index.html#stills-gallery">GALERÍA</a>
<a class="nav-link" href="index.html#tour-dates">TOUR</a>
<a class="nav-link-ext is-active" href="/blog">DIARIO</a>
<a class="nav-link-ext" href="/gurus">GURÚS</a>
<a class="nav-link-ext" href="/benchmark-humo">BENCHMARK</a>
<a class="nav-link-ext" href="/blog/gon-intervalo">GON</a>
</nav>
<div class="system-status">
<span class="status-indicator"></span>
<span class="status-text">C5-REAL</span>
</div>
</header>
<!-- HERO -->
<header class="blog-hero">
<p class="blog-hero-label">Archivo Editorial</p>
<h1 class="blog-hero-title"><span>Diario</span></h1>
<p class="blog-hero-sub">Textos, análisis, set lore y crítica cultural. Sin relleno.</p>
</header>
<!-- SUBSCRIPTION BLOCK -->
<section class="sub-section">
<div class="sub-card">
<div class="sub-content">
<h2 class="sub-title">Ensayos, audio y artefactos...</h2>
<p class="sub-description">1–3 envíos/semana, mezcla de ensayo, audio y artefactos prácticos sobre IA y música.</p>
</div>
<form action="https://borjamoskv.substack.com/subscribe" class="sub-form" id="subForm" method="GET" target="_blank">
<input class="sub-input" name="email" placeholder="Tu correo electrónico" required="" type="email"/>
<button class="sub-btn" type="submit">Suscribirse</button>
</form>
</div>
</section>
<!-- FILTER BAR -->
<div aria-label="Filtrar por categoría" class="blog-filters" id="filterBar" role="toolbar">
<span class="filter-label">Filtrar</span>
<button class="filter-btn active" data-filter="all">Todo</button>
<button class="filter-btn" data-filter="ensayo">Ensayo</button>
<button class="filter-btn" data-filter="articulo">Artículo</button>
<button class="filter-btn" data-filter="analisis">Análisis</button>
<button class="filter-btn" data-filter="tecnica">Técnica</button>
<button class="filter-btn" data-filter="tesis">Tesis</button>
</div>
<!-- SECTION: POPULAR -->
<section class="blog-section-container">
<div class="section-label">Más populares</div>
<div class="blog-grid" id="popularGrid">
  {popularArticles.map((article, idx) => {
    const custom = customMetadata[article.id] || {};
    const category = custom.category || getCategory(article.data.tags, article.id);
    const displayTag = custom.tag || (article.data.tags && article.data.tags.length > 0 ? article.data.tags[0].replace('#', '') : 'Artículo');
    const layoutClass = idx === 0 ? 'blog-card--featured' : (idx === 1 ? 'blog-card--side' : 'blog-card--full');
    const ctaText = custom.cta || (category === 'tecnica' ? 'Ver análisis →' : (category === 'analisis' ? 'Ver autopsia →' : 'Leer ensayo →'));
    const contextText = custom.context || '';
    
    return (
      <a class={`blog-card ${layoutClass}`} data-category={category} href={`/blog/${article.id}`}>
        <div class="card-meta">
          <span class={`card-tag card-tag--${category}`}>{displayTag}</span>
          <span class="card-date">{formatDate(article.data.pubDate)}</span>
        </div>
        <h2 class="card-title">{article.data.title}</h2>
        <p class="card-excerpt">
          <span class="excerpt-image">{article.data.description}</span>
          {contextText && <span class="excerpt-context">{contextText}</span>}
        </p>
        <span class="card-cta">{ctaText}</span>
      </a>
    );
  })}
</div>
