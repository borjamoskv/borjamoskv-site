const months = {
  enero: 0, febrero: 1, marzo: 2, abril: 3, mayo: 4, junio: 5,
  julio: 6, agosto: 7, septiembre: 8, octubre: 9, noviembre: 10, diciembre: 11
};

function parseSpanishDate(dateStr) {
  if (!dateStr) return new Date(0);
  const cleaned = dateStr.replace(/‑/g, '-').replace(/‑/g, '-');
  const parts = cleaned.toLowerCase().split(' ');
  if (parts.length === 5) {
    const day = parseInt(parts[0], 10);
    const month = months[parts[2]];
    const year = parseInt(parts[4], 10);
    if (!isNaN(day) && month !== undefined && !isNaN(year)) {
      return new Date(year, month, day);
    }
  }
  const parsed = Date.parse(cleaned);
  return isNaN(parsed) ? new Date(0) : new Date(parsed);
}

function formatDate(dateStr) {
  const date = parseSpanishDate(dateStr);
  if (date.getTime() === 0) return dateStr;
  const yyyy = date.getFullYear();
  const mm = String(date.getMonth() + 1).padStart(2, '0');
  const dd = String(date.getDate()).padStart(2, '0');
  return `${yyyy}‑${mm}‑${dd}`; // non-breaking hyphen
}

function getCategory(tags, slug) {
  if (!tags) return 'articulo';
  const tagList = tags.map(t => t.toLowerCase().replace('#', ''));
  if (tagList.includes('ensayo')) return 'ensayo';
  if (tagList.includes('tesis')) return 'tesis';
  if (tagList.includes('analisis') || tagList.includes('análisis') || tagList.includes('investigación') || tagList.includes('investigacion')) return 'analisis';
  if (tagList.includes('tecnica') || tagList.includes('técnica') || tagList.includes('silicio') || tagList.includes('sistemas')) return 'tecnica';
  if (tagList.includes('articulo') || tagList.includes('artículo') || tagList.includes('cronica') || tagList.includes('crónica')) return 'articulo';
  
  if (slug.includes('historia-')) return 'tecnica';
  if (slug.includes('sintetologia-')) return 'tecnica';
  
  return 'articulo';
}

