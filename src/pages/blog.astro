const mdArticles = await getCollection('articles');

const formattedMdArticles = mdArticles.map(art => ({
  id: art.id,
  data: {
    title: art.data.title,
    description: art.data.description || '',
    pubDate: art.data.pubDate || '',
    tags: art.data.tags || []
  }
}));

const allArticles = [...formattedMdArticles, ...standaloneArticles];

const sortedArticles = allArticles.sort((a, b) => {
  const dateA = parseSpanishDate(a.data.pubDate);
  const dateB = parseSpanishDate(b.data.pubDate);
  return dateB.getTime() - dateA.getTime();
});

const popularSlugs = ['hito-nobel', 'como-suena-jarana-dor', 'termodinamica-de-agentes'];

const popularArticles = sortedArticles.filter(a => popularSlugs.includes(a.id));
popularArticles.sort((a, b) => popularSlugs.indexOf(a.id) - popularSlugs.indexOf(b.id));

const recentArticles = sortedArticles.filter(a => !popularSlugs.includes(a.id));
