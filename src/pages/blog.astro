<link href="/cortex-terminal.css" rel="stylesheet"/>
<style>
    /* ═══════════════════════════════════════════════════
       BLOG PAGE — Industrial Noir Editorial System
       ═══════════════════════════════════════════════════ */

    /* ── Page shell ── */
    .blog-page {
      min-height: 100vh;
      background: #0c0514; /* Deep purple background */
      color: #F3F4F6;
      --bg-color: #0c0514;
      --accent-primary: #FF0055; /* Pink */
      --accent-secondary: #2B3BE5; /* YInMn Blue */
    }

    /* ── Hero header ── */
    .blog-hero {
      padding: 10rem 2rem 5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .blog-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 25% 60%, rgba(43, 59, 229, 0.22) 0%, transparent 55%),
        radial-gradient(ellipse at 75% 20%, rgba(255, 0, 85, 0.12) 0%, transparent 45%);
      pointer-events: none;
    }

    .blog-hero-label {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: var(--accent-primary, #FF0055);
      margin-bottom: 1.5rem;
    }

    .blog-hero-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(3rem, 9vw, 7rem);
      font-weight: 900;
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: #E0E0E0;
      margin-bottom: 1.5rem;
    }

    .blog-hero-title span {
      background: linear-gradient(135deg, #FF0055, #2B3BE5);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .blog-hero-sub {
      font-family: 'Inter', sans-serif;
      font-size: 1.05rem;
      font-weight: 300;
      line-height: 1.7;
      color: rgba(224, 224, 224, 0.5);
      max-width: 520px;
      margin: 0 auto;
    }

    /* ── Filter bar ── */
    .blog-filters {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      padding: 0 2rem 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .filter-label {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(224, 224, 224, 0.3);
      margin-right: 0.5rem;
    }

    .filter-btn {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.4rem 1rem;
      border: 1px solid rgba(224, 224, 224, 0.08);
      border-radius: 9999px;
      background: transparent;
      color: rgba(224, 224, 224, 0.45);
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .filter-btn:hover {
      border-color: var(--accent-primary, #2E5090);
      color: #E0E0E0;
    }

    .filter-btn.active {
      background: var(--accent-primary, #2E5090);
      border-color: var(--accent-primary, #2E5090);
      color: #E0E0E0;
    }

    /* ── Blog grid ── */
    .blog-grid {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem 6rem;
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1.5rem;
    }

    /* ── Base card ── */
    .blog-card {
      display: flex;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      padding: 2rem;
      text-decoration: none;
      color: inherit;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1),
                  border-color 0.3s ease,
                  background 0.3s ease;
    }

    .blog-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, transparent, var(--accent-primary, #FF0055), transparent);
      transform: scaleX(0);
      transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .blog-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 0, 85, 0.35);
      background: rgba(255, 0, 85, 0.04);
    }

    .blog-card:hover::before {
      transform: scaleX(1);
    }

    /* ── Featured card (spans 8 cols) ── */
    .blog-card--featured {
      grid-column: span 8;
      padding: 3rem;
      min-height: 340px;
      background: rgba(43, 59, 229, 0.06);
      border-color: rgba(43, 59, 229, 0.2);
    }

    .blog-card--featured::before {
      height: 4px;
      background: linear-gradient(90deg, #FF0055, #2B3BE5 50%, transparent);
      transform: scaleX(1);
    }

    .blog-card--featured .card-title {
      font-size: clamp(1.6rem, 3vw, 2.4rem);
    }

    /* ── Side card (spans 4 cols) ── */
    .blog-card--side {
      grid-column: span 4;
    }

    /* ── Half card (spans 6 cols) ── */
    .blog-card--half {
      grid-column: span 6;
    }

    /* ── Third card (spans 4 cols) ── */
    .blog-card--third {
      grid-column: span 4;
    }

    /* ── Card internals ── */
    .card-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }

    .card-tag {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      border: 1px solid currentColor;
      color: var(--accent-primary, #2E5090);
    }

    .card-tag--ensayo  { color: #FF6600; border-color: rgba(255, 102, 0, 0.4); }
    .card-tag--tecnica { color: #2E5090; border-color: rgba(46, 80, 144, 0.4); }
    .card-tag--analisis{ color: #5a7ed6; border-color: rgba(90, 126, 214, 0.4); }
    .card-tag--articulo{ color: #E5B94B; border-color: rgba(229, 185, 75, 0.4); }
    .card-tag--tesis   { color: #b4ff00; border-color: rgba(180, 255, 0, 0.4); }
    .card-tag--paragraph{ color: rgba(224,224,224,0.4); border-color: rgba(224,224,224,0.12); }

    .card-date {
      font-family: 'Inter', sans-serif;
      font-size: 0.75rem;
      color: rgba(224, 224, 224, 0.3);
      letter-spacing: 0.05em;
    }

    .card-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.3rem;
      font-weight: 700;
      line-height: 1.25;
      letter-spacing: -0.02em;
      color: #E0E0E0;
      margin-bottom: 1rem;
      flex: 1;
    }

    .card-excerpt {
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      line-height: 1.65;
      color: rgba(224, 224, 224, 0.5);
      margin-bottom: 1.5rem;
    }

    .card-cta {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent-primary, #2E5090);
      margin-top: auto;
      transition: color 0.2s ease, letter-spacing 0.2s ease;
    }

    .blog-card:hover .card-cta {
      color: #5a7ed6;
      letter-spacing: 0.28em;
    }

    /* ── Paragraph dynamic section ── */
    .paragraph-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem 2rem;
    }

    .section-label {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(224, 224, 224, 0.25);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(224, 224, 224, 0.06);
    }

    .paragraph-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .paragraph-loader {
      grid-column: span 3;
      text-align: center;
      font-family: 'Orbitron', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: var(--accent-primary, #2E5090);
      padding: 2rem;
    }

    /* ── Divider ── */
    .blog-divider {
      max-width: 1200px;
      margin: 0 auto 2rem;
      padding: 0 2rem;
      border: none;
      height: 1px;
      background: rgba(224, 224, 224, 0.04);
    }

    /* ── Hidden filter state ── */
    .blog-card[data-hidden="true"] {
      display: none;
    }

    /* ── Responsive ── */
    @media (max-width: 1024px) {
      .blog-card--featured { grid-column: span 12; }
      .blog-card--side      { grid-column: span 6; }
      .blog-card--half      { grid-column: span 6; }
      .blog-card--third     { grid-column: span 6; }
    }

    @media (max-width: 640px) {
      .blog-grid { gap: 1rem; }
      .blog-card--featured,
      .blog-card--side,
      .blog-card--half,
      .blog-card--third { grid-column: span 12; }
      .blog-hero { padding: 8rem 1.5rem 3rem; }
      .blog-filters { padding: 0 1.5rem 2rem; }
      .blog-grid,
      .paragraph-section { padding-left: 1.5rem; padding-right: 1.5rem; }
    }

    /* ── RITXIE HAWTING CHATQUITO (Industrial Noir Glassmorphism) ── */
    .chatquito-open-btn {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 1000;
      background: #0A0A0A;
      color: #FFF;
      border: 1px solid #2B3BE5;
      padding: 0.8rem 1.5rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      font-weight: 700;
      cursor: pointer;
      border-radius: 4px;
      box-shadow: 0 4px 20px rgba(43, 59, 229, 0.15), inset 0 0 10px rgba(43, 59, 229, 0.1);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .chatquito-open-btn:hover {
      background: #2B3BE5;
      box-shadow: 0 4px 25px rgba(43, 59, 229, 0.4);
      transform: translateY(-2px);
    }

    .chatquito-open-btn.hidden {
      opacity: 0;
      pointer-events: none;
      transform: scale(0.9) translateY(10px);
    }

    .chatquito {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      width: 380px;
      height: 520px;
      max-height: calc(100vh - 6rem);
      max-width: calc(100vw - 4rem);
      z-index: 1001;
      background: rgba(10, 10, 10, 0.85);
      backdrop-filter: blur(25px) saturate(180%);
      -webkit-backdrop-filter: blur(25px) saturate(180%);
      border: 1px solid rgba(43, 59, 229, 0.3);
      border-radius: 8px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 30px rgba(43, 59, 229, 0.05);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transform: translateY(20px) scale(0.95);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .chatquito.visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    .chatquito-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 1.25rem;
      background: rgba(43, 59, 229, 0.08);
      border-bottom: 1px solid rgba(43, 59, 229, 0.2);
    }

    .chatquito-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: #FFF;
      text-shadow: 0 0 8px rgba(43, 59, 229, 0.5);
    }

    .chatquito-controls {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .chatquito-voice-btn {
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.85rem;
      cursor: pointer;
      transition: color 0.2s ease, transform 0.2s ease;
      padding: 0.2rem;
    }

    .chatquito-voice-btn:hover {
      color: #2B3BE5;
      transform: scale(1.1);
    }

    .chatquito-voice-btn.muted {
      color: rgba(255, 255, 255, 0.2);
    }

    .chatquito-close {
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.9rem;
      cursor: pointer;
      transition: color 0.2s ease;
      padding: 0.2rem;
    }

    .chatquito-close:hover {
      color: #2B3BE5;
    }

    .chatquito-body {
      flex: 1;
      overflow-y: auto;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      scroll-behavior: smooth;
    }

    /* Custom Scrollbar for Chat Body */
    .chatquito-body::-webkit-scrollbar {
      width: 4px;
    }
    .chatquito-body::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.02);
    }
    .chatquito-body::-webkit-scrollbar-thumb {
      background: rgba(43, 59, 229, 0.3);
      border-radius: 2px;
    }
    .chatquito-body::-webkit-scrollbar-thumb:hover {
      background: #2B3BE5;
    }

    .chat-msg {
      max-width: 85%;
      padding: 0.75rem 1rem;
      border-radius: 6px;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 0.85rem;
      line-height: 1.4;
      opacity: 0;
      animation: chatquito-message-appear 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      will-change: transform, opacity;
    }

    @keyframes chatquito-message-appear {
      from {
        opacity: 0;
        transform: translateY(8px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .chat-msg.bot {
      align-self: flex-start;
      background: rgba(255, 255, 255, 0.04);
      color: #E0E0E0;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-top-left-radius: 0;
    }

    .chat-msg.user {
      align-self: flex-end;
      background: #2B3BE5;
      color: #FFF;
      border-top-right-radius: 0;
      box-shadow: 0 4px 12px rgba(43, 59, 229, 0.2);
    }

    .chatquito-input {
      padding: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(10, 10, 10, 0.5);
    }

    .chatquito-input input {
      width: 100%;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 4px;
      padding: 0.75rem 1rem;
      color: #FFF;
      font-family: inherit;
      font-size: 0.85rem;
      outline: none;
      transition: all 0.3s ease;
    }

    .chatquito-input input:focus {
      border-color: #2B3BE5;
      background: rgba(255, 255, 255, 0.05);
      box-shadow: 0 0 10px rgba(43, 59, 229, 0.2);
    }

    /* WASM Search Result Styles */
    .search-results-header {
      font-size: 0.75rem;
      color: #888;
      margin-bottom: 0.5rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding-bottom: 0.25rem;
    }

    .search-results-header strong {
      color: #2B3BE5;
    }

    .search-results-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      max-height: 280px;
      overflow-y: auto;
      padding-right: 4px;
    }

    .search-track-item {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 4px;
      padding: 0.6rem;
      transition: all 0.2s ease;
    }

    .search-track-item:hover {
      background: rgba(43, 59, 229, 0.05);
      border-color: rgba(43, 59, 229, 0.3);
    }

    .track-main-info {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.5rem;
      margin-bottom: 0.15rem;
    }

    .track-title {
      font-weight: 600;
      color: #FFF;
      font-size: 0.8rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 65%;
    }

    .track-artist {
      font-size: 0.7rem;
      color: #aaa;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 35%;
    }

    .track-sub-info {
      display: flex;
      justify-content: space-between;
      font-size: 0.65rem;
      color: #666;
      margin-bottom: 0.4rem;
    }

    .track-metrics {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .metric-bar-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .metric-label {
      font-size: 0.6rem;
      color: #888;
      min-width: 50px;
    }

    .metric-bar-bg {
      flex: 1;
      height: 3px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 2px;
      overflow: hidden;
    }

    .metric-bar-fill {
      height: 100%;
      border-radius: 2px;
    }

    .metric-bar-fill.valence {
      background: #2B3BE5;
    }

    /* ── Full card (spans 12 cols) ── */
    .blog-card--full {
      grid-column: span 12;
      padding: 3rem;
      min-height: 280px;
      background: rgba(43, 59, 229, 0.04);
      border-color: rgba(43, 59, 229, 0.15);
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      text-decoration: none;
      color: inherit;
      transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1),
                  border-color 0.3s ease,
                  background 0.3s ease;
    }

    .blog-card--full::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, transparent, var(--accent-primary, #FF0055), transparent);
      transform: scaleX(0);
      transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .blog-card--full:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 0, 85, 0.35);
      background: rgba(255, 0, 85, 0.04);
    }

    .blog-card--full:hover::before {
      transform: scaleX(1);
    }

    .blog-card--full .card-cta {
      margin-top: auto;
    }

    /* ── Excerpt Organizers ── */
    .excerpt-image {
      display: block;
      color: #E0E0E0;
      font-weight: 500;
      margin-bottom: 0.25rem;
    }
    
    .excerpt-context {
      display: block;
      color: rgba(224, 224, 224, 0.45);
      font-size: 0.85rem;
    }

    /* ── Subscription Card ── */
    .sub-section {
      max-width: 1200px;
      margin: 0 auto 3rem;
      padding: 0 2rem;
    }

    .sub-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .sub-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 50%, rgba(255, 0, 85, 0.08) 0%, transparent 60%);
      pointer-events: none;
    }

    .sub-content {
      flex: 1;
      max-width: 500px;
    }

    .sub-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 2.2rem;
      font-weight: 800;
      line-height: 1.1;
      color: #E0E0E0;
      margin-bottom: 0.75rem;
      letter-spacing: -0.03em;
    }

    .sub-description {
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      line-height: 1.6;
      color: rgba(224, 224, 224, 0.6);
      margin: 0;
    }

    .sub-form {
      display: flex;
      gap: 1rem;
      flex: 1;
      max-width: 480px;
      position: relative;
      z-index: 2;
    }

    .sub-input {
      flex: 1;
      background: rgba(10, 10, 10, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.1);
