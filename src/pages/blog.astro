---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Diario — Borja Moskv">
  <style>
    /* ═══════════════════════════════════════════════════
       BLOG PAGE — Industrial Noir Editorial System
       ═══════════════════════════════════════════════════ */

    .blog-page {
      min-height: 100vh;
      color: var(--color-parchment);
      --bg-color: transparent;
      --accent-primary: var(--color-yinmn);
      --accent-secondary: var(--color-amber);
      padding-top: 8rem;
      padding-bottom: 10rem;
    }

    /* ── Hero header ── */
    .blog-hero {
      padding: 4rem 2rem 5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
      max-width: var(--max-w);
      margin: 0 auto;
    }

    .blog-hero-label {
      font-family: var(--font-secondary);
      font-size: 0.7rem;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: var(--color-amber);
      margin-bottom: 1.5rem;
      text-shadow: 0 0 20px rgba(255, 159, 28, 0.3);
    }

    .blog-hero-title {
      font-family: var(--font-primary);
      font-size: clamp(3.5rem, 8vw, 8rem);
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: -0.04em;
      color: var(--color-parchment);
      margin-bottom: 1.5rem;
      text-transform: uppercase;
    }

    .blog-hero-title span {
      background: linear-gradient(135deg, var(--color-yinmn), var(--color-amber));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .blog-hero-sub {
      font-family: var(--font-primary);
      font-size: 1.1rem;
      font-weight: 300;
      line-height: 1.7;
      color: var(--color-muted);
      max-width: 600px;
      margin: 0 auto;
    }

    /* ── Filter bar ── */
    .blog-filters {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      padding: 0 2rem 3rem;
      max-width: var(--max-w);
      margin: 0 auto;
    }

    .filter-label {
      font-family: var(--font-secondary);
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(243, 244, 246, 0.35);
      margin-right: 0.5rem;
    }

    .filter-btn {
      font-family: var(--font-secondary);
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.5rem 1.2rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 4px;
      background: rgba(10, 10, 10, 0.4);
      color: rgba(243, 244, 246, 0.55);
      cursor: pointer;
      transition: all 0.25s var(--ease-omega);
    }

    .filter-btn:hover {
      border-color: var(--color-yinmn);
      color: #FFF;
      box-shadow: 0 0 15px rgba(43, 59, 229, 0.3);
    }

    .filter-btn.active {
      background: var(--color-yinmn);
      border-color: var(--color-yinmn);
      color: #FFF;
      box-shadow: 0 0 20px rgba(43, 59, 229, 0.4);
    }

    /* ── Search Bar Style ── */
    .blog-search-container {
      position: relative;
      margin-left: auto;
      min-width: 300px;
    }

    .blog-search-input {
      width: 100%;
      background: rgba(10, 10, 10, 0.55);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 4px;
      padding: 0.6rem 1rem 0.6rem 2.5rem;
      color: var(--color-parchment);
      font-family: var(--font-primary);
      font-size: 0.85rem;
      outline: none;
      transition: all 0.3s var(--ease-omega);
      backdrop-filter: blur(5px);
    }

    .blog-search-input:focus {
      border-color: var(--color-yinmn);
      background: rgba(10, 10, 10, 0.85);
      box-shadow: 0 0 20px rgba(43, 59, 229, 0.25);
    }

    .search-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(243, 244, 246, 0.35);
      pointer-events: none;
      transition: color 0.3s ease;
    }

    .blog-search-input:focus + .search-icon {
      color: var(--color-yinmn);
    }

    @media (max-width: 768px) {
      .blog-search-container {
        margin-left: 0;
        width: 100%;
        margin-top: 1rem;
      }
    }

    /* ── Blog grid ── */
    .blog-grid {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 2rem 6rem;
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1.75rem;
      will-change: transform;
      transform-origin: center top;
    }

    /* ── Base card ── */
    .blog-card {
      display: flex;
      flex-direction: column;
      background: rgba(10, 10, 10, 0.45);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 8px;
      padding: 2.2rem;
      text-decoration: none;
      color: inherit;
      position: relative;
      overflow: hidden;
      transition: transform 0.4s var(--ease-omega),
                  border-color 0.4s var(--ease-omega),
                  background-color 0.4s var(--ease-omega);
    }

    .blog-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, transparent, var(--color-yinmn), transparent);
      transform: scaleX(0);
      transition: transform 0.4s var(--ease-omega);
    }

    .blog-card:hover {
      border-color: rgba(43, 59, 229, 0.35);
      background: rgba(43, 59, 229, 0.03);
    }

    .blog-card:hover::before {
      transform: scaleX(1);
    }

    /* ── Featured card ── */
    .blog-card--featured {
      grid-column: span 8;
      padding: 3.5rem;
      min-height: 360px;
      background: rgba(43, 59, 229, 0.03);
      border-color: rgba(43, 59, 229, 0.15);
    }

    .blog-card--featured::before {
      height: 4px;
      background: linear-gradient(90deg, var(--color-yinmn), var(--color-amber), transparent);
      transform: scaleX(1);
    }

    .blog-card--featured .card-title {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    }

    /* ── Cortex Sovereign Card ── */
    .blog-card--cortex {
      background: linear-gradient(135deg, rgba(43, 59, 229, 0.06) 0%, rgba(255, 159, 28, 0.03) 100%) !important;
      border-color: rgba(43, 59, 229, 0.25) !important;
      box-shadow: 0 0 30px rgba(43, 59, 229, 0.1), inset 0 0 20px rgba(43, 59, 229, 0.02);
    }

    .blog-card--cortex::before {
      height: 4px;
      background: linear-gradient(90deg, var(--color-yinmn), var(--color-amber), var(--color-yinmn)) !important;
      transform: scaleX(1) !important;
    }

    .blog-card--cortex:hover {
      border-color: rgba(255, 159, 28, 0.4) !important;
      box-shadow: 0 0 40px rgba(255, 159, 28, 0.15), inset 0 0 25px rgba(43, 59, 229, 0.05) !important;
    }

    .blog-card--side { grid-column: span 4; }
    .blog-card--half { grid-column: span 6; }
    .blog-card--third { grid-column: span 4; }

    /* ── Full card (spans 12 cols) ── */
    .blog-card--full {
      grid-column: span 12;
      padding: 3.5rem;
      min-height: 300px;
      background: rgba(43, 59, 229, 0.02);
      border-color: rgba(43, 59, 229, 0.12);
    }

    .blog-card--full::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: linear-gradient(90deg, transparent, var(--color-amber), transparent);
      transform: scaleX(0);
      transition: transform 0.4s var(--ease-omega);
    }

    .blog-card--full:hover {
      border-color: rgba(255, 159, 28, 0.3);
      background: rgba(255, 159, 28, 0.02);
    }

    .blog-card--full:hover::before {
      transform: scaleX(1);
    }

    /* ── Card internals ── */
    .card-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }

    .card-tag {
      font-family: var(--font-secondary);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: 2px;
      border: 1px solid currentColor;
      font-weight: 700;
    }

    .card-tag--ensayo   { color: var(--color-amber); border-color: rgba(255, 159, 28, 0.3); }
    .card-tag--tecnica  { color: var(--color-yinmn); border-color: rgba(43, 59, 229, 0.3); }
    .card-tag--analisis { color: #00f0ff; border-color: rgba(0, 240, 255, 0.3); }
    .card-tag--articulo { color: var(--color-oxide); border-color: rgba(255, 215, 0, 0.3); }
    .card-tag--tesis    { color: #b4ff00; border-color: rgba(180, 255, 0, 0.3); }
    .card-tag--paragraph{ color: var(--color-muted); border-color: rgba(255, 255, 255, 0.1); }

    .card-date {
      font-family: var(--font-secondary);
      font-size: 0.75rem;
      color: rgba(243, 244, 246, 0.35);
      letter-spacing: 0.05em;
    }

    .card-title {
      font-family: var(--font-primary);
      font-size: 1.4rem;
      font-weight: 800;
      line-height: 1.25;
      letter-spacing: -0.02em;
      color: var(--color-parchment);
      margin-bottom: 1.25rem;
      flex: 1;
    }

    .card-excerpt {
      font-family: var(--font-primary);
      font-size: 0.95rem;
      line-height: 1.65;
      color: var(--color-muted);
      margin-bottom: 1.5rem;
    }

    .excerpt-image {
      display: block;
      color: var(--color-parchment);
      font-weight: 500;
      margin-bottom: 0.4rem;
    }
    
    .excerpt-context {
      display: block;
      color: var(--color-muted);
      font-size: 0.85rem;
    }

    .card-cta {
      font-family: var(--font-secondary);
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-amber);
      margin-top: auto;
      transition: color 0.25s var(--ease-omega), letter-spacing 0.25s var(--ease-omega);
      font-weight: 700;
    }

    .blog-card:hover .card-cta {
      color: #FFF;
      letter-spacing: 0.25em;
    }

    /* ── Subscription Card ── */
    .sub-section {
      max-width: var(--max-w);
      margin: 0 auto 4rem;
      padding: 0 2rem;
    }

    .sub-card {
      background: rgba(10, 10, 10, 0.55);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 159, 28, 0.15);
      border-radius: 8px;
      padding: 3.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
    }

    .sub-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 85% 50%, rgba(43, 59, 229, 0.08) 0%, transparent 60%);
      pointer-events: none;
    }

    .sub-content {
      flex: 1;
      max-width: 550px;
    }

    .sub-title {
      font-family: var(--font-primary);
      font-size: 2.2rem;
      font-weight: 900;
      line-height: 1.1;
      color: var(--color-parchment);
      margin-bottom: 0.75rem;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }

    .sub-description {
      font-family: var(--font-primary);
      font-size: 1rem;
      line-height: 1.65;
      color: var(--color-muted);
      margin: 0;
    }

    .sub-form {
      display: flex;
      gap: 1rem;
      flex: 1;
      max-width: 480px;
      position: relative;
      z-index: 2;
    }

    .sub-input {
      flex: 1;
      background: rgba(5, 5, 5, 0.75);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      padding: 1rem 1.25rem;
      color: #FFF;
      font-family: var(--font-primary);
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s var(--ease-omega);
    }

    .sub-input:focus {
      border-color: var(--color-amber);
      box-shadow: 0 0 15px rgba(255, 159, 28, 0.25);
    }

    .sub-btn {
      font-family: var(--font-secondary);
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: var(--color-amber);
      color: #000;
      border: none;
      border-radius: 4px;
      padding: 1rem 2rem;
      cursor: pointer;
      transition: all 0.3s var(--ease-omega);
      box-shadow: 0 4px 15px rgba(255, 159, 28, 0.25);
    }

    .sub-btn:hover {
      background: #FFF;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(255, 255, 255, 0.3);
    }

    /* ── Recommendations Block ── */
    .recommendations-section {
      max-width: var(--max-w);
      margin: 4rem auto 6rem;
      padding: 0 2rem;
    }

    .recommendations-heading {
      font-family: var(--font-primary);
      font-size: 2rem;
      font-weight: 900;
      color: var(--color-parchment);
      margin-bottom: 3rem;
      text-align: center;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      text-transform: uppercase;
    }

    .recommendations-heading::before,
    .recommendations-heading::after {
      content: '';
      flex: 1;
      height: 1px;
      max-width: 150px;
      background: rgba(255, 255, 255, 0.08);
    }

    .recommendations-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }

    .recommendation-card {
      background: rgba(10, 10, 10, 0.4);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 8px;
      padding: 2.2rem;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: all 0.3s var(--ease-omega);
    }

    .recommendation-card::before {
      content: '“';
      position: absolute;
      top: 1rem;
      left: 1.5rem;
      font-family: var(--font-primary);
      font-size: 6rem;
      color: rgba(43, 59, 229, 0.08);
      line-height: 1;
      pointer-events: none;
    }

    .recommendation-quote {
      font-family: var(--font-primary);
      font-size: 0.95rem;
      line-height: 1.7;
      color: rgba(243, 244, 246, 0.7);
      margin-bottom: 1.75rem;
      position: relative;
      z-index: 1;
      font-style: italic;
    }

    .recommendation-author {
      font-family: var(--font-secondary);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--color-yinmn);
      text-transform: uppercase;
      margin: 0;
    }

    .recommendation-card:hover {
      border-color: rgba(43, 59, 229, 0.2);
      background: rgba(43, 59, 229, 0.02);
      transform: translateY(-3px);
    }

    /* ── Substack RSS Feed ── */
    .paragraph-section {
      max-width: var(--max-w);
      margin: 0 auto 2rem;
      padding: 0 2rem 4rem;
    }

    .section-label {
      font-family: var(--font-secondary);
      font-size: 0.65rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(243, 244, 246, 0.3);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.06);
    }

    .paragraph-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }

    .paragraph-loader {
      grid-column: span 3;
      text-align: center;
      font-family: var(--font-secondary);
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: var(--color-amber);
      padding: 3rem;
    }

    .blog-divider {
      max-width: var(--max-w);
      margin: 0 auto 3rem;
      padding: 0 2rem;
      border: none;
      height: 1px;
      background: rgba(255, 255, 255, 0.06);
    }

    /* ── Uniform grid filter state ── */
    .blog-grid.is-filtered .blog-card {
      grid-column: span 4 !important;
      min-height: auto !important;
    }

    @media (max-width: 1024px) {
      .blog-grid.is-filtered .blog-card {
        grid-column: span 6 !important;
      }
    }

    @media (max-width: 640px) {
      .blog-grid.is-filtered .blog-card {
        grid-column: span 12 !important;
      }
    }

    @keyframes cardFadeIn {
      from {
        opacity: 0;
        transform: translateY(15px) scale(0.97);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .blog-card:not([data-hidden="true"]):not([data-search-hidden="true"]) {
      animation: cardFadeIn 0.35s var(--ease-omega) forwards;
    }

    .blog-card[data-hidden="true"],
    .blog-card[data-search-hidden="true"] {
      display: none !important;
    }

    @media (max-width: 1024px) {
      .blog-card--featured { grid-column: span 12; }
      .blog-card--side      { grid-column: span 6; }
      .blog-card--half      { grid-column: span 6; }
      .blog-card--third     { grid-column: span 6; }
      .recommendations-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .sub-card {
        flex-direction: column;
        align-items: stretch;
        padding: 2.5rem;
        text-align: center;
        gap: 2rem;
      }
      .sub-content, .sub-form { max-width: 100%; }
      .recommendations-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 640px) {
      .blog-grid { gap: 1rem; }
      .blog-card--featured,
      .blog-card--side,
      .blog-card--half,
      .blog-card--third { grid-column: span 12; }
      .blog-hero { padding: 4rem 1.5rem 2rem; }
      .blog-filters { padding: 0 1.5rem 2rem; }
      .blog-grid, .paragraph-section { padding-left: 1.5rem; padding-right: 1.5rem; }
      .sub-form { flex-direction: column; }
      .sub-title { font-size: 1.8rem !important; }
      .card-title { font-size: 1.3rem !important; }
    }

    /* ── RITXIE HAWTING CHATQUITO (OS-Level Draggable HUD Module) ── */
    .chatquito-open-btn {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 999;
      background: var(--color-void);
      color: #FFF;
      border: 1px solid var(--color-yinmn);
      padding: 0.8rem 1.5rem;
      font-family: var(--font-secondary);
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      font-weight: 700;
      cursor: pointer;
      border-radius: 4px;
      box-shadow: 0 4px 25px rgba(43, 59, 229, 0.15), inset 0 0 12px rgba(43, 59, 229, 0.05);
      transition: all 0.3s var(--ease-omega);
    }

    .chatquito-open-btn:hover {
      background: var(--color-yinmn);
      box-shadow: 0 4px 30px rgba(43, 59, 229, 0.4);
      transform: translateY(-2px);
    }

    .chatquito-open-btn.hidden {
      opacity: 0;
      pointer-events: none;
      transform: scale(0.9) translateY(10px);
    }

    .chatquito {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      width: 400px;
      height: 540px;
      max-height: calc(100vh - 6rem);
      max-width: calc(100vw - 4rem);
      z-index: 1000;
      background: rgba(10, 10, 10, 0.82);
      backdrop-filter: blur(25px) saturate(180%);
      -webkit-backdrop-filter: blur(25px) saturate(180%);
      border: 1px solid rgba(43, 59, 229, 0.3);
      border-radius: 8px;
      box-shadow: 0 15px 50px rgba(0, 0, 0, 0.6), 0 0 35px rgba(43, 59, 229, 0.08);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transform: translateY(20px) scale(0.95);
      transition: opacity 0.4s var(--ease-omega), transform 0.4s var(--ease-omega);
      user-select: none;
    }

    .chatquito.visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    .chatquito-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.9rem 1.25rem;
      background: rgba(43, 59, 229, 0.12);
      border-bottom: 1px solid rgba(43, 59, 229, 0.25);
      user-select: none;
    }

    .chatquito-title-wrap {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .chatquito-status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #00ff00;
      box-shadow: 0 0 8px #00ff00;
      animation: blink-live 1.5s infinite alternate;
    }

    .chatquito-title {
      font-family: var(--font-secondary);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: #FFF;
      text-shadow: 0 0 8px rgba(43, 59, 229, 0.4);
    }

    .chatquito-controls {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      z-index: 10;
    }

    .chatquito-voice-btn, .chatquito-close {
      background: none;
      border: none;
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.9rem;
      cursor: pointer;
      transition: color 0.2s ease, transform 0.2s ease;
      padding: 0.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .chatquito-voice-btn:hover {
      color: var(--color-amber);
      transform: scale(1.15);
    }

    .chatquito-close:hover {
