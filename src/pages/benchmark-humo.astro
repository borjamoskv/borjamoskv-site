      let m = 0x80000000;
      let a = 1103515245;
      let c = 12345;
      let state = seed;
      return {
        next: function() {
          state = (a * state + c) % m;
          return state / (m - 1);
        },
        nextInt: function(min, max) {
          return Math.floor(this.next() * (max - min)) + min;
        },
        choice: function(array) {
          return array[Math.floor(this.next() * array.length)];
        }
      };
