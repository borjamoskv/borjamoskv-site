              hype = rng.nextInt(35, 80);
              utility = rng.nextInt(55, 92);
            } else if (category === "virtual") {
              hype = rng.nextInt(65, 92);
              utility = rng.nextInt(25, 60);
            }
            
            // Followers count distribution
            const folType = rng.next();
            let followers = 0;
            if (folType < 0.65) {
              followers = rng.nextInt(5000, 45000);
            } else if (folType < 0.90) {
              followers = rng.nextInt(45000, 250000);
            } else {
              followers = rng.nextInt(250000, 1800000);
            }
            
            list.push({
              name: name,
              handle: handle,
              category: category,
              hype: hype,
              utility: utility,
              followers: followers,
              cliche: cliche,
              exergy: "C4-SINTÉTICO",
              verdict: verdict,
              territory: territory
            });
          }
          
          step++;
          msg.textContent = `Inicializando base de datos soberana (${Math.round((step/totalSteps)*100)}%)...`;
          setTimeout(doStep, 10);
        } else {
          influencerDatabase = list;
          
          // Complete telemetry calculations
          updateTelemetryAndRender();
          
          // Hide loader
          overlay.classList.add('hidden');
          
          // Init UI listeners
          initUIListeners();
        }
      }
      
      setTimeout(doStep, 10);
    }

    // ── Telemetry Calculations ──
    function updateTelemetryAndRender() {
      // Calculate average hype and exergy loss
      let totalHype = 0;
      let totalUtility = 0;
      let totalExergyLost = 0; // In Joules

      influencerDatabase.forEach(item => {
        totalHype += item.hype;
        totalUtility += item.utility;
        
        // Exergy Loss Equation (Rule Ω₂): waste factor based on Hype * Followers
        // Scale down to a reasonable Gigajoule figure for attention attention footprint
        totalExergyLost += (item.followers * item.hype * 2.2); 
      });

      const avgHype = (totalHype / influencerDatabase.length).toFixed(1);
      const avgUtility = (totalUtility / influencerDatabase.length).toFixed(1);
      const gigajoulesLost = (totalExergyLost / 1e9).toFixed(2);
      const sovereignEfficiency = (totalUtility / totalHype).toFixed(2);

      document.getElementById('hudHype').textContent = `${avgHype}%`;
      document.getElementById('hudExergy').innerHTML = `${gigajoulesLost}<span>GJ</span>`;
      document.getElementById('hudEfficiency').textContent = sovereignEfficiency;

      // Apply initial filters
      applyFilters();
    }

    // ── Filter & Sort Logic ──
    function applyFilters() {
      const searchVal = document.getElementById('searchInput').value.toLowerCase().trim();
      const territory = document.getElementById('territorySelect').value;
      const sortVal = document.getElementById('sortSelect').value;
      
      // Active category
      const activeCatBtn = document.querySelector('.filter-btn.active');
      const category = activeCatBtn ? activeCatBtn.dataset.cat : 'ALL';

      filteredDatabase = influencerDatabase.filter(item => {
        // Search filter
        const matchSearch = !searchVal || 
                            item.name.toLowerCase().includes(searchVal) || 
                            item.handle.toLowerCase().includes(searchVal) ||
                            item.cliche.toLowerCase().includes(searchVal);
        
        // Territory filter
        const matchTerritory = territory === 'ALL' || item.territory === territory;
        
        // Category filter
        const matchCategory = category === 'ALL' || item.category === category;

        return matchSearch && matchTerritory && matchCategory;
      });

      // Sorting
      filteredDatabase.sort((a, b) => {
        if (sortVal === 'hype-desc') {
          return b.hype - a.hype;
        } else if (sortVal === 'hype-asc') {
          return a.hype - b.hype;
        } else if (sortVal === 'utility-desc') {
          return b.utility - a.utility;
        } else if (sortVal === 'exergy-desc') {
          // Compare exergy directly: followers * hype
          return (b.followers * b.hype) - (a.followers * a.hype);
        } else if (sortVal === 'followers-desc') {
          return b.followers - a.followers;
        }
        return 0;
      });

      // Reset to page 1 on filter
      currentPage = 1;
      renderTable();
    }

    // ── Table Rendering with Pagination ──
    function renderTable() {
      const tbody = document.getElementById('leaderboardBody');
      tbody.innerHTML = '';

      const totalItems = filteredDatabase.length;
      const totalPages = Math.max(1, Math.ceil(totalItems / ITEMS_PER_PAGE));
      
      // Bound check
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      document.getElementById('pageInfo').textContent = `Pág. ${currentPage} de ${totalPages}`;
      document.getElementById('prevPage').disabled = (currentPage === 1);
      document.getElementById('nextPage').disabled = (currentPage === totalPages);

      if (totalItems === 0) {
        tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; color:rgba(243,244,246,0.3); padding:3rem;">Ninguna entidad coincide con los parámetros de búsqueda.</td></tr>`;
        return;
      }

      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = Math.min(start + ITEMS_PER_PAGE, totalItems);

      for (let i = start; i < end; i++) {
        const item = filteredDatabase[i];
        const rank = i + 1;
        const isReal = item.exergy === "C5-REAL";
        
        // Calculations for card columns
        const exergyLostVal = ((item.followers * item.hype * 2.2) / 1e6).toFixed(1); // Megajoules
        const formattedFollowers = formatNumber(item.followers);
        
        // Table row builder
        const row = document.createElement('tr');
        row.className = `${isReal ? 'real-row' : ''} rank-${rank <= 3 ? rank : 'normal'}`;
        row.setAttribute('data-id', i);
        row.innerHTML = `
          <td class="rank-col">${rank}</td>
          <td>
            <div class="identity-cell">
              <span class="influencer-name">${escapeHTML(item.name)}</span>
              <span class="influencer-handle">${escapeHTML(item.handle)}</span>
            </div>
          </td>
          <td>
            <span class="tag tag-${item.category}">${escapeHTML(item.category)}</span>
          </td>
          <td>
            <div class="metric-value">${item.hype}%</div>
            <div class="progress-bar-container" title="Índice de Humo: ${item.hype}%">
              <div class="progress-bar hype-bar" style="width: ${item.hype}%"></div>
            </div>
          </td>
          <td>
            <div class="metric-value">${item.utility}%</div>
            <div class="progress-bar-container" title="Utilidad Real: ${item.utility}%">
              <div class="progress-bar utility-bar" style="width: ${item.utility}%"></div>
            </div>
          </td>
          <td class="followers-col">${formattedFollowers}</td>
          <td class="exergy-col">${exergyLostVal} MJ</td>
          <td>
            <span class="status-badge ${isReal ? 'status-c5' : 'status-c4'}">${item.exergy}</span>
          </td>
        `;

        // Detail row builder
        const detailRow = document.createElement('tr');
        detailRow.className = 'detail-row';
        detailRow.style.display = 'none'; // Initially hidden
        detailRow.innerHTML = `
          <td colspan="8">
            <div class="detail-wrapper" id="detail-${i}">
              <div class="detail-grid">
                <div class="detail-block">
                  <p class="detail-title">Frase Cliché típica</p>
                  <p class="detail-phrase">${escapeHTML(item.cliche)}</p>
                </div>
                <div class="detail-block">
                  <p class="detail-title">Veredicto Soberano</p>
                  <p class="detail-verdict">${escapeHTML(item.verdict)}</p>
                </div>
              </div>
            </div>
          </td>
        `;

        // Row expand toggle
        row.addEventListener('click', (e) => {
          // Avoid triggering when clicking elements inside
          const currentDisplay = detailRow.style.display;
          const wrapper = detailRow.querySelector('.detail-wrapper');
          
          if (currentDisplay === 'none') {
            detailRow.style.display = 'table-row';
            // Force reflow
            wrapper.offsetHeight;
            wrapper.classList.add('open');
          } else {
            wrapper.classList.remove('open');
            // Wait for transition to complete before hiding display
            setTimeout(() => {
              if (!wrapper.classList.contains('open')) {
                detailRow.style.display = 'none';
              }
            }, 300);
          }
        });

        tbody.appendChild(row);
        tbody.appendChild(detailRow);
      }
    }

    // ── Helper formatters ──
    function formatNumber(num) {
      if (num >= 1000000) {
        return (num / 1000000).toFixed(1) + 'M';
      }
      if (num >= 1000) {
        return (num / 1000).toFixed(0) + 'K';
      }
      return num.toString();
    }

    function escapeHTML(str) {
      return str.replace(/[&<>'"]/g, 
        tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
      );
    }

    // ── UI Event listeners ──
    function initUIListeners() {
      // Search typing (throttled)
      let searchTimeout;
      document.getElementById('searchInput').addEventListener('input', () => {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          applyFilters();
        }, 150);
      });

      // Select dropdowns
      document.getElementById('territorySelect').addEventListener('change', applyFilters);
      document.getElementById('sortSelect').addEventListener('change', applyFilters);

      // Category filter buttons
      const catBtns = document.querySelectorAll('.filter-btn');
      catBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          catBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          applyFilters();
        });
      });

      // Pagination
      document.getElementById('prevPage').addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          renderTable();
          window.scrollTo({ top: document.querySelector('.controls-panel').offsetTop - 100, behavior: 'smooth' });
        }
      });

      document.getElementById('nextPage').addEventListener('click', () => {
        const totalItems = filteredDatabase.length;
        const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
        if (currentPage < totalPages) {
          currentPage++;
          renderTable();
          window.scrollTo({ top: document.querySelector('.controls-panel').offsetTop - 100, behavior: 'smooth' });
        }
      });

      // ── Site Header Scroll ──────────────────────────
      const header = document.getElementById('header');
      if (header) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 50) {
            header.classList.add('is-scrolled');
          } else {
            header.classList.remove('is-scrolled');
          }
        });
      }
    }
  </script>
</body>
</html>
