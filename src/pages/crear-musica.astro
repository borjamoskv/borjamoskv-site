---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BORJA MOSKV — Crear Música · Síntesis YuE">
  <style is:global>
    :root {
      --color-noir-bg: #07070a;
      --color-noir-card: #0c0c12;
      --color-electric-blue: #2b3be5;
      --color-cyber-cyan: #00f0ff;
      --color-cyber-pink: #ff0055;
      --color-neon-amber: #ff9f1c;
      --font-mono: 'JetBrains Mono', monospace;
    }

    .crear-musica-container {
      min-height: 100vh;
      background-color: var(--color-noir-bg);
      color: #ffffff;
      padding-top: 8rem;
      padding-bottom: 10rem;
    }

    .glass-panel {
      background: rgba(12, 12, 18, 0.85);
      border: 1px solid rgba(0, 240, 255, 0.15);
      border-radius: 16px;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.05);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .glass-panel:hover {
      border-color: rgba(0, 240, 255, 0.3);
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.95), 0 0 30px rgba(0, 240, 255, 0.05);
    }

    .synth-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 3rem;
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--gutter);
    }

    @media (max-width: 1024px) {
      .synth-grid {
        grid-template-columns: 1fr;
      }
    }

    .section-title {
      font-size: clamp(2rem, 5vw, 4.5rem);
      font-weight: 900;
      letter-spacing: -0.05em;
      line-height: 0.95;
      text-transform: uppercase;
      background: linear-gradient(135deg, var(--color-cyber-cyan), var(--color-electric-blue), var(--color-cyber-pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 0.5rem;
      filter: drop-shadow(0 0 30px rgba(0, 240, 255, 0.15));
    }

    .section-subtitle {
      font-family: var(--font-secondary);
      font-size: 0.8rem;
      letter-spacing: 0.4em;
      color: var(--color-cyber-cyan);
      text-transform: uppercase;
      opacity: 0.8;
      margin-bottom: 4rem;
      text-align: center;
    }

    /* Form Styles */
    .form-group {
      margin-bottom: 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .form-label {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-cyber-cyan);
      display: flex;
      justify-content: space-between;
    }

    .form-label span {
      color: var(--color-muted);
    }

    .form-input, .form-textarea {
      background: rgba(5, 5, 8, 0.9);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: #ffffff;
      padding: 1rem;
      font-size: 0.95rem;
      transition: all 0.3s ease;
    }

    .form-input:focus, .form-textarea:focus {
      outline: none;
      border-color: var(--color-cyber-cyan);
      box-shadow: 0 0 15px rgba(0, 240, 255, 0.15);
      background: rgba(5, 5, 8, 0.95);
    }

    .form-textarea {
      resize: vertical;
      font-family: var(--font-mono);
      line-height: 1.6;
    }

    /* Audio Drag and Drop */
    .audio-upload-zone {
      border: 2px dashed rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 2rem;
      text-align: center;
      cursor: pointer;
      background: rgba(5, 5, 8, 0.5);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .audio-upload-zone:hover, .audio-upload-zone.dragover {
      border-color: var(--color-cyber-cyan);
      background: rgba(0, 240, 255, 0.05);
    }

    .upload-icon {
      color: var(--color-cyber-cyan);
      filter: drop-shadow(0 0 8px rgba(0, 240, 255, 0.3));
    }

    .upload-text {
      font-size: 0.85rem;
      color: var(--color-muted);
    }

    /* Parameter Controls */
    .slider-container {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .slider-header {
      display: flex;
      justify-content: space-between;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--color-muted);
    }

    .slider-input {
      -webkit-appearance: none;
      width: 100%;
      height: 4px;
      border-radius: 2px;
      background: #222;
      outline: none;
      transition: background 0.3s ease;
    }

    .slider-input::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--color-cyber-cyan);
      cursor: pointer;
      box-shadow: 0 0 10px var(--color-cyber-cyan);
      transition: all 0.2s ease;
    }

    .slider-input::-webkit-slider-thumb:hover {
      transform: scale(1.2);
    }

    /* Switch Style */
    .switch-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(5, 5, 8, 0.8);
      padding: 1rem;
      border-radius: 8px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .switch-label {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #fff;
    }

    .switch {
      position: relative;
      display: inline-block;
      width: 50px;
      height: 26px;
    }

    .switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #222;
      transition: .4s;
      border-radius: 34px;
    }

    .slider:before {
      position: absolute;
      content: "";
      height: 18px;
      width: 18px;
      left: 4px;
      bottom: 4px;
      background-color: white;
      transition: .4s;
      border-radius: 50%;
    }

    input:checked + .slider {
      background-color: var(--color-electric-blue);
      box-shadow: 0 0 10px rgba(43, 59, 229, 0.5);
    }

    input:checked + .slider:before {
      transform: translateX(24px);
      background-color: var(--color-cyber-cyan);
    }

    /* Terminal Console */
    .terminal-console {
      background: #030305;
      border: 1px solid rgba(0, 240, 255, 0.1);
      border-radius: 12px;
      padding: 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      height: 350px;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      overflow: hidden;
      box-shadow: inset 0 0 30px rgba(0,0,0,0.95);
    }

    .terminal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      padding-bottom: 0.75rem;
      margin-bottom: 0.5rem;
      color: var(--color-muted);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .terminal-body {
      flex: 1;
      overflow-y: auto;
      padding-right: 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      scroll-behavior: smooth;
    }

    /* Scrollbar */
    .terminal-body::-webkit-scrollbar {
      width: 4px;
    }
    .terminal-body::-webkit-scrollbar-track {
      background: transparent;
    }
    .terminal-body::-webkit-scrollbar-thumb {
      background: rgba(0, 240, 255, 0.2);
      border-radius: 2px;
    }

    .log-line {
      line-height: 1.4;
      white-space: pre-wrap;
    }

    .log-system { color: #888899; }
    .log-stage1 { color: var(--color-cyber-cyan); }
    .log-stage2 { color: #bb77ff; }
    .log-vocoder { color: var(--color-neon-amber); }
    .log-error { color: var(--color-cyber-pink); font-weight: 700; }

    /* Button styles */
    .synth-btn {
      background: linear-gradient(135deg, var(--color-electric-blue), #1e29a8);
      color: #ffffff;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      padding: 1.2rem;
      font-family: var(--font-mono);
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      font-weight: bold;
    }

    .synth-btn:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(43, 59, 229, 0.4), 0 0 15px rgba(0, 240, 255, 0.2);
      border-color: rgba(0, 240, 255, 0.4);
    }

    .synth-btn:active:not(:disabled) {
      transform: translateY(1px);
    }

    .synth-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      background: #111;
    }

    /* Output Player Section */
    .output-section {
      background: linear-gradient(180deg, var(--color-noir-card) 0%, rgba(12, 12, 18, 0.4) 100%);
      border: 1px dashed rgba(0, 240, 255, 0.3);
      padding: 2rem;
      border-radius: 12px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      animation: pulseBorder 2s infinite ease-in-out;
    }

    @keyframes pulseBorder {
      0%, 100% { border-color: rgba(0, 240, 255, 0.2); }
      50% { border-color: rgba(0, 240, 255, 0.6); }
    }

    .hidden {
      display: none !important;
    }

    /* Waveform Animation */
    .wave-loader {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 4px;
      height: 40px;
    }

    .wave-bar {
      width: 4px;
      height: 100%;
      background-color: var(--color-cyber-cyan);
      border-radius: 2px;
      animation: dance 1.2s infinite ease-in-out;
    }

    .wave-bar:nth-child(1) { animation-delay: -1.1s; }
    .wave-bar:nth-child(2) { animation-delay: -1.0s; }
    .wave-bar:nth-child(3) { animation-delay: -0.9s; }
    .wave-bar:nth-child(4) { animation-delay: -0.8s; }
    .wave-bar:nth-child(5) { animation-delay: -0.7s; }

    @keyframes dance {
      0%, 100% { transform: scaleY(0.3); }
      50% { transform: scaleY(1.0); }
    }
  </style>

  <main class="crear-musica-container">
    <div style="text-align: center; margin-bottom: 1.5rem;">
      <h1 class="section-title">CREACIÓN MUSICAL</h1>
      <p class="section-subtitle">SÍNTESIS ICL LOCAL — YUE-S1-7B</p>
    </div>

    <div class="synth-grid">
      <!-- Input Panel -->
      <section class="glass-panel" style="padding: 2.5rem;">
        <form id="yue-synth-form" enctype="multipart/form-data">
          <!-- Lyrics Input -->
          <div class="form-group">
            <label class="form-label" for="lyrics">
              Líricas (Lyrics)
              <span>Separar bloques con doble salto de línea</span>
            </label>
            <textarea 
              id="lyrics" 
              name="lyrics" 
              class="form-textarea" 
              rows="8" 
              placeholder="[verse]&#10;In the deep neon rain, cyber dreams call...&#10;&#10;[chorus]&#10;Lost in the code, synthesis takes hold..."
              required></textarea>
          </div>

          <!-- Genre Prompt -->
          <div class="form-group">
            <label class="form-label" for="genre">
              Género & Timbre (Genre Tags)
              <span>5 tags recomendados separados por espacio</span>
            </label>
            <input 
              type="text" 
              id="genre" 
              name="genre" 
              class="form-input" 
              placeholder="inspiring female uplifting pop airy vocal" 
              required />
          </div>

          <!-- Audio Prompts (ICL) -->
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
            <div class="form-group">
              <label class="form-label">
                Pista Vocal (Vocals)
                <span>Audio referencia para ICL</span>
              </label>
              <div class="audio-upload-zone" id="vocals-zone">
                <svg class="upload-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <div class="upload-text">Seleccionar vocal track</div>
                <input type="file" id="vocal_file" name="vocal_file" accept="audio/*" class="hidden" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">
                Instrumental
                <span>Audio referencia para ICL</span>
              </label>
              <div class="audio-upload-zone" id="inst-zone">
                <svg class="upload-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <div class="upload-text">Seleccionar instrumental</div>
                <input type="file" id="inst_file" name="inst_file" accept="audio/*" class="hidden" />
              </div>
            </div>
          </div>

          <!-- Advanced Parameters -->
          <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2rem;">
            <h3 style="font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-cyber-cyan);">Parámetros de Síntesis</h3>
            
            <div class="slider-container">
              <div class="slider-header">
                <span>Repetition Penalty</span>
                <span id="rep-val">1.1</span>
              </div>
              <input type="range" id="repetition_penalty" name="repetition_penalty" min="1.0" max="2.0" step="0.05" value="1.1" class="slider-input" />
            </div>

            <div class="slider-container">
              <div class="slider-header">
                <span>Número de Segmentos</span>
                <span id="seg-val">2</span>
              </div>
              <input type="range" id="run_n_segments" name="run_n_segments" min="1" max="6" step="1" value="2" class="slider-input" />
            </div>
          </div>

          <!-- Execution Mode & Trigger -->
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="switch-container">
              <span class="switch-label">Simular Síntesis (C4-SIM)</span>
              <label class="switch">
                <input type="checkbox" id="simulation" name="simulation" checked />
                <span class="slider"></span>
              </label>
            </div>

            <button type="submit" id="submit-btn" class="synth-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
              Sintetizar Audio
            </button>
          </div>
        </form>
      </section>

      <!-- Output Panel & Logs -->
      <section style="display: flex; flex-direction: column; gap: 2rem;">
        <!-- Terminal Logs -->
        <div class="glass-panel" style="padding: 1.5rem;">
          <div class="terminal-console">
            <div class="terminal-header">
              <span>Sovereign Synthesizer Engine Monitor</span>
              <span id="terminal-status">OFFLINE</span>
            </div>
            <div class="terminal-body" id="log-body">
              <div class="log-line log-system">[SYSTEM] Ready. Enter lyrics and genre metadata.</div>
            </div>
          </div>
        </div>

        <!-- Wave Loader (Hidden by default) -->
        <div id="loader-panel" class="glass-panel hidden" style="padding: 2rem; text-align: center;">
          <div class="wave-loader" style="margin-bottom: 1.5rem;">
            <div class="wave-bar"></div>
            <div class="wave-bar"></div>
            <div class="wave-bar"></div>
            <div class="wave-bar"></div>
            <div class="wave-bar"></div>
          </div>
          <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-cyber-cyan); text-transform: uppercase; letter-spacing: 0.15em;">Procesando Inferencia Local en Redes de Silicio...</p>
          <div style="margin-top: 1rem; width: 100%; height: 4px; background: #222; border-radius: 2px; overflow: hidden; position: relative;">
            <div id="prog-bar" style="width: 0%; height: 100%; background: var(--color-cyber-cyan); box-shadow: 0 0 8px var(--color-cyber-cyan); transition: width 0.4s ease;"></div>
          </div>
        </div>

        <!-- Output Audio Player -->
        <div id="output-panel" class="glass-panel output-section hidden">
          <svg style="color: var(--color-cyber-cyan);" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          <div>
            <h3 style="font-size: 1.25rem; font-weight: bold; margin-bottom: 0.5rem;">SÍNTESIS COMPLETADA</h3>
            <p style="font-size: 0.8rem; color: var(--color-muted); font-family: var(--font-mono);">TRACK ID: <span id="out-track-id">N/A</span></p>
          </div>
          <audio id="synth-audio-player" controls style="width: 100%; border-radius: 8px; background: #111;"></audio>
        </div>
      </section>
    </div>
  </main>

  <script>
    // @ts-nocheck
    // File inputs handling
    const setupUploadZone = (zoneId, fileId) => {
      const zone = document.getElementById(zoneId);
      const fileInput = document.getElementById(fileId);
      if (!zone || !fileInput) return;

      zone.addEventListener('click', () => fileInput.click());
      zone.addEventListener('dragover', (e) => {
        e.preventDefault();
        zone.classList.add('dragover');
      });
      zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
      zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.classList.remove('dragover');
        if (e.dataTransfer.files.length) {
          fileInput.files = e.dataTransfer.files;
          updateFileName();
        }
      });

      const updateFileName = () => {
        const textEl = zone.querySelector('.upload-text');
        if (fileInput.files && fileInput.files[0] && textEl) {
          textEl.textContent = fileInput.files[0].name;
          textEl.style.color = 'var(--color-cyber-cyan)';
        }
      };

      fileInput.addEventListener('change', updateFileName);
    };

    const initPage = () => {
      setupUploadZone('vocals-zone', 'vocal_file');
      setupUploadZone('inst-zone', 'inst_file');

      // Sliders label updates
      const repSlider = document.getElementById('repetition_penalty');
      const repLabel = document.getElementById('rep-val');
      if (repSlider && repLabel) {
        repSlider.addEventListener('input', (e) => {
          repLabel.textContent = e.target.value;
        });
      }

      const segSlider = document.getElementById('run_n_segments');
      const segLabel = document.getElementById('seg-val');
      if (segSlider && segLabel) {
        segSlider.addEventListener('input', (e) => {
          segLabel.textContent = e.target.value;
        });
      }

      // Process trigger
      const form = document.getElementById('yue-synth-form');
      const logBody = document.getElementById('log-body');
      const statusLabel = document.getElementById('terminal-status');
      const loaderPanel = document.getElementById('loader-panel');
      const progBar = document.getElementById('prog-bar');
      const outputPanel = document.getElementById('output-panel');
      const submitBtn = document.getElementById('submit-btn');

      if (!form || !logBody || !submitBtn) return;

      let pollInterval;

      const formatLogLine = (line) => {
        let cls = 'log-system';
        if (line.startsWith('[STAGE 1]')) cls = 'log-stage1';
        if (line.startsWith('[STAGE 2]')) cls = 'log-stage2';
        if (line.startsWith('[VOCODER]')) cls = 'log-vocoder';
        if (line.includes('[ERROR]') || line.includes('[WARN/ERR]')) cls = 'log-error';
        return `<div class="log-line ${cls}">${escapeHtml(line)}</div>`;
      };

      const escapeHtml = (text) => {
        return text
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      };

      const startPolling = (taskId) => {
        pollInterval = setInterval(async () => {
          try {
            const res = await fetch('/api/yue-status');
            if (res.ok) {
              const data = await res.json();
              
              // Actualizar logs
              logBody.innerHTML = data.logs.map(formatLogLine).join('');
              logBody.scrollTop = logBody.scrollHeight;

              // Progreso
              if (progBar) progBar.style.width = `${data.progress}%`;

              if (data.status === 'completed') {
                clearInterval(pollInterval);
                statusLabel.textContent = 'IDLE';
                statusLabel.style.color = '#888';
                if (loaderPanel) loaderPanel.classList.add('hidden');
                submitBtn.removeAttribute('disabled');

                if (outputPanel && data.outputFile) {
                  const outTrackId = document.getElementById('out-track-id');
                  const audioPlayer = document.getElementById('synth-audio-player');
                  if (outTrackId) outTrackId.textContent = data.taskId;
                  if (audioPlayer) {
                    audioPlayer.src = data.outputFile;
                    audioPlayer.load();
                  }
                  outputPanel.classList.remove('hidden');
                }
              } else if (data.status === 'failed') {
                clearInterval(pollInterval);
                statusLabel.textContent = 'FAILED';
                statusLabel.style.color = 'var(--color-cyber-pink)';
                if (loaderPanel) loaderPanel.classList.add('hidden');
                submitBtn.removeAttribute('disabled');
              }
            }
          } catch (e) {
            console.error('Error polling status:', e);
          }
        }, 1000);
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Limpiar estados anteriores
        clearInterval(pollInterval);
        logBody.innerHTML = '<div class="log-line log-system">[SYSTEM] Submitting payload to generator...</div>';
        if (outputPanel) outputPanel.classList.add('hidden');
        if (loaderPanel) loaderPanel.classList.remove('hidden');
        if (progBar) progBar.style.width = '0%';
        submitBtn.setAttribute('disabled', 'true');
        statusLabel.textContent = 'ACTIVE INFERENCE';
        statusLabel.style.color = 'var(--color-cyber-cyan)';

        const formData = new FormData(form);
        const isSim = document.getElementById('simulation').checked;
        formData.append('simulation', isSim ? 'true' : 'false');

        try {
          const response = await fetch('/api/generate-yue', {
            method: 'POST',
            body: formData
          });

          if (response.ok) {
            const data = await response.json();
            logBody.innerHTML += `<div class="log-line log-system">[SYSTEM] Server acknowledged. Task: ${data.taskId}</div>`;
            startPolling(data.taskId);
          } else {
            const error = await response.json();
            logBody.innerHTML += `<div class="log-line log-error">[ERROR] ${error.error || 'Fallo desconocido al iniciar la generación.'}</div>`;
            submitBtn.removeAttribute('disabled');
            if (loaderPanel) loaderPanel.classList.add('hidden');
            statusLabel.textContent = 'ERROR';
            statusLabel.style.color = 'var(--color-cyber-pink)';
          }
        } catch (err) {
          logBody.innerHTML += `<div class="log-line log-error">[ERROR] ${err.message}</div>`;
          submitBtn.removeAttribute('disabled');
          if (loaderPanel) loaderPanel.classList.add('hidden');
          statusLabel.textContent = 'ERROR';
          statusLabel.style.color = 'var(--color-cyber-pink)';
        }
      });
    };

    document.addEventListener('astro:page-load', initPage);
    initPage();
  </script>
</Layout>
