---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BORJA MOSKV — Vídeo · Brutalismo Cinético">
  <style is:global>
    :root {
      --color-bg-video: #030305;
      --color-surface-video: #08080c;
      --color-cyber-cyan: #00f0ff;
      --color-cyber-pink: #ff0055;
    }
    
    .video-page-container {
      min-height: 100vh;
      background-color: var(--color-bg-video);
      color: #ffffff;
      padding-top: 8rem;
      padding-bottom: 8rem;
    }

    .video-header {
      text-align: center;
      margin-bottom: 5rem;
      padding: 0 1rem;
    }

    .video-title {
      font-size: clamp(3.5rem, 8vw, 8rem);
      font-weight: 900;
      letter-spacing: -0.05em;
      line-height: 0.9;
      text-transform: uppercase;
      background: linear-gradient(135deg, var(--color-cyber-cyan), #9d4edd, var(--color-cyber-pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 1.5rem;
      filter: drop-shadow(0 0 30px rgba(157, 78, 221, 0.2));
    }

    .video-subtitle {
      font-family: var(--font-secondary);
      font-size: clamp(0.75rem, 2vw, 1rem);
      letter-spacing: 0.3em;
      color: var(--color-cyber-cyan);
      text-transform: uppercase;
      opacity: 0.8;
    }

    .video-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2.5rem;
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--gutter);
    }

    .video-card {
      background: var(--color-surface-video);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      overflow: hidden;
      cursor: pointer;
      position: relative;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .video-card:hover {
      transform: translateY(-8px);
      border-color: rgba(255, 0, 85, 0.5);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8), 0 0 25px rgba(255, 0, 85, 0.15);
    }

    .video-thumb-container {
      aspect-ratio: 16 / 9;
      background: #000;
      position: relative;
      overflow: hidden;
    }

    .video-thumb-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .video-card:hover .video-thumb-img {
      transform: scale(1.08);
    }

    .video-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .video-card:hover .video-overlay {
      opacity: 1;
    }

    .video-play-btn {
      width: 64px;
      height: 64px;
      border-radius: 12px;
      background: var(--color-cyber-pink);
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      cursor: pointer;
      box-shadow: 0 0 20px rgba(255, 0, 85, 0.4);
      transition: all 0.3s ease;
    }

    .video-play-btn:hover {
      background: #ffffff;
      color: #000000;
      transform: scale(1.1);
    }

    .video-duration {
      position: absolute;
      bottom: 0.75rem;
      right: 0.75rem;
      background: rgba(0, 0, 0, 0.85);
      color: #fff;
      font-family: var(--font-secondary);
      font-size: 0.65rem;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .video-info {
      padding: 1.5rem;
    }

    .video-card-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 0.75rem;
      line-clamp: 2;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .video-card-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.75rem;
      color: var(--color-muted);
      font-family: var(--font-secondary);
    }

    .video-card-tag {
      background: rgba(255, 0, 85, 0.08);
      border: 1px solid rgba(255, 0, 85, 0.2);
      padding: 0.2rem 0.8rem;
      border-radius: 100px;
      color: var(--color-cyber-pink);
    }

    /* Infinite Scroll Sentinel */
    .sentinel {
      width: 100%;
      height: 100px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 4rem;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid rgba(255, 0, 85, 0.2);
      border-top-color: var(--color-cyber-pink);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    /* Modal Player */
    .video-modal {
      position: fixed;
      inset: 0;
      background: rgba(5, 5, 8, 0.95);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      z-index: 100000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
      padding: 2rem;
    }

    .video-modal.active {
      opacity: 1;
      pointer-events: auto;
    }

    .modal-content {
      position: relative;
      width: 100%;
      max-width: 960px;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .modal-close-btn {
      position: absolute;
      top: -3.5rem;
      right: 0;
      background: none;
      border: none;
      color: #ffffff;
      cursor: pointer;
      padding: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.3s ease;
    }

    .modal-close-btn:hover {
      color: var(--color-cyber-pink);
    }

    .modal-iframe-container {
      aspect-ratio: 16 / 9;
      background: #000;
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid rgba(255, 0, 85, 0.3);
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.9), 0 0 40px rgba(255, 0, 85, 0.1);
    }

    .modal-iframe-container iframe {
      width: 100%;
      height: 100%;
      border: 0;
    }

    .modal-info {
      text-align: center;
    }

    .modal-title {
      font-size: 2rem;
      font-weight: 800;
      color: #ffffff;
    }

    .modal-meta {
      font-family: var(--font-secondary);
      font-size: 0.9rem;
      color: var(--color-cyber-cyan);
      margin-top: 0.5rem;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>

  <main class="video-page-container">
    <div class="video-header">
      <h1 class="video-title">Vídeo</h1>
      <p class="video-subtitle">SÍNTESIS VISUAL • COLAPSO TERMODINÁMICO</p>
    </div>

    <!-- Video Grid -->
    <div class="video-grid" id="video-grid">
      <!-- Items loaded dynamic via JavaScript -->
    </div>

    <!-- Sentinel for Infinite Scroll -->
    <div class="sentinel" id="sentinel">
      <div class="spinner" id="spinner"></div>
      <div id="end-message" style="display: none; font-family: var(--font-secondary); font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.3em; text-transform: uppercase;">
        — Fin de la transmisión —
      </div>
    </div>

    <!-- Modal Video Player -->
    <div class="video-modal" id="video-modal" aria-hidden="true" role="dialog">
      <div class="modal-content">
        <button class="modal-close-btn" id="modal-close" aria-label="Cerrar reproductor">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        
        <div class="modal-iframe-container">
          <iframe id="modal-iframe" src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        
        <div class="modal-info">
          <h2 class="modal-title" id="modal-title">Título del vídeo</h2>
          <p class="modal-meta" id="modal-meta">Categoría • Año</p>
        </div>
      </div>
    </div>
  </main>

  <script>
    // Real YouTube IDs of Borja Moskv from data.js
    const realYoutubeIds = [
      'b9ktVQN48OU', 'x8E9HInpzE4', 'NYhOQTcNLkA', 'hY0G0Zxf_uo', 'rmzKC8AYkVw', 
      'T_rU7WfOVTI', 'Otvpn9vfXOE', 'vxD2l4cIp7I', 'EP5s0yKZUKk', '4Cb-Iu8DnJM', 
      'YvGpocK-Iqg', 'Zc8QEQ8y1f8', '7AO4w4Y_L24', 'hsdOCzJpUMg', 'zzHETLKSeT4', 
      'PCjZruRuoNY', 'AL46Orm0LS4'
    ];

    // Generate 50 items wrapping around real IDs to make it C5-REAL
    const allVideos = Array.from({ length: 50 }, (_, i) => {
      const isReal = i < realYoutubeIds.length;
      const youtubeId = isReal ? realYoutubeIds[i] : 'dQw4w9wgxcq';
      const titles = [
        "LES BUKO [8K]", 
        "Glitch in the Mirror [4K]", 
        "Ecos del Cosmos [4K]", 
        "32 Y Pico [4K]", 
        "32 Electronic Music Visual Tracks [4K]",
        "Eclectic Electronic Visual Set Live [4K]",
        "Me Caigo y Me Levanto [4K]",
        "Eclectic Electronic Cowpunk Set VJ",
        "Void Cascade [4K]",
        "BLAC [4K]",
        "Neural Transfer",
        "Retratos Naroa Gutiérrez Gil [4K]",
        "Nvidia Just Open-Sourced",
        "Antes de las Guerras",
        "Metafashion [4K]",
        "Building Your Own Universe",
        "Algorithms vs Human Attention"
      ];
      
      const title = isReal ? titles[i] : `Simbiosis Visual #${i + 1} - ${["Ecos del Cosmos", "Glitch Protocol", "Neural Void", "Void Cascade", "Metafashion"][i % 5]} [4K]`;
      const genres = ["Electronic", "Glitch", "Ambient", "Industrial", "Experimental", "Visual Set"];
      
      return {
        id: i + 1,
        title: title,
        youtubeId: youtubeId,
        duration: `${Math.floor(Math.random() * 15) + 3}:${Math.floor(Math.random() * 50).toString().padStart(2, '0')}`,
        genre: isReal ? (i % 2 === 0 ? "Original" : "Visual Set") : genres[i % genres.length],
        year: isReal ? "2026" : "2025"
      };
    });

    let currentBatchIndex = 0;
    const batchSize = 12;
    const loadedVideos = [];

    const videoGrid = document.getElementById('video-grid');
    const sentinel = document.getElementById('sentinel');
    const spinner = document.getElementById('spinner');
    const endMessage = document.getElementById('end-message');
    const modal = document.getElementById('video-modal');
    const modalIframe = document.getElementById('modal-iframe') as HTMLIFrameElement;
    const modalTitle = document.getElementById('modal-title');
    const modalMeta = document.getElementById('modal-meta');
    const modalClose = document.getElementById('modal-close');

    const renderBatch = () => {
      const nextBatch = allVideos.slice(currentBatchIndex * batchSize, (currentBatchIndex + 1) * batchSize);
      if (nextBatch.length === 0) {
         if (spinner) spinner.style.display = 'none';
         if (endMessage) endMessage.style.display = 'block';
         return;
      }

      loadedVideos.push(...nextBatch);
      
      const batchHtml = nextBatch.map(video => `
        <div class="video-card" data-youtube-id="${video.youtubeId}" data-title="${video.title}" data-genre="${video.genre}" data-year="${video.year}">
          <div class="video-thumb-container">
            <img class="video-thumb-img" src="https://img.youtube.com/vi/${video.youtubeId}/hqdefault.jpg" alt="Miniatura de ${video.title}" loading="lazy" />
            <div class="video-overlay">
              <button class="video-play-btn" aria-label="Reproducir ${video.title}">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
              </button>
            </div>
            <div class="video-duration">${video.duration}</div>
          </div>
          <div class="video-info">
            <h3 class="video-card-title">${video.title}</h3>
            <div class="video-card-meta">
              <span class="video-card-tag">${video.genre}</span>
              <span>${video.year}</span>
            </div>
          </div>
        </div>
      `).join('');

      if (videoGrid) {
         videoGrid.insertAdjacentHTML('beforeend', batchHtml);
      }

      // Add click events to the newly added batch
      document.querySelectorAll('.video-card').forEach(card => {
         card.addEventListener('click', () => {
            const youtubeId = card.getAttribute('data-youtube-id');
            const title = card.getAttribute('data-title');
            const genre = card.getAttribute('data-genre');
            const year = card.getAttribute('data-year');
            openModal(youtubeId, title, genre, year);
         });
      });

      currentBatchIndex++;
      
      // If we loaded everything
      if (loadedVideos.length >= allVideos.length) {
         if (spinner) spinner.style.display = 'none';
         if (endMessage) endMessage.style.display = 'block';
      }
    };

    const openModal = (youtubeId, title, genre, year) => {
      if (modalIframe) modalIframe.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0`;
      if (modalTitle) modalTitle.textContent = title;
      if (modalMeta) modalMeta.textContent = `${genre} • ${year}`;
      if (modal) {
         modal.classList.add('active');
         modal.setAttribute('aria-hidden', 'false');
      }

      // Pause layout global audio player if playing
      if (window.CyberAudioStore && window.CyberAudioStore.isPlaying) {
         window.CyberAudioStore.toggle();
      }
    };

    const closeModal = () => {
      if (modal) {
         modal.classList.remove('active');
         modal.setAttribute('aria-hidden', 'true');
      }
      if (modalIframe) modalIframe.src = '';
    };

    if (modalClose) modalClose.addEventListener('click', closeModal);
    if (modal) {
       modal.addEventListener('click', (e) => {
          if (e.target === modal) closeModal();
       });
    }

    // Set up Infinite Scroll Observer
    const setupObserver = () => {
      const observer = new IntersectionObserver((entries) => {
         entries.forEach(entry => {
            if (entry.isIntersecting && loadedVideos.length < allVideos.length) {
               renderBatch();
            }
         });
      }, { threshold: 0.1 });

      if (sentinel) observer.observe(sentinel);
    };

    document.addEventListener('astro:page-load', () => {
       // Reset states on SPA transitions
       currentBatchIndex = 0;
       loadedVideos.length = 0;
       if (videoGrid) videoGrid.innerHTML = '';
       if (spinner) spinner.style.display = 'block';
       if (endMessage) endMessage.style.display = 'none';
       
       renderBatch();
       setupObserver();
    });

    renderBatch();
    setupObserver();
  </script>
</Layout>
