---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BORJA MOSKV — Música · Vídeo · Blog">
<style>

      :root {
        --color-bg: #030304;
        --color-surface: #0a0a0c;
        --color-text: #F8F9FA;
        --color-muted: rgba(255, 255, 255, 0.55);
        --color-accent: #2B3BE5;
        --color-pink: #FF0055;
        --color-accent-glow: rgba(43, 59, 229, 0.5);
        --color-pink-glow: rgba(255, 0, 85, 0.5);
        --font-sans: 'Outfit', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
        --max-w: 1280px;
        --gutter: 5vw;
        --glass-bg: rgba(5, 5, 6, 0.55);
        --glass-border: rgba(255, 255, 255, 0.06);
      }
      
      * { margin: 0; padding: 0; box-sizing: border-box; }

      html {
        scroll-behavior: smooth;
        background-color: var(--color-void);
      }

      body {
        background-color: var(--color-void);
        color: var(--color-parchment);
        font-family: var(--font-primary);
        min-height: 100vh;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ─── Global Noise Texture ─── */
      body::before {
        content: "";
        position: fixed;
        top: 0; left: 0; width: 100vw; height: 100vh;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
      }

      /* ─── Fixed Background Video ─── */
      .bg-video-container {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        z-index: 0;
      }
      .bg-video {
        width: 100%; height: 100%;
        object-fit: cover;
        opacity: 0.25;
        filter: grayscale(80%) contrast(120%);
        mix-blend-mode: luminosity;
      }
      .overlay {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: radial-gradient(ellipse at center, rgba(3,3,4,0.4) 0%, rgba(3,3,4,0.95) 100%);
        z-index: 1;
        pointer-events: none;
      }

      /* ─── Navigation ─── */
      .top-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
        display: flex;
        justify-content: center;
        gap: 3rem;
        padding: 1.2rem 2rem;
        background: linear-gradient(to bottom, rgba(3,3,4,0.9), rgba(3,3,4,0));
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid transparent;
        transition: all 0.4s ease;
      }
      .nav-link {
        color: var(--color-muted);
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-family: var(--font-secondary);
        transition: color 0.3s ease, text-shadow 0.3s ease;
        position: relative;
      }
      .nav-link:hover { 
        color: #FFFFFF; 
        text-shadow: 0 0 12px rgba(255,255,255,0.4);
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -6px; left: 50%;
        width: 0%; height: 1px;
        background: var(--color-amber);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        transform: translateX(-50%);
      }
      .nav-link:hover::after {
        width: 100%;
        box-shadow: 0 0 8px var(--color-amber);
      }
      .nav-brand::after {
        display: none !important;
      }

      /* ─── Content Layer ─── */
      .content-layer {
        position: relative;
        z-index: 10;
      }

      /* ─── HERO ─── */
      .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 6rem 2rem 4rem;
        position: relative;
      }

      .hero-label {
        font-family: var(--font-secondary);
        font-size: 0.7rem;
        letter-spacing: 0.5em;
        text-transform: uppercase;
        color: var(--color-amber);
        margin-bottom: 1.5rem;
        opacity: 0;
        animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards 0.2s;
        text-shadow: 0 0 20px rgba(255, 159, 28, 0.4);
      }

      .hero-title {
        font-size: clamp(4.5rem, 15vw, 14rem);
        font-weight: 900;
        line-height: 0.85;
        letter-spacing: -0.05em;
        margin-bottom: 2rem;
        color: #fff;
        background: linear-gradient(180deg, #FFFFFF 0%, rgba(255, 255, 255, 0.4) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        opacity: 0;
        animation: fadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards 0.4s;
        filter: drop-shadow(0 0 40px rgba(255,255,255,0.1));
      }

      .hero-subtitle {
        font-size: 1.25rem;
        font-weight: 300;
        color: var(--color-muted);
        max-width: 600px;
        line-height: 1.6;
        margin-bottom: 3.5rem;
        opacity: 0;
        animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards 0.6s;
      }

      .hero-actions {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        justify-content: center;
        opacity: 0;
        animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards 0.8s;
      }

      .hero-btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2.5rem;
        border-radius: 100px;
        text-decoration: none;
        font-family: var(--font-secondary);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
        overflow: hidden;
        z-index: 1;
      }

      .hero-btn.primary {
        background: var(--color-yinmn);
        color: #FFFFFF;
        border: 1px solid rgba(255,255,255,0.1);
        box-shadow: 0 0 20px rgba(43, 59, 229, 0.3);
      }
      .hero-btn.primary::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transform: translateX(-100%);
        transition: transform 0.6s ease;
        z-index: -1;
      }
      .hero-btn.primary:hover {
        background: #3A4BFF;
        box-shadow: 0 10px 40px rgba(43, 59, 229, 0.6);
        transform: translateY(-3px) scale(1.02);
      }
      .hero-btn.primary:hover::before {
        transform: translateX(100%);
      }

      .hero-btn.outline {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        color: var(--color-parchment);
        border: 1px solid var(--glass-border);
      }
      .hero-btn.outline:hover {
        border-color: rgba(255, 255, 255, 0.3);
        background: rgba(255, 255, 255, 0.05);
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        transform: translateY(-3px) scale(1.02);
      }

      .scroll-indicator {
        position: absolute;
        bottom: 3rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        opacity: 0;
        animation: fadeUp 1s ease forwards 1.2s;
      }
      .scroll-indicator span {
        font-family: var(--font-secondary);
        font-size: 0.6rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--color-muted);
      }
      .scroll-line {
        width: 1px;
        height: 60px;
        background: linear-gradient(to bottom, var(--color-amber), transparent);
        animation: scrollPulse 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      }

      /* ─── Section shared ─── */
      .section {
        padding: 8rem var(--gutter);
        position: relative;
        background: rgba(3, 3, 4, 0.7);
        backdrop-filter: blur(60px);
        -webkit-backdrop-filter: blur(60px);
        border-top: 1px solid var(--glass-border);
      }

      .section-inner {
        max-width: var(--max-w);
        margin: 0 auto;
      }

      .section-header {
        text-align: center;
        margin-bottom: 5rem;
      }

      .section-label {
        font-family: var(--font-secondary);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.5em;
        text-transform: uppercase;
        color: var(--color-amber);
        margin-bottom: 1.5rem;
        display: block;
        text-shadow: 0 0 15px rgba(255, 159, 28, 0.4);
      }

      .section-title {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 900;
        letter-spacing: -0.04em;
      }

      .section-title span {
        background: linear-gradient(135deg, #FFFFFF, var(--color-muted));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* ─── MÚSICA: Featured + Grid ─── */
      .featured-video {
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 4rem;
        border: 1px solid var(--glass-border);
        box-shadow: 0 20px 60px rgba(0,0,0,0.6);
        position: relative;
        background: #000;
      }
      .featured-video iframe {
        width: 100%; height: 100%;
        border: none;
      }

      .thumb-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
      }

      .thumb-card {
        position: relative;
        aspect-ratio: 16 / 9;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        border: 1px solid var(--glass-border);
        background: var(--glass-bg);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .thumb-card::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 12px;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.0);
        transition: all 0.4s ease;
        pointer-events: none;
      }
      .thumb-card:hover {
        transform: translateY(-6px) scale(1.02);
        border-color: rgba(43, 59, 229, 0.6);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(43, 59, 229, 0.5);
      }
      .thumb-card:hover::after {
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);
      }
      .thumb-card img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.6s ease;
        filter: saturate(0.8) contrast(1.1);
      }
      .thumb-card:hover img {
        transform: scale(1.08);
        filter: saturate(1.2) contrast(1.2);
      }
      .thumb-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(3, 3, 4, 0.95) 0%, rgba(3, 3, 4, 0.4) 40%, transparent 100%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1.5rem;
        opacity: 0;
        transition: opacity 0.4s ease;
      }
      .thumb-card:hover .thumb-overlay {
        opacity: 1;
      }
      .thumb-title {
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #fff;
        margin-bottom: 0.3rem;
      }
      .thumb-desc {
        font-family: var(--font-secondary);
        font-size: 0.65rem;
        color: var(--color-amber);
      }

      .play-icon {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%) scale(0.6);
        width: 56px; height: 56px;
        border-radius: 50%;
        background: rgba(43, 59, 229, 0.9);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 0 20px rgba(43, 59, 229, 0.5);
      }
      .thumb-card:hover .play-icon {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
      .play-icon svg {
        width: 20px; height: 20px;
        fill: #FFFFFF;
        margin-left: 3px;
      }

      /* ─── VÍDEO Section ─── */
      .video-scroll-row {
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        padding-bottom: 2rem;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.15) transparent;
        padding-left: 0.5rem;
        padding-right: 0.5rem;
      }
      .video-scroll-row::-webkit-scrollbar {
        height: 6px;
      }
      .video-scroll-row::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.2);
        border-radius: 4px;
      }
      .video-scroll-row::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 4px;
      }
      .video-scroll-row::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.4);
      }

      .video-scroll-card {
        flex: 0 0 340px;
        scroll-snap-align: start;
        aspect-ratio: 16 / 9;
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        border: 1px solid var(--glass-border);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
      }
      .video-scroll-card:hover {
        transform: translateY(-6px) scale(1.02);
        border-color: rgba(255, 0, 85, 0.6);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(255, 159, 28, 0.4);
      }
      .video-scroll-card img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }
      .video-scroll-card:hover img {
        transform: scale(1.08);
      }
      .video-scroll-card .thumb-overlay {
        opacity: 0;
        transition: opacity 0.4s ease;
      }
      .video-scroll-card:hover .thumb-overlay {
        opacity: 1;
      }
      .video-scroll-card:hover .play-icon {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
        background: rgba(255, 0, 85, 0.9);
        box-shadow: 0 0 20px rgba(255, 159, 28, 0.4);
      }

      /* ─── BLOG Section ─── */
      .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
      }

      .blog-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 3rem 2.5rem;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 380px;
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(20px);
      }

      .blog-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 3px;
        background: linear-gradient(90deg, transparent, var(--color-amber), var(--color-yinmn), transparent);
        transform: scaleX(0);
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .blog-card:hover {
        transform: translateY(-10px);
        border-color: rgba(43, 59, 229, 0.4);
        background: rgba(43, 59, 229, 0.05);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), 0 0 40px rgba(43, 59, 229, 0.1);
      }
      .blog-card:hover::before {
        transform: scaleX(1);
      }

      .card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
      }

      .card-tag {
        font-family: var(--font-secondary);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-amber);
        background: rgba(255, 0, 85, 0.08);
        border: 1px solid rgba(255, 0, 85, 0.3);
        padding: 0.4rem 1rem;
        border-radius: 100px;
        box-shadow: 0 0 10px rgba(255, 0, 85, 0);
        transition: all 0.3s ease;
      }
      .blog-card:hover .card-tag {
        box-shadow: 0 0 15px rgba(255, 0, 85, 0.2);
        background: rgba(255, 0, 85, 0.15);
      }
      .card-tag.tech {
        color: var(--color-yinmn);
        border-color: rgba(43, 59, 229, 0.3);
        background: rgba(43, 59, 229, 0.08);
      }
      .blog-card:hover .card-tag.tech {
        box-shadow: 0 0 15px rgba(43, 59, 229, 0.2);
        background: rgba(43, 59, 229, 0.15);
      }

      .card-date {
        font-family: var(--font-secondary);
        font-size: 0.7rem;
        color: var(--color-muted);
      }

      .card-title {
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1.3;
        margin-bottom: 1.5rem;
        color: #FFFFFF;
        letter-spacing: -0.02em;
        transition: color 0.3s ease;
      }
      .blog-card:hover .card-title {
        color: #fff;
        text-shadow: 0 0 20px rgba(255,255,255,0.2);
      }

      .card-excerpt {
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--color-muted);
        margin-bottom: 2.5rem;
        font-weight: 400;
        flex-grow: 1;
        transition: color 0.3s ease;
      }
      .blog-card:hover .card-excerpt {
        color: rgba(255,255,255,0.7);
      }

      .card-cta {
        font-family: var(--font-secondary);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-muted);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        transition: all 0.3s ease;
      }
      .blog-card:hover .card-cta {
        color: var(--color-yinmn);
        text-shadow: 0 0 10px rgba(43, 59, 229, 0.5);
      }
      .card-cta .arrow-icon {
        transition: transform 0.3s ease;
      }
      .blog-card:hover .card-cta .arrow-icon {
        transform: translateX(5px);
      }

      .section-footer {
        text-align: center;
        margin-top: 5rem;
      }

      .view-all-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        color: #FFFFFF;
        text-decoration: none;
        font-family: var(--font-secondary);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        border: 1px solid var(--glass-border);
        background: var(--glass-bg);
        padding: 1.2rem 3rem;
        border-radius: 100px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .view-all-btn:hover {
        border-color: var(--color-yinmn);
        background: rgba(43, 59, 229, 0.1);
        box-shadow: 0 10px 30px rgba(43, 59, 229, 0.2);
        transform: translateY(-3px) scale(1.02);
      }

      /* ─── Arrow Icon ─── */
      .arrow-icon {
        width: 16px; height: 16px;
        fill: none;
        stroke: currentColor;
        stroke-width: 2;
        stroke-linecap: square;
      }

      /* ─── Footer ─── */
      .site-footer {
        position: relative;
        z-index: 10;
        text-align: center;
        padding: 4rem 2rem;
        border-top: 1px solid var(--glass-border);
        background: rgba(3, 3, 4, 0.95);
      }
      .footer-text {
        font-family: var(--font-secondary);
        font-size: 0.7rem;
        letter-spacing: 0.3em;
        color: var(--color-muted);
        text-transform: uppercase;
      }

      /* ─── Animations ─── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(30px); filter: blur(10px); }
        to { opacity: 1; transform: translateY(0); filter: blur(0); }
      }
      @keyframes scrollPulse {
        0%, 100% { opacity: 0.2; transform: scaleY(0.8); transform-origin: top; }
        50% { opacity: 1; transform: scaleY(1); transform-origin: top; }
      }

      /* ─── Responsive ─── */
      @media (max-width: 1024px) {
        :root { --gutter: 3rem; }
        .thumb-grid { grid-template-columns: repeat(3, 1fr); }
        .blog-grid { grid-template-columns: repeat(2, 1fr); }
        .bandcamp-grid { grid-template-columns: 1fr !important; }
      }
      @media (max-width: 768px) {
        :root { --gutter: 1.5rem; }
        .top-nav { gap: 1.5rem; padding: 1.2rem 1rem; }
        .thumb-grid { grid-template-columns: repeat(2, 1fr); }
        .blog-grid { grid-template-columns: 1fr; }
        .hero-actions { flex-direction: column; align-items: center; width: 100%; padding: 0 2rem; }
        .hero-btn { width: 100%; justify-content: center; }
        .video-scroll-card { flex: 0 0 280px; }
      }
      @media (max-width: 480px) {
        .thumb-grid { grid-template-columns: 1fr; }
        .top-nav { gap: 1rem; font-size: 0.65rem; }
        .hero-title { font-size: 3.5rem; }
      }
    

/* ─── SOTA: Scroll-Driven Entry Effects (Industrial Noir / Music Visual) ─── */
@media (prefers-reduced-motion: no-preference) {
  @supports ((animation-timeline: view()) and (animation-range: entry)) {
    @keyframes sota-grow {
      from { 
        scale: 0.8; 
        opacity: 0; 
        filter: blur(15px) grayscale(100%); 
        transform: translateY(100px) perspective(1000px) rotateX(10deg); 
      }
      to { 
        scale: 1; 
        opacity: 1; 
        filter: blur(0) grayscale(0%); 
        transform: translateY(0) perspective(1000px) rotateX(0deg); 
      }
    }
    
    .thumb-card, .blog-card {
      animation: sota-grow auto cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-timeline: view();
      animation-range: entry 5% cover 35%;
      will-change: transform, opacity, filter;
    }
    
    @keyframes sota-scroll-x {
      from { 
        scale: 0.7; 
        opacity: 0; 
        filter: blur(10px);
        transform: translateX(100px) perspective(800px) rotateY(-25deg); 
      }
      to { 
        scale: 1; 
        opacity: 1; 
        filter: blur(0);
        transform: translateX(0) perspective(800px) rotateY(0); 
      }
    }

    .video-scroll-card {
      animation: sota-scroll-x auto cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-timeline: view(inline);
      animation-range: entry 0% cover 50%;
      will-change: transform, opacity, filter;
    }
  }
}

