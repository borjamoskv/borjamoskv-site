---
// index.astro
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BORJA MOSKV // NO SLEEP IN MY CITY</title>
    <meta name="description" content="Audio directo, vídeo en primer plano, ciudad al fondo." />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&family=JetBrains+Mono:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --color-bg: #0A0A0A;
        --color-text: #F3F4F6;
        --color-accent: #2B3BE5;
        --font-sans: 'Outfit', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
      }
      
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-sans);
        overflow: hidden;
        height: 100vh;
        width: 100vw;
        position: relative;
      }

      /* Background Video */
      .bg-video-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
      }
      
      .bg-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.6; /* Slight dimming to make text readable */
      }

      /* Overlay Gradient */
      .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at center, rgba(10,10,10,0.1) 0%, rgba(10,10,10,0.85) 100%);
        z-index: 1;
        pointer-events: none;
      }

      /* Navigation */
      .top-nav {
        position: absolute;
        top: 3rem;
        right: 4rem;
        z-index: 10;
        display: flex;
        gap: 3rem;
      }

      .nav-link {
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 400;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: color 0.3s ease;
      }

      .nav-link:hover {
        color: #FFFFFF;
      }

      /* Giant Title */
      .hero-title {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 10;
        font-size: 16vw;
        font-weight: 900;
        white-space: nowrap;
        color: transparent;
        -webkit-text-stroke: 2px rgba(255, 255, 255, 0.9);
        pointer-events: none;
        user-select: none;
        line-height: 1;
        letter-spacing: -0.02em;
      }

      /* Bottom Left Info */
      .track-info {
        position: absolute;
        bottom: 3rem;
        left: 4rem;
        z-index: 10;
        display: flex;
        gap: 4rem;
      }

      .info-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        position: relative;
      }

      .info-group:not(:last-child)::after {
        content: '';
        position: absolute;
        right: -2rem;
        top: 15%;
        height: 70%;
        width: 1px;
        background-color: rgba(255,255,255,0.15);
      }

      .info-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .info-value {
        font-size: 1.1rem;
        font-weight: 300;
        letter-spacing: 0.02em;
      }

      /* Bottom Right Actions */
      .action-buttons {
        position: absolute;
        bottom: 3rem;
        right: 4rem;
        z-index: 10;
        display: flex;
        gap: 2.5rem;
        align-items: center;
      }

      .action-btn {
        background: none;
        border: none;
        color: var(--color-text);
        font-family: var(--font-sans);
        font-size: 0.9rem;
        font-weight: 300;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        text-decoration: none;
        opacity: 0.8;
      }

      .action-btn:hover {
        opacity: 1;
      }

      .action-btn.primary {
        border: 1px solid rgba(255,255,255,0.3);
        padding: 0.75rem 1.5rem;
        border-radius: 100px;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
        opacity: 1;
      }

      .action-btn.primary:hover {
        border-color: var(--color-text);
        background: rgba(255, 255, 255, 0.05);
      }
      
      .arrow-icon {
        width: 16px;
        height: 16px;
        fill: none;
        stroke: currentColor;
        stroke-width: 1.5;
        stroke-linecap: square;
      }

    </style>
  </head>
  <body>
    <!-- Background Layer -->
    <div class="bg-video-container">
      <video class="bg-video" autoplay loop muted playsinline>
        <source src="/media/videos/no-sleep-in-my-city.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="overlay"></div>

    <!-- UI Layer -->
    <header>
      <nav class="top-nav">
        <a href="#" class="nav-link">Música</a>
        <a href="#" class="nav-link">Vídeo</a>
        <a href="#" class="nav-link">Imagen</a>
      </nav>
    </header>

    <main>
      <h1 class="hero-title">BORJA MOSKV</h1>

      <div class="track-info">
        <div class="info-group">
          <span class="info-label">Obra</span>
          <span class="info-value">No Sleep In My City</span>
        </div>
        <div class="info-group">
          <span class="info-label">Formato</span>
          <span class="info-value">Video musical</span>
        </div>
        <div class="info-group">
          <span class="info-label">Duración</span>
          <span class="info-value">03:35</span>
        </div>
      </div>

      <div class="action-buttons">
        <a href="#" class="action-btn">
          Escuchar ahora
          <svg class="arrow-icon" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#" class="action-btn">
          Ver la pieza
          <svg class="arrow-icon" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <button class="action-btn primary">
          Modo pieza
        </button>
      </div>
    </main>

  </body>
</html>
