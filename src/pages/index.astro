---
// index.astro — BORJA MOSKV · Centered Hub
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BORJA MOSKV — Música · Vídeo · Blog</title>
    <meta name="description" content="Borja Moskv — Música electrónica, vídeo experimental y ensayo. Audio directo, vídeo en primer plano, ciudad al fondo." />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&family=JetBrains+Mono:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --color-bg: #0A0A0A;
        --color-surface: #111111;
        --color-text: #F3F4F6;
        --color-muted: rgba(255, 255, 255, 0.45);
        --color-accent: #2B3BE5;
        --color-pink: #FF0055;
        --font-sans: 'Outfit', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
        --max-w: 1200px;
        --gutter: 4rem;
      }
      
      * { margin: 0; padding: 0; box-sizing: border-box; }

      html {
        scroll-behavior: smooth;
      }

      body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-sans);
        min-height: 100vh;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      /* ─── Fixed Background Video ─── */
      .bg-video-container {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        z-index: 0;
      }
      .bg-video {
        width: 100%; height: 100%;
        object-fit: cover;
        opacity: 0.35;
      }
      .overlay {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: radial-gradient(ellipse at center, rgba(10,10,10,0.3) 0%, rgba(10,10,10,0.92) 100%);
        z-index: 1;
        pointer-events: none;
      }

      /* ─── Navigation ─── */
      .top-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
        display: flex;
        justify-content: center;
        gap: 2.5rem;
        padding: 1.5rem 2rem;
        background: rgba(10, 10, 10, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      }
      .nav-link {
        color: rgba(255, 255, 255, 0.55);
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 400;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        font-family: var(--font-mono);
        transition: color 0.3s ease;
      }
      .nav-link:hover { color: #FFFFFF; }

      /* ─── Content Layer ─── */
      .content-layer {
        position: relative;
        z-index: 10;
      }

      /* ─── HERO ─── */
      .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 6rem 2rem 4rem;
        position: relative;
      }

      .hero-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--color-pink);
        margin-bottom: 2rem;
        opacity: 0;
        animation: fadeUp 0.8s ease forwards 0.2s;
      }

      .hero-title {
        font-size: clamp(4rem, 14vw, 12rem);
        font-weight: 900;
        line-height: 0.9;
        letter-spacing: -0.04em;
        color: transparent;
        -webkit-text-stroke: 2px rgba(255, 255, 255, 0.85);
        margin-bottom: 2rem;
        opacity: 0;
        animation: fadeUp 1s ease forwards 0.4s;
      }

      .hero-subtitle {
        font-size: 1.1rem;
        font-weight: 300;
        color: var(--color-muted);
        max-width: 520px;
        line-height: 1.7;
        margin-bottom: 3rem;
        opacity: 0;
        animation: fadeUp 0.8s ease forwards 0.7s;
      }

      .hero-actions {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        justify-content: center;
        opacity: 0;
        animation: fadeUp 0.8s ease forwards 0.9s;
      }

      .hero-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.85rem 2rem;
        border-radius: 100px;
        text-decoration: none;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
      }

      .hero-btn.primary {
        background: var(--color-accent);
        color: #FFFFFF;
        border: 1px solid var(--color-accent);
      }
      .hero-btn.primary:hover {
        background: #3a4bf0;
        box-shadow: 0 0 30px rgba(43, 59, 229, 0.3);
        transform: translateY(-2px);
      }

      .hero-btn.outline {
        background: transparent;
        color: var(--color-text);
        border: 1px solid rgba(255, 255, 255, 0.2);
      }
      .hero-btn.outline:hover {
        border-color: rgba(255, 255, 255, 0.5);
        background: rgba(255, 255, 255, 0.04);
        transform: translateY(-2px);
      }

      .scroll-indicator {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        opacity: 0;
        animation: fadeUp 0.6s ease forwards 1.2s;
      }
      .scroll-indicator span {
        font-family: var(--font-mono);
        font-size: 0.55rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.25);
      }
      .scroll-line {
        width: 1px;
        height: 40px;
        background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
        animation: scrollPulse 2s ease-in-out infinite;
      }

      /* ─── Section shared ─── */
      .section {
        padding: 7rem var(--gutter);
        position: relative;
        background: rgba(10, 10, 10, 0.88);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border-top: 1px solid rgba(255, 255, 255, 0.04);
      }

      .section-inner {
        max-width: var(--max-w);
        margin: 0 auto;
      }

      .section-header {
        text-align: center;
        margin-bottom: 4rem;
      }

      .section-label {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.5em;
        text-transform: uppercase;
        color: var(--color-pink);
        margin-bottom: 1rem;
        display: block;
      }

      .section-title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .section-title span {
        background: linear-gradient(135deg, var(--color-pink), var(--color-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* ─── MÚSICA: Featured + Grid ─── */
      .featured-video {
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 3rem;
        border: 1px solid rgba(255, 255, 255, 0.06);
        position: relative;
      }
      .featured-video iframe {
        width: 100%; height: 100%;
        border: none;
      }

      .thumb-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }

      .thumb-card {
        position: relative;
        aspect-ratio: 16 / 9;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        border: 1px solid rgba(255, 255, 255, 0.04);
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .thumb-card:hover {
        transform: translateY(-4px);
        border-color: rgba(43, 59, 229, 0.4);
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.5);
      }
      .thumb-card img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }
      .thumb-card:hover img {
        transform: scale(1.06);
      }
      .thumb-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(10, 10, 10, 0.85) 0%, transparent 60%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 1rem;
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .thumb-card:hover .thumb-overlay {
        opacity: 1;
      }
      .thumb-title {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }
      .thumb-desc {
        font-family: var(--font-mono);
        font-size: 0.55rem;
        color: var(--color-muted);
        margin-top: 0.2rem;
      }

      /* Play icon */
      .play-icon {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%) scale(0.8);
        width: 48px; height: 48px;
        border-radius: 50%;
        background: rgba(43, 59, 229, 0.85);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: all 0.35s ease;
      }
      .thumb-card:hover .play-icon {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
      .play-icon svg {
        width: 18px; height: 18px;
        fill: #FFFFFF;
        margin-left: 2px;
      }

      /* ─── VÍDEO Section ─── */
      .video-scroll-row {
        display: flex;
        gap: 1rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        padding-bottom: 1.5rem;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.08) transparent;
      }
      .video-scroll-row::-webkit-scrollbar {
        height: 4px;
      }
      .video-scroll-row::-webkit-scrollbar-track {
        background: transparent;
      }
      .video-scroll-row::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 2px;
      }

      .video-scroll-card {
        flex: 0 0 300px;
        scroll-snap-align: start;
        aspect-ratio: 16 / 9;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
        border: 1px solid rgba(255, 255, 255, 0.04);
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
      }
      .video-scroll-card:hover {
        transform: translateY(-3px);
        border-color: rgba(255, 0, 85, 0.3);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
      }
      .video-scroll-card img {
        width: 100%; height: 100%;
        object-fit: cover;
      }
      .video-scroll-card .thumb-overlay {
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .video-scroll-card:hover .thumb-overlay {
        opacity: 1;
      }
      .video-scroll-card:hover .play-icon {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }

      /* ─── BLOG Section ─── */
      .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
      }

      .blog-card {
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 300px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
      }

      .blog-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 2px;
        background: linear-gradient(90deg, transparent, var(--color-pink), var(--color-accent), transparent);
        transform: scaleX(0);
        transition: transform 0.4s ease;
      }

      .blog-card:hover {
        transform: translateY(-6px);
        border-color: rgba(43, 59, 229, 0.3);
        background: rgba(43, 59, 229, 0.03);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 25px rgba(43, 59, 229, 0.05);
      }
      .blog-card:hover::before {
        transform: scaleX(1);
      }

      .card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
      }

      .card-tag {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-pink);
        border: 1px solid rgba(255, 0, 85, 0.25);
        padding: 0.25rem 0.75rem;
        border-radius: 100px;
      }
      .card-tag.tech {
        color: var(--color-accent);
        border-color: rgba(43, 59, 229, 0.25);
      }

      .card-date {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: rgba(255, 255, 255, 0.3);
      }

      .card-title {
        font-size: 1.35rem;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 1rem;
        color: #FFFFFF;
        letter-spacing: -0.01em;
      }

      .card-excerpt {
        font-size: 0.88rem;
        line-height: 1.65;
        color: rgba(255, 255, 255, 0.45);
        margin-bottom: 2rem;
        font-weight: 300;
        flex-grow: 1;
      }

      .card-cta {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: color 0.3s ease;
      }
      .blog-card:hover .card-cta {
        color: #FFFFFF;
      }

      .section-footer {
        text-align: center;
        margin-top: 4rem;
      }

      .view-all-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        color: #FFFFFF;
        text-decoration: none;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        border: 1px solid rgba(255, 255, 255, 0.12);
        padding: 1rem 2.5rem;
        border-radius: 4px;
        transition: all 0.3s ease;
      }
      .view-all-btn:hover {
        border-color: var(--color-accent);
        background: rgba(43, 59, 229, 0.08);
      }

      /* ─── Arrow Icon ─── */
      .arrow-icon {
        width: 14px; height: 14px;
        fill: none;
        stroke: currentColor;
        stroke-width: 1.5;
        stroke-linecap: square;
      }

      /* ─── Footer ─── */
      .site-footer {
        position: relative;
        z-index: 10;
        text-align: center;
        padding: 3rem 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        background: rgba(10, 10, 10, 0.92);
      }
      .footer-text {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        color: rgba(255, 255, 255, 0.2);
        text-transform: uppercase;
      }

      /* ─── Animations ─── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes scrollPulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 0.8; }
      }

      /* ─── Responsive ─── */
      @media (max-width: 1024px) {
        :root { --gutter: 2.5rem; }
        .thumb-grid { grid-template-columns: repeat(3, 1fr); }
        .blog-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 768px) {
        :root { --gutter: 1.5rem; }
        .top-nav { gap: 1.5rem; padding: 1.2rem 1rem; }
        .thumb-grid { grid-template-columns: repeat(2, 1fr); }
        .blog-grid { grid-template-columns: 1fr; }
        .hero-actions { flex-direction: column; align-items: center; }
        .video-scroll-card { flex: 0 0 260px; }
      }
      @media (max-width: 480px) {
        .thumb-grid { grid-template-columns: 1fr; }
        .top-nav { gap: 1rem; font-size: 0.65rem; }
      }
    </style>
  </head>
  <body>
    <!-- Background Layer -->
    <div class="bg-video-container">
      <video class="bg-video" autoplay loop muted playsinline>
        <source src="/media/videos/no-sleep-in-my-city.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="overlay"></div>

    <!-- Navigation -->
    <header>
      <nav class="top-nav">
        <a href="#musica" class="nav-link">Música</a>
        <a href="#video" class="nav-link">Vídeo</a>
        <a href="#blog" class="nav-link">Blog</a>
        <a href="https://www.youtube.com/@borjamoskv" target="_blank" rel="noopener" class="nav-link">YouTube</a>
      </nav>
    </header>

    <div class="content-layer">
      <!-- ═══ HERO ═══ -->
      <section class="hero">
        <span class="hero-label">Música · Vídeo · Ensayo</span>
        <h1 class="hero-title">BORJA<br/>MOSKV</h1>
        <p class="hero-subtitle">Audio directo, vídeo en primer plano, ciudad al fondo.</p>
        <div class="hero-actions">
          <a href="#musica" class="hero-btn primary">
            Escuchar
            <svg class="arrow-icon" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#video" class="hero-btn outline">
            Ver vídeos
            <svg class="arrow-icon" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#blog" class="hero-btn outline">
            Leer diario
          </a>
        </div>
        <div class="scroll-indicator">
          <span>Scroll</span>
          <div class="scroll-line"></div>
        </div>
      </section>

      <!-- ═══ MÚSICA ═══ -->
      <section id="musica" class="section">
        <div class="section-inner">
          <div class="section-header">
            <span class="section-label">Producción Original</span>
            <h2 class="section-title"><span>Música</span></h2>
          </div>

          <!-- Featured embed -->
          <div class="featured-video">
            <iframe
              src="https://www.youtube.com/embed/b9ktVQN48OU?rel=0&modestbranding=1&color=white"
              title="LES BUKO — Borja Moskv [8K]"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>

          <!-- Thumbnail grid -->
          <div class="thumb-grid">
            <a href="https://www.youtube.com/watch?v=NYhOQTcNLkA" target="_blank" rel="noopener" class="thumb-card">
              <img src="https://img.youtube.com/vi/NYhOQTcNLkA/hqdefault.jpg" alt="Ecos del Cosmos" loading="lazy" />
              <div class="thumb-overlay">
                <span class="thumb-title">Ecos del Cosmos</span>
                <span class="thumb-desc">Ambient / Sci-Fi [4K]</span>
              </div>
              <div class="play-icon"><svg viewBox="0 0 24 24"><polygon points="6,3 20,12 6,21"/></svg></div>
            </a>
            <a href="https://www.youtube.com/watch?v=x8E9HInpzE4" target="_blank" rel="noopener" class="thumb-card">
              <img src="https://img.youtube.com/vi/x8E9HInpzE4/hqdefault.jpg" alt="Glitch in the Mirror" loading="lazy" />
              <div class="thumb-overlay">
                <span class="thumb-title">Glitch in the Mirror</span>
                <span class="thumb-desc">Experimental [4K]</span>
              </div>
              <div class="play-icon"><svg viewBox="0 0 24 24"><polygon points="6,3 20,12 6,21"/></svg></div>
            </a>
            <a href="https://www.youtube.com/watch?v=hY0G0Zxf_uo" target="_blank" rel="noopener" class="thumb-card">
              <img src="https://img.youtube.com/vi/hY0G0Zxf_uo/hqdefault.jpg" alt="32 Y PICO" loading="lazy" />
              <div class="thumb-overlay">
                <span class="thumb-title">32 Y Pico</span>
                <span class="thumb-desc">Electronic [4K]</span>
              </div>
              <div class="play-icon"><svg viewBox="0 0 24 24"><polygon points="6,3 20,12 6,21"/></svg></div>
            </a>
            <a href="https://www.youtube.com/watch?v=NJqC3Xf6RzE" target="_blank" rel="noopener" class="thumb-card">
              <img src="https://img.youtube.com/vi/NJqC3Xf6RzE/hqdefault.jpg" alt="PATADAS" loading="lazy" />
              <div class="thumb-overlay">
                <span class="thumb-title">Patadas</span>
                <span class="thumb-desc">Electronic</span>
              </div>
              <div class="play-icon"><svg viewBox="0 0 24 24"><polygon points="6,3 20,12 6,21"/></svg></div>
            </a>
            <a href="https://www.youtube.com/watch?v=LDzdKd4WxvI" target="_blank" rel="noopener" class="thumb-card">
              <img src="https://img.youtube.com/vi/LDzdKd4WxvI/hqdefault.jpg" alt="4 DROGAS" loading="lazy" />
              <div class="thumb-overlay">
                <span class="thumb-title">4 Drogas</span>
                <span class="thumb-desc">Techno</span>
              </div>
              <div class="play-icon"><svg viewBox="0 0 24 24"><polygon points="6,3 20,12 6,21"/></svg></div>
            </a>
            <a href="https://www.youtube.com/watch?v=hsdOCzJpUMg" target="_blank" rel="noopener" class="thumb-card">
              <img src="https://img.youtube.com/vi/hsdOCzJpUMg/hqdefault.jpg" alt="Antes de las Guerras" loading="lazy" />
              <div class="thumb-overlay">
                <span class="thumb-title">Antes de las Guerras</span>
                <span class="thumb-desc">Ambient</span>
              </div>
              <div class="play-icon"><svg viewBox="0 0 24 24"><polygon points="6,3 20,12 6,21"/></svg></div>
            </a>
            <a href="https://www.youtube.com/watch?v=EP5s0yKZUKk" target="_blank" rel="noopener" class="thumb-card">
              <img src="https://img.youtube.com/vi/EP5s0yKZUKk/hqdefault.jpg" alt="Void Cascade" loading="lazy" />
              <div class="thumb-overlay">
                <span class="thumb-title">Void Cascade</span>
