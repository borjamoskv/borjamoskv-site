---
/* src/components/AIAgent.astro */
---
<div class="ai-telemetry-wrapper" transition:persist="ai-agent-persisted">
  <!-- Minimalist Rotating Telemetry Compass (Trigger Button) -->
  <button id="ai-telemetry-badge" class="telemetry-trigger" aria-label="Abrir Consola de Telemetría Exergética">
    <div class="compass-ring"></div>
    <div class="compass-coordinates" id="compass-coords">X: 000 | Y: 000</div>
    <div class="compass-label">BM-Ω // TELEMETRY</div>
  </button>

  <!-- Fullscreen Technical HUD Overlay -->
  <div id="ai-agent-hud" class="hud-overlay hidden">
    <!-- Grid Layout -->
    <div class="hud-grid">
      <!-- HUD Header -->
      <div class="hud-header">
        <div class="hud-logo">
          <span class="pulse-amber"></span>
          <span>BM-Ω // SYSTEM COGNITIVE OVERLAY [NAROA-2026]</span>
        </div>
        <div class="hud-entropy" id="hud-entropy-display">ENTROPY: --- [C4-SIM]</div>
        <div class="hud-exit" id="hud-close-btn">[ TERMINATE CORE // ESC ]</div>
      </div>

      <!-- Left Panel: Physical Synth & Visual Modulators -->
      <div class="hud-panel left-panel">
        <h3 class="panel-title">// PHYSICAL RESONANCE MODULATORS</h3>
        
        <!-- Interactive Theremin Synth Pad -->
        <div class="synth-pad-container">
          <div class="synth-label">THEREMIN FREQUENCY INJECTOR (DRAG MOUSE)</div>
          <div id="synth-theremin" class="synth-theremin">
            <div class="grid-lines"></div>
            <div id="theremin-cursor" class="theremin-cursor"></div>
            <span class="theremin-readout" id="theremin-readout">Hz: 0.00 // Amp: 0.00</span>
          </div>
        </div>

        <!-- Slider Modulators -->
        <div class="sliders-container">
          <div class="slider-group">
            <div class="slider-header">
              <span>WEBGL DISTORTION RATIO</span>
              <span id="val-distortion">1.0x</span>
            </div>
            <input type="range" id="slide-distortion" min="0" max="5" step="0.1" value="1" class="hud-slider" />
          </div>

          <div class="slider-group">
            <div class="slider-header">
              <span>GLSL TIME DILATION</span>
              <span id="val-time">1.0x</span>
            </div>
            <input type="range" id="slide-time" min="0.1" max="4" step="0.1" value="1" class="hud-slider" />
          </div>

          <div class="slider-group">
            <div class="slider-header">
              <span>EXERGY GRAIN DUST</span>
              <span id="val-grain">3%</span>
            </div>
            <input type="range" id="slide-grain" min="1" max="15" step="1" value="3" class="hud-slider" />
          </div>
        </div>
      </div>

      <!-- Center Panel: Real-Time Spectrogram Visualizer -->
      <div class="hud-panel center-panel">
        <h3 class="panel-title">// HARMONIC FREQUENCY SPECTRUM</h3>
        <div class="canvas-container">
          <canvas id="hud-spectrogram" width="360" height="180"></canvas>
        </div>
        
        <div class="hud-actions">
          <button id="btn-corrupt" class="hud-btn">// CORRUPT VIEWPORT TEXT</button>
          <button id="btn-pulse" class="hud-btn">// INJECT IMPULSE FREQ</button>
        </div>
      </div>

      <!-- Right Panel: Silicon Telemetry Feed & LLM Agent -->
      <div class="hud-panel right-panel">
        <h3 class="panel-title">// RITXIE HAWTING // LLM NEURAL LINK</h3>
        <div class="logs-container" id="hud-logs">
          <!-- Streams automatically -->
        </div>
        <form id="agent-form" class="agent-terminal" autocomplete="off">
          <span class="terminal-prompt">&gt;</span>
          <input type="text" id="agent-input" class="terminal-input" placeholder="INGRESA COMANDO EN LA TERMINAL..." />
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  /* ─── STYLING - HUD INTERFACE ─── */
  .ai-telemetry-wrapper {
    position: fixed;
    bottom: 110px;
    right: 2.5rem;
    z-index: 999999;
    font-family: var(--font-secondary);
  }

  /* Telemetry Trigger Button (Minimalist Cyber Compass) */
  .telemetry-trigger {
    background: rgba(10, 10, 10, 0.95);
    border: 1px solid var(--glass-border);
    border-radius: 6px;
    padding: 0.8rem 1.2rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.3rem;
    color: var(--color-parchment);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7);
    transition: all 0.4s var(--ease-omega);
  }

  .telemetry-trigger:hover {
    border-color: var(--color-yinmn);
    box-shadow: 0 0 15px rgba(43, 59, 229, 0.3);
    transform: scale(1.02);
  }

  .compass-ring {
    width: 22px;
    height: 22px;
    border: 1px dashed var(--color-yinmn);
    border-radius: 50%;
    position: relative;
    align-self: center;
    margin-bottom: 0.2rem;
    animation: spin-compass 12s linear infinite;
  }
  .compass-ring::after {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    width: 2px; height: 6px;
    background: var(--color-amber);
    transform: translateX(-50%);
  }

  @keyframes spin-compass {
    from { transform: rotate(0deg); } to { transform: rotate(360deg); }
  }

  .compass-coordinates {
    font-size: 0.55rem;
    color: var(--color-amber);
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  .compass-label {
    font-size: 0.5rem;
    color: rgba(243, 244, 246, 0.4);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  /* Fullscreen HUD Overlay styling */
  .hud-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    background: rgba(5, 5, 8, 0.95);
    backdrop-filter: blur(35px);
    -webkit-backdrop-filter: blur(35px);
    z-index: 1000000;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 3vw;
    transition: opacity 0.5s var(--ease-omega);
  }

  .hud-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* Core Grid */
  .hud-grid {
    width: 100%;
    max-width: 1200px;
    height: 100%;
    display: grid;
    grid-template-columns: 1.1fr 1fr 1.1fr;
    grid-template-rows: auto 1fr;
    gap: 1.5rem;
  }

  /* Header */
  .hud-header {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 1rem;
  }

  .hud-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #fff;
  }

  .pulse-amber {
    width: 6px; height: 6px;
    background: var(--color-amber);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--color-amber);
    animation: status-breathe 1.5s infinite alternate;
  }

  @keyframes status-breathe {
    from { opacity: 0.3; } to { opacity: 1; }
  }

  .hud-entropy {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-yinmn);
    letter-spacing: 0.15em;
    text-shadow: 0 0 10px rgba(43, 59, 229, 0.4);
  }

  .hud-exit {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--color-amber);
    cursor: pointer;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }
  .hud-exit:hover {
    color: #fff;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
  }

  /* Panel Generic Styles */
  .hud-panel {
    background: rgba(15, 15, 18, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 6px;
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    overflow: hidden;
  }

  .panel-title {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--color-yinmn);
    border-bottom: 1px solid rgba(43, 59, 229, 0.15);
    padding-bottom: 0.5rem;
    font-weight: 700;
  }

  /* Left Panel: Theremin Synth Area */
  .synth-pad-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .synth-label {
    font-size: 0.55rem;
    color: rgba(243, 244, 246, 0.4);
    letter-spacing: 0.05em;
  }

  .synth-theremin {
    height: 180px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(43, 59, 229, 0.2);
    border-radius: 4px;
    position: relative;
    cursor: crosshair;
    overflow: hidden;
  }

  .grid-lines {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: 
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .theremin-cursor {
    position: absolute;
    width: 12px; height: 12px;
    border: 1px solid var(--color-amber);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    display: none;
    box-shadow: 0 0 10px var(--color-amber);
  }

  .theremin-readout {
    position: absolute;
    bottom: 8px; right: 8px;
    font-size: 0.55rem;
    color: var(--color-amber);
    pointer-events: none;
    background: rgba(10, 10, 10, 0.8);
    padding: 0.2rem 0.4rem;
    border-radius: 2px;
  }

  /* Sliders */
  .sliders-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .slider-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .slider-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.55rem;
    color: rgba(243, 244, 246, 0.55);
    letter-spacing: 0.1em;
  }

  .hud-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 2px;
    background: rgba(255, 255, 255, 0.1);
    outline: none;
    border-radius: 2px;
  }

  .hud-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 10px; height: 10px;
    background: var(--color-yinmn);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 0 8px var(--color-yinmn);
    transition: transform 0.2s ease;
  }

  .hud-slider::-webkit-slider-thumb:hover {
    transform: scale(1.3);
  }

  /* Center Panel */
  .canvas-container {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 4px;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.5rem;
  }

  .hud-actions {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: auto;
  }

  .hud-btn {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-parchment);
    padding: 0.8rem;
    font-family: var(--font-secondary);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.3s var(--ease-omega);
  }

  .hud-btn:hover {
    background: rgba(43, 59, 229, 0.1);
    border-color: var(--color-yinmn);
    box-shadow: 0 0 12px rgba(43, 59, 229, 0.2);
    color: #fff;
  }

  /* Right Panel: Telemetry Logs */
  .logs-container {
    flex: 1;
    overflow-y: auto;
    font-size: 0.55rem;
    line-height: 1.5;
    color: rgba(243, 244, 246, 0.5);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-right: 0.5rem;
  }
  .logs-container::-webkit-scrollbar {
    width: 3px;
  }
  .logs-container::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }

  .log-row {
    word-break: break-all;
    border-left: 1px solid rgba(255, 255, 255, 0.05);
    padding-left: 0.4rem;
  }
  .log-row.alert {
    color: var(--color-amber);
    border-left-color: var(--color-amber);
  }
  .log-row.cyan {
    color: var(--color-yinmn);
    border-left-color: var(--color-yinmn);
  }
  .log-row.agent {
    color: #fff;
    border-left-color: #fff;
    font-weight: 700;
    text-shadow: 0 0 5px rgba(255, 255, 255, 0.4);
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* LLM Terminal Input */
  .agent-terminal {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 0.8rem;
    margin-top: 0.5rem;
  }
  .terminal-prompt {
    color: var(--color-amber);
    font-weight: 900;
    font-size: 0.8rem;
  }
  .terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #fff;
    font-family: var(--font-secondary);
    font-size: 0.6rem;
    outline: none;
    letter-spacing: 0.1em;
  }
  .terminal-input::placeholder {
    color: rgba(255, 255, 255, 0.2);
  }

  /* Responsive HUD overlay */
  @media (max-width: 900px) {
    .hud-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto auto;
      overflow-y: auto;
    }
    .hud-panel {
      height: auto;
    }
  }
</style>

<script>
  // ─── CLIENT SIDE DISRUPTIVE COGNITIVE HUDS ───

  let hudActive = false;
  let synthOsc: OscillatorNode | null = null;
  let synthGain: GainNode | null = null;
  let spectrogramAnimFrame: number;
  let logLimit = 60;
  
  // Custom interface for Astro compiler safety
  interface CyberAudioStore {
    isPlaying: boolean;
    analyser?: AnalyserNode;
  }
  declare global {
    interface Window {
      audioCtx?: AudioContext;
      globalAudioVolume?: number;
      CyberAudioStore?: CyberAudioStore;
    }
  }

  // Helper to run non-critical updates deferred (INP optimization)
  function addLogEntryDeferred(text: string, type: "system" | "alert" | "cyan" | "agent" = "system") {
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(() => addLogEntry(text, type));
    } else {
      setTimeout(() => addLogEntry(text, type), 0);
    }
  }

  function initTelemetryHUD() {
    const trigger = document.getElementById('ai-telemetry-badge');
    const hud = document.getElementById('ai-agent-hud');
    const closeBtn = document.getElementById('hud-close-btn');
    const thPad = document.getElementById('synth-theremin');
    const thCursor = document.getElementById('theremin-cursor');
    const thReadout = document.getElementById('theremin-readout');

    if (!trigger || !hud || !closeBtn || !thPad || !thCursor || !thReadout) return;

    // 1. OPEN / CLOSE HANDLERS
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const nextActive = hud.classList.contains('hidden');
      hud.classList.toggle('hidden');
      hudActive = nextActive;
      
      if (hudActive) {
        document.body.style.overflow = 'hidden'; // Lock scrolling
        
        // Defer audio context loading and layout operations
        setTimeout(() => {
          playTick(800, 200, 0.08); // responsive click
          startSpectrogram(document.getElementById('hud-spectrogram') as HTMLCanvasElement);
          addLogEntryDeferred("COGNITIVE HUD OVERLAY MOUNTED.", "cyan");
          addLogEntryDeferred("TELEMETRY CHANNEL 0xFE ALIGNED.", "system");
          syncGlobalEntropy();
        }, 0);
      } else {
        closeHUD();
      }
    });

    closeBtn.addEventListener('click', closeHUD);

    // Escape Key closure
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && hudActive) {
        closeHUD();
      }
    });

    function closeHUD() {
      hud.classList.add('hidden');
      hudActive = false;
      document.body.style.overflow = ''; // Unlock scrolling
      
      // Defer teardown to avoid blocking close rendering
      setTimeout(() => {
        cancelAnimationFrame(spectrogramAnimFrame);
        stopTheremin();
        playTick(400, 100, 0.08);
      }, 0);
    }

    // 2. LIVE CURSOR COMPASS TRACKER - Throttled with requestAnimationFrame
    let mouseMovePending = false;
    let lastX = 0, lastY = 0;

    document.addEventListener('mousemove', (e) => {
      lastX = e.clientX;
      lastY = e.clientY;

      if (!mouseMovePending) {
        mouseMovePending = true;
        requestAnimationFrame(() => {
          mouseMovePending = false;
          const coords = document.getElementById('compass-coords');
          if (coords) {
            const xStr = lastX.toString().padStart(3, '0');
            const yStr = lastY.toString().padStart(3, '0');
            coords.textContent = `X: ${xStr} | Y: ${yStr}`;
          }

          if (hudActive && Math.random() < 0.04) {
            addLogEntryDeferred(`CURSOR COORDINATES ATTAINED: X=${lastX} Y=${lastY}`);
          }
        });
      }
    });

    // 3. THEREMIN SYNTH LOGIC - Throttled with requestAnimationFrame
    thPad.addEventListener('mouseenter', () => {
      thCursor.style.display = 'block';
      startTheremin();
    });

    thPad.addEventListener('mouseleave', () => {
      thCursor.style.display = 'none';
      stopTheremin();
    });

    let thereminPending = false;
    let lastThX = 0, lastThY = 0;

    thPad.addEventListener('mousemove', (e) => {
      lastThX = e.clientX;
      lastThY = e.clientY;

      if (!thereminPending) {
        thereminPending = true;
        requestAnimationFrame(() => {
          thereminPending = false;
          const rect = thPad.getBoundingClientRect();
          const pctX = Math.max(0, Math.min(1, (lastThX - rect.left) / rect.width));
          const pctY = Math.max(0, Math.min(1, (lastThY - rect.top) / rect.height));

          // Map Y to top position of cursor, X to left
          thCursor.style.left = `${pctX * 100}%`;
          thCursor.style.top = `${pctY * 100}%`;

          // Frequency mapping: 150Hz to 1200Hz
          const freq = 150 + (pctX * 1050);
          // Volume mapping: inverse Y (top is louder)
          const volume = (1 - pctY) * 0.08;

          thReadout.textContent = `Hz: ${freq.toFixed(2)} // Amp: ${volume.toFixed(3)}`;

          if (synthOsc && synthGain && window.audioCtx) {
            synthOsc.frequency.setValueAtTime(freq, window.audioCtx.currentTime);
            synthGain.gain.setValueAtTime(volume, window.audioCtx.currentTime);
          }

          if (Math.random() < 0.05) {
            addLogEntryDeferred(`THEREMIN SYNAPTIC INJECTOR: FREQ=${freq.toFixed(1)}Hz GAIN=${(volume * 1000).toFixed(0)}mB`, "alert");
          }
        });
      }
    });

    // 4. SLIDERS CONTROLLERS
    const sDist = document.getElementById('slide-distortion') as HTMLInputElement;
    const sTime = document.getElementById('slide-time') as HTMLInputElement;
    const sGrain = document.getElementById('slide-grain') as HTMLInputElement;

    sDist.addEventListener('input', () => {
      const val = parseFloat(sDist.value);
      document.getElementById('val-distortion').textContent = `${val.toFixed(1)}x`;
      // Direct WebGL shader binding
      // @ts-ignore
      window.globalDistortionRatio = val;
      addLogEntryDeferred(`WEBGL SHADER DISTORTION RATIO => ${val.toFixed(2)}`, "cyan");
    });

    sTime.addEventListener('input', () => {
      const val = parseFloat(sTime.value);
      document.getElementById('val-time').textContent = `${val.toFixed(1)}x`;
      
      // We can modulate shader time speed by scaling time parameter increment
      // Let's bind it to window object so initGLSL can read it!
      // @ts-ignore
      window.glslTimeScale = val;
      addLogEntryDeferred(`GLSL CLOCK DILATION FACTOR => ${val.toFixed(2)}`, "cyan");
    });

    sGrain.addEventListener('input', () => {
      const val = parseInt(sGrain.value);
      document.getElementById('val-grain').textContent = `${val}%`;
      
      // Mutate actual global CSS grain overlay opacity
      const bodyBefore = document.querySelector('body');
      if (bodyBefore) {
        bodyBefore.style.setProperty('--grain-opacity', (val / 100).toString());
      }
      // Inject CSS rule directly or mutate document custom style
      let sheet = document.getElementById('dynamic-grain-style');
      if (!sheet) {
        sheet = document.createElement('style');
        sheet.id = 'dynamic-grain-style';
        document.head.appendChild(sheet);
      }
      sheet.textContent = `body::before { opacity: ${val / 100} !important; }`;
      addLogEntryDeferred(`EXERGY FILM GRAIN DENSITY INJECTED => ${val}%`);
    });

    // 5. INTERACTIVE PAGE DISRUPTIONS
    const btnCorrupt = document.getElementById('btn-corrupt');
    const btnPulse = document.getElementById('btn-pulse');

    btnCorrupt.addEventListener('click', () => {
      playTick(1200, 300, 0.4);
      setTimeout(() => {
        corruptViewportHeaders();
        incrementGlobalEntropy(10);
      }, 0);
    });

    btnPulse.addEventListener('click', () => {
      playTick(80, 2800, 0.6);
      setTimeout(() => {
        injectVisualPulse();
        incrementGlobalEntropy(25);
      }, 0);
    });

    // 5.5 LLM AGENT COMMUNICATION (Ritxie Hawting)
    const agentForm = document.getElementById('agent-form');
    const agentInput = document.getElementById('agent-input') as HTMLInputElement;

    if (agentForm && agentInput) {
      agentForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const text = agentInput.value.trim();
        if (!text) return;

        addLogEntryDeferred(`USR_CMD: ${text}`, "cyan");
        agentInput.value = '';
        agentInput.disabled = true;
        
        // Typing indicator
        addLogEntryDeferred("RITXIE HAWTING_SINTETIZANDO...", "alert");
        
        try {
          const res = await fetch('/api/agent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: text })
          });
          
          if (!res.ok) throw new Error('CORTEX REJECTED CONNECTION');
          
          const data = await res.json();
          addLogEntryDeferred(data.response || "RITXIE_HAWTING: VACÍO", "agent");
          
          // Trigger physics response on AI reply
          setTimeout(() => {
            injectVisualPulse();
          }, 0);

        } catch(err) {
          addLogEntryDeferred("RITXIE_HAWTING: [ERROR DE CONEXIÓN CON EL CORTEX]", "alert");
        } finally {
          agentInput.disabled = false;
          agentInput.focus();
        }
      });
    }

    // Initial logs setup
    addLogEntryDeferred("SILICON TELEMETRY OVERLAY STANDBY.", "system");
  }

  // ─── ENTROPY KV LOGIC ───
  async function syncGlobalEntropy() {
    try {
      const res = await fetch('/api/telemetry');
      if (res.ok) {
        const data = await res.json();
        const display = document.getElementById('hud-entropy-display');
        if (display) {
          const type = data.status.includes('REAL') ? 'C5-REAL' : 'C4-SIM';
          display.textContent = `ENTROPY: ${data.entropy} [${type}]`;
        }
      }
    } catch (e) {
      console.warn("Entropy sync failed", e);
    }
  }

  async function incrementGlobalEntropy(delta: number) {
    try {
      const res = await fetch('/api/telemetry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ delta })
      });
      if (res.ok) {
        const data = await res.json();
        const display = document.getElementById('hud-entropy-display');
        if (display) {
          const type = data.status.includes('REAL') ? 'C5-REAL' : 'C4-SIM';
          display.textContent = `ENTROPY: ${data.entropy} [${type}]`;
        }
      }
    } catch (e) {
      console.warn("Entropy increment failed", e);
    }
  }

  // Web Audio custom click / tick synth
  function playTick(start: number, end: number, duration: number) {
    try {
      const ctx = window.audioCtx;
      if (!ctx || ctx.state !== 'running') return;
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(start, ctx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(end, ctx.currentTime + duration);
      gain.gain.setValueAtTime(0.015, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + duration);
      osc.start();
      osc.stop(ctx.currentTime + duration);
    } catch(e){}
  }

  // Theremin Audio Setup
  function startTheremin() {
    try {
      const ctx = window.audioCtx;
      if (!ctx) return;
      if (ctx.state !== 'running') {
        ctx.resume();
      }

      synthOsc = ctx.createOscillator();
      synthGain = ctx.createGain();

      synthOsc.type = 'sine';
      synthOsc.frequency.setValueAtTime(440, ctx.currentTime);
      synthGain.gain.setValueAtTime(0.0001, ctx.currentTime);

      synthOsc.connect(synthGain);
      synthGain.connect(ctx.destination);

      synthOsc.start();
    } catch(err) {
      console.warn("Theremin initialization failed", err);
    }
  }

  function stopTheremin() {
    try {
      if (synthOsc && synthGain && window.audioCtx) {
        synthGain.gain.exponentialRampToValueAtTime(0.0001, window.audioCtx.currentTime + 0.1);
        const oscToStop = synthOsc;
        setTimeout(() => {
          try {
            oscToStop.stop();
          } catch(e){}
        }, 120);
      }
    } catch(e){}
    synthOsc = null;
    synthGain = null;
  }

  // 6. LOG BUFFER MANAGEMENT
  function addLogEntry(text: string, type: "system" | "alert" | "cyan" | "agent" = "system") {
    const logs = document.getElementById('hud-logs');
    if (!logs) return;

    const row = document.createElement('div');
    row.className = `log-row ${type}`;
    
    const pad = (n: number) => n.toString().padStart(2, '0');
    const now = new Date();
    const ts = `[${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}.${(now.getMilliseconds()/10).toFixed(0).padStart(2, '0')}]`;
    
    row.textContent = `${ts} // ${text}`;
    logs.appendChild(row);

    // Limit log rows to prevent performance leak
    while (logs.childNodes.length > logLimit) {
      logs.removeChild(logs.firstChild!);
    }

    logs.scrollTop = logs.scrollHeight;
  }

  // 7. REAL-TIME SPECTROGRAM VISUALIZER
  function startSpectrogram(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    function render() {
      if (!hudActive) return;
      spectrogramAnimFrame = requestAnimationFrame(render);

      // Drawing Spectrogram logic
      ctx.fillStyle = 'rgba(10, 10, 10, 0.15)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      const store = window.CyberAudioStore;
      
      // If a track is active, grab frequency data
      if (store && store.isPlaying && store.analyser && window.audioCtx) {
        const bufferLength = store.analyser.frequencyBinCount;
        const dataArray = new Uint8Array(bufferLength);
        store.analyser.getByteFrequencyData(dataArray);

        const barWidth = (canvas.width / bufferLength) * 2.5;
        let barHeight;
        let x = 0;

        for (let i = 0; i < bufferLength; i++) {
          barHeight = dataArray[i] * 0.6;

          // HSL colors between YInMn Blue and Amber
          const hue = 233 - (dataArray[i] / 255) * 200; // Shift hue based on strength
          ctx.fillStyle = `hsla(${hue}, 80%, 50%, 0.75)`;
          ctx.fillRect(x, canvas.height - barHeight, barWidth - 1, barHeight);

          x += barWidth;
        }
      } else {
        // Draw idle sine wave if no audio is playing
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';
        ctx.lineWidth = 1;
        ctx.beginPath();
        const time = Date.now() * 0.003;
        for (let x = 0; x < canvas.width; x++) {
          const y = canvas.height / 2 + Math.sin(x * 0.04 + time) * 8;
          if (x === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();
      }
    }

    render();
  }

  // 8. CORRUPT PAGE TEXT (HEX Scrambler)
  function corruptViewportHeaders() {
    addLogEntry("MUTATING PAGE TYPOGRAPHY MATRIX...", "alert");
    
    // Find all titles
    const headers = document.querySelectorAll('h1, h2, h3, .section-title, .hero-title');
    
    headers.forEach(header => {
      const originalText = header.getAttribute('data-orig-text') || header.textContent || '';
      
      if (!header.getAttribute('data-orig-text')) {
        header.setAttribute('data-orig-text', originalText);
      }

      let iteration = 0;
      const chars = "0123456789ABCDEF[]{}/\\*&%$#@!+=-_";
      
      const interval = setInterval(() => {
        header.textContent = originalText
          .split("")
          .map((char, index) => {
            if (char === " ") return " ";
            if (index < iteration) {
              return originalText[index];
            }
            return chars[Math.floor(Math.random() * chars.length)];
          })
          .join("");
        
        if (iteration >= originalText.length) {
          clearInterval(interval);
          header.textContent = originalText; // Restore fully
        }
        iteration += 1 / 3;
      }, 30);
    });

    addLogEntry("TYPOGRAPHY MATRIX RESTABILIZED.");
  }

  // 9. MASSIVE PULSE IMPACT (GLITCH FLASH)
  function injectVisualPulse() {
    addLogEntry("INJECTING COGNITIVE RESONANCE IMPULSE...", "alert");
    playTick(80, 2800, 0.6); // Massive sweep audio

    // Create a fullscreen dynamic flash overlay
    const flash = document.createElement('div');
    flash.style.position = 'fixed';
    flash.style.top = '0';
    flash.style.left = '0';
    flash.style.width = '100vw';
    flash.style.height = '100vh';
    flash.style.background = 'rgba(255, 159, 28, 0.2)'; // amber flash
    flash.style.zIndex = '9999999';
    flash.style.pointerEvents = 'none';
    flash.style.transition = 'opacity 0.6s var(--ease-omega)';
    document.body.appendChild(flash);

    // Glitch WebGL shader
    const origVol = window.globalAudioVolume || 0;
    window.globalAudioVolume = 5.0; // Max distortion

    setTimeout(() => {
      flash.style.opacity = '0';
      setTimeout(() => {
        flash.remove();
        window.globalAudioVolume = origVol;
        addLogEntry("COGNITIVE PULSE STABILIZED. HEAT SINK COMPLETE.");
      }, 600);
    }, 100);
  }

  // Bind loader logic
  document.addEventListener('DOMContentLoaded', initTelemetryHUD);
  document.addEventListener('astro:page-load', initTelemetryHUD);
</script>
