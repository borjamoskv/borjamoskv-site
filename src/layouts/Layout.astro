---
// ─── C5-REAL EDGE CACHING ───
// Cloudflare Edge Cache: 1 day, Browser Cache: 1 hour.
Astro.response.headers.set('Cache-Control', 'public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800');

import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import AIAgent from '../components/AIAgent.astro';
import WalkingGalleryNode from '../components/WalkingGalleryNode.astro';
import EspejoDelAlma from '../components/EspejoDelAlma.astro';
import bandcampTracks from '../data/bandcamp_tracks.json';
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="Borja Moskv — Música, Vídeo y Ensayos de Vanguardia. Síntesis C5-REAL, Colapso Termodinámico y Auditoría del Silicio." />

    <!-- ─── METRICS OPTIMIZATION (LCP / FCP) ─── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&family=JetBrains+Mono:wght@300;400;700&display=swap" rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800;900&family=JetBrains+Mono:wght@300;400;700&display=swap" rel="stylesheet" /></noscript>
    <link rel="preconnect" href="https://www.youtube.com" />
    <link rel="preconnect" href="https://i.ytimg.com" />
    <link rel="preconnect" href="https://open.spotify.com" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://borjamoskvsite.vercel.app/" />
    <meta property="og:title" content="BORJA MOSKV — Música · Vídeo · Blog" />
    <meta property="og:description" content="Borja Moskv — Música, Vídeo y Ensayos de Vanguardia. Síntesis C5-REAL, Colapso Termodinámico y Auditoría del Silicio." />
    <meta property="og:image" content="/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://borjamoskvsite.vercel.app/" />
    <meta property="twitter:title" content="BORJA MOSKV — Música · Vídeo · Blog" />
    <meta property="twitter:description" content="Borja Moskv — Música, Vídeo y Ensayos de Vanguardia. Síntesis C5-REAL, Colapso Termodinámico y Auditoría del Silicio." />
    <meta property="twitter:image" content="/og-image.jpg" />

    <ClientRouter />
  </head>
  <body>
    
    <button id="audio-badge" aria-label="Inicializar y controlar el audio del sistema" transition:persist style="background: rgba(10, 10, 10, 0.95); border: 1px solid rgba(255, 159, 28, 0.4); border-radius: 4px; padding: 0.6rem 1.2rem; cursor: pointer; display: flex; align-items: center; gap: 0.8rem; pointer-events: auto; z-index: 100000; transition: all 0.3s ease;">
      <div class="audio-dot"></div>
      <span style="font-family: var(--font-secondary); font-size: 0.65rem; color: #fff; letter-spacing: 0.1em; text-transform: uppercase;">AUDIO OFFLINE — TAP TO INITIALIZE</span>
    </button>

    <div id="omega-progress" aria-hidden="true" transition:persist></div>

    <!-- Background Layer -->
    <div class="bg-video-container" transition:persist>
      <video id="global-bg-video" class="bg-video" autoplay loop muted playsinline></video>
      <script is:inline>
        (function() {
          const videos = [
            "/media/videos/no-sleep-in-my-city.mp4",
            "/media/videos/bizarro-loop.mp4",
            "/media/videos/hortaliza-deep.mp4"
          ];
          const randomVideo = videos[Math.floor(Math.random() * videos.length)];
          const videoEl = document.getElementById('global-bg-video');
          // Only set source if it hasn't been set (preserves view transition persistence)
          if (videoEl && !videoEl.getAttribute('src')) {
            videoEl.src = randomVideo;
            videoEl.load();
            videoEl.play().catch(e => console.warn("Video autoplay blocked", e));
          }
        })();
      </script>
    </div>
    <div class="overlay" transition:persist></div>

    <!-- Navigation -->
    <header transition:persist="main-header">
      <nav class="top-nav" aria-label="Navegación principal">
        <a href="/" class="nav-brand nav-link" style="font-weight: 900; color: var(--color-yinmn); margin-right: auto; z-index: 1001; text-shadow: 0 0 15px rgba(43, 59, 229, 0.4);">BM // CORE</a>
        
        <!-- Desktop Links -->
        <div class="nav-links-desktop">
          <a href="/#laboratorio" class="nav-link" aria-label="Laboratorio">Laboratorio</a>
          <a href="/#musica" class="nav-link" aria-label="Sección de música">Música</a>
          <a href="/crear-musica" class="nav-link" aria-label="Crear Música con YuE">Crear Música</a>
          
          <div class="nav-dropdown" id="bandcamp-dropdown-wrapper">
            <a href="javascript:void(0)" class="nav-link-ext dropdown-toggle" aria-haspopup="true" aria-expanded="false">Bandcamp</a>
            <div class="dropdown-menu" id="bandcamp-dropdown-menu">
              <div class="dropdown-search-container">
                <div style="display: flex; align-items: center; gap: 0.5rem; width: 100%;">
                  <input type="text" class="dropdown-search" id="bandcamp-search" placeholder="FILTRAR LANZAMIENTOS..." autocomplete="off" style="flex-grow: 1;" />
                  <span class="dropdown-count-badge" id="bandcamp-count">{bandcampTracks.length}</span>
                </div>
                <div class="dropdown-filter-tabs">
                  <button class="filter-tab active" data-filter="all">ALL</button>
                  <button class="filter-tab" data-filter="album">ALBUMS</button>
                  <button class="filter-tab" data-filter="track">TRACKS</button>
                </div>
              </div>
              <div class="dropdown-items-list grid-layout" id="bandcamp-items-list">
                <div class="dropdown-no-results" style="display: none;">
                  SIN COINCIDENCIAS / NO RELEASES FOUND
                </div>
                {bandcampTracks.map((track, idx) => {
                  const isAlbum = track.href.includes('/album/');
                  return (
                    <a href={`https://borjamoskv.bandcamp.com${track.href}`} target="_blank" rel="noopener" class="dropdown-item" data-title={track.title.toLowerCase()} data-type={isAlbum ? 'album' : 'track'} style={`--item-idx: ${idx};`}>
                      <img src={track.img} alt={track.title} class="dropdown-item-img" loading="lazy" />
                      <div class="dropdown-item-info">
                        <span class="dropdown-item-title">{track.title}</span>
                        <span class="dropdown-item-badge">{isAlbum ? 'ALBUM' : 'TRACK'}</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          </div>

          <a href="/#video" class="nav-link" aria-label="Sección de vídeos">Vídeo</a>
          <a href="/#blog" class="nav-link" aria-label="Sección de diario y ensayos">Diario</a>
          <a href="/#manifiesto" class="nav-link" aria-label="Manifiesto del artista">Manifiesto</a>
          <a href="https://www.youtube.com/@borjamoskv" target="_blank" rel="noopener" class="nav-link" aria-label="Canal de YouTube de Borja Moskv">YouTube</a>
        </div>

        <!-- Sliding Underline -->
        <div class="nav-underline" id="nav-underline"></div>

        <!-- Hamburger Icon for Mobile Menu -->
        <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú de navegación" aria-expanded="false" style="z-index: 1001;">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </nav>

      <!-- Fullscreen Mobile Navigation Drawer -->
      <div class="mobile-menu-overlay" id="mobile-menu-overlay">
        <nav class="mobile-menu-nav" aria-label="Navegación móvil">
          <a href="/#laboratorio" class="mobile-nav-link">Laboratorio</a>
          <a href="/#musica" class="mobile-nav-link">Música</a>
          <a href="/crear-musica" class="mobile-nav-link">Crear Música</a>
          
          <div class="mobile-nav-dropdown" style="width: 100%; text-align: center;">
            <button class="mobile-dropdown-toggle" style="background: none; border: none; cursor: pointer; padding: 1rem 0; width: 100%; font-family: var(--font-secondary); font-size: 1.5rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-parchment); transition: color 0.3s ease;">Bandcamp ▾</button>
            <div class="mobile-dropdown-menu" style="display: none; max-height: 280px; overflow-y: auto; background: rgba(5,5,5,0.95); border: 1px solid rgba(43,59,229,0.2); border-radius: 8px; padding: 0.5rem; margin: 0.5rem 0;">
              <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; padding: 0 0.5rem;">
                <input type="text" class="dropdown-search mobile-dropdown-search" placeholder="FILTRAR..." style="flex-grow: 1; margin-bottom: 0;" autocomplete="off" />
                <span class="dropdown-count-badge mobile-dropdown-count">{bandcampTracks.length}</span>
              </div>
              <div class="dropdown-filter-tabs" style="justify-content: center; margin-bottom: 0.5rem; padding: 0 0.5rem;">
                <button class="filter-tab active" data-filter="all">ALL</button>
                <button class="filter-tab" data-filter="album">ALBUMS</button>
                <button class="filter-tab" data-filter="track">TRACKS</button>
              </div>
              <div class="mobile-dropdown-items-list">
                <div class="dropdown-no-results" style="display: none; width: 100%;">
                  SIN COINCIDENCIAS / NO RELEASES FOUND
                </div>
                {bandcampTracks.map((track, idx) => {
                  const isAlbum = track.href.includes('/album/');
                  return (
                    <a href={`https://borjamoskv.bandcamp.com${track.href}`} target="_blank" rel="noopener" class="dropdown-item" data-title={track.title.toLowerCase()} data-type={isAlbum ? 'album' : 'track'} style={`font-size: 0.65rem; padding: 0.4rem; --item-idx: ${idx};`}>
                      <img src={track.img} alt={track.title} class="dropdown-item-img" style="width: 28px; height: 28px;" loading="lazy" />
                      <div class="dropdown-item-info">
                        <span class="dropdown-item-title" style="font-size: 0.65rem; color: #fff;">{track.title}</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          </div>

          <a href="/#video" class="mobile-nav-link">Vídeo</a>
          <a href="/#blog" class="mobile-nav-link">Diario</a>
          <a href="/#manifiesto" class="mobile-nav-link">Manifiesto</a>
          <a href="https://www.youtube.com/@borjamoskv" target="_blank" rel="noopener" class="mobile-nav-link">YouTube</a>
        </nav>
      </div>
    </header>

    <slot />

    <!-- Footer -->
    <footer class="site-footer" transition:persist>
      <p class="footer-text">© 2026 Borja Moskv · YInMn 2026</p>
    </footer>
  

    <!-- Persistent Global Cyber Player -->
    <div class="cyber-player" id="cyber-player" transition:persist="cyber-player-persisted">
      <canvas id="player-waveform" style="position: absolute; top: 0; left: 0; width: 100%; height: 35px; pointer-events: none; opacity: 0.75; z-index: 1;"></canvas>
      <div class="player-inner" style="position: relative; z-index: 2;">
        <div class="player-cover">
          <img id="player-cover-img" src="data:image/svg+xml,%3Csvg viewBox='0 0 1 1' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='100%25' height='100%25' fill='%23111'/%3E%3C/svg%3E" alt="Portada" />
        </div>
        
        <div class="player-info">
          <div class="player-track-title" id="player-track-title">Selecciona una pista</div>
          <div class="player-track-artist" id="player-track-artist">Borja Moskv</div>
        </div>

        <div class="player-controls">
          <button class="player-btn" id="player-prev-btn" aria-label="Pista anterior">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5"/></svg>
          </button>
          
          <button class="player-btn player-play-btn" id="player-play-btn" aria-label="Reproducir / Pausar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" id="player-play-icon"><polygon points="5 3 19 12 5 21"/></svg>
          </button>
          
          <button class="player-btn" id="player-next-btn" aria-label="Siguiente pista">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/></svg>
          </button>
          
          <button class="player-btn" id="player-close-btn" aria-label="Cerrar reproductor" style="margin-left: 0.5rem; color: rgba(255,255,255,0.35);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        <div class="player-timeline">
          <span id="player-time-current">0:00</span>
          <div class="progress-bar-container" id="progress-bar-container" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
            <div class="progress-bar-fill" id="progress-bar-fill"></div>
          </div>
          <span id="player-time-duration">0:00</span>
        </div>

        <div class="player-volume-container">
          <button class="player-btn" id="player-volume-btn" aria-label="Silenciar / Activar sonido">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          </button>
          <div class="volume-slider" id="volume-slider">
            <div class="volume-slider-fill" id="volume-slider-fill"></div>
          </div>
        </div>
      </div>
    </div>

    <div id="omega-cursor" transition:persist></div>
    <AIAgent />
    <WalkingGalleryNode />
    <EspejoDelAlma />
    <script src="../scripts/cortex-core.ts"></script>
    <style is:global>
      #omega-cursor {
        position: fixed;
        top: 0; left: 0;
        width: 400px; height: 400px;
        margin-top: -200px; margin-left: -200px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(43, 59, 229, 0.12) 0%, rgba(43, 59, 229, 0) 60%);
        pointer-events: none;
        z-index: 99999;
        mix-blend-mode: screen;
        will-change: transform;
      }
      body:active #omega-cursor {
        background: radial-gradient(circle, rgba(255, 159, 28, 0.15) 0%, rgba(255, 159, 28, 0) 60%);
        transition: background 0.1s ease;
      }
    
      #audio-badge {
        position: fixed;
        bottom: 2rem; right: 2rem;
        z-index: 100000;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-secondary);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        color: #fff;
        background: rgba(10, 10, 10, 0.95);
        padding: 0.6rem 1.2rem;
        border: 1px solid rgba(255, 159, 28, 0.4);
        border-radius: 4px;
        backdrop-filter: blur(8px);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        pointer-events: auto;
        cursor: pointer;
      }
      #audio-badge:hover {
        border-color: #00ff00;
        background: #000;
        box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
        transform: scale(1.05);
      }
      .audio-dot {
        width: 6px; height: 6px;
        background: var(--color-amber);
        border-radius: 50%;
        animation: blink 1s infinite alternate;
      }
      @keyframes blink { from { opacity: 0.2; } to { opacity: 1; box-shadow: 0 0 8px var(--color-amber); } }

    

      /* Global Cyber Player Styles */
      .cyber-player {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(5, 5, 8, 0.95);
        border-top: 1px solid rgba(0, 240, 255, 0.3);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 9999;
        padding: 1.2rem 2rem;
        transition: all 0.4s ease;
        transform: translateY(100%);
      }

      .cyber-player.active {
        transform: translateY(0);
      }

      .player-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      .player-cover {
        width: 50px;
        height: 50px;
        background: #111;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgba(0, 240, 255, 0.2);
        flex-shrink: 0;
      }

      .player-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .player-info {
        flex: 0 1 200px;
        min-width: 0;
      }

      .player-track-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .player-track-artist {
        font-size: 0.75rem;
        color: var(--color-cyber-cyan, #00f0ff);
      }

      .player-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .player-btn {
        background: none;
        border: none;
        color: var(--color-cyber-cyan, #00f0ff);
        cursor: pointer;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
      }

      .player-btn:hover {
        color: #fff;
        text-shadow: 0 0 8px var(--color-cyber-cyan, #00f0ff);
      }

      .player-play-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--color-cyber-cyan, #00f0ff);
        color: #000;
      }

      .player-play-btn:hover {
        background: #ffffff;
        transform: scale(1.05);
      }

      .player-timeline {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.7rem;
        font-family: var(--font-secondary);
        color: var(--color-muted);
      }

      .progress-bar-container {
        flex: 1;
        height: 4px;
        background: #222;
        border-radius: 10px;
        cursor: pointer;
        position: relative;
      }

      .progress-bar-fill {
        height: 100%;
        width: 0%;
        background: var(--color-cyber-cyan, #00f0ff);
        border-radius: 10px;
        position: absolute;
        top: 0;
        left: 0;
      }

      .player-volume-container {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .volume-slider {
        width: 80px;
        height: 4px;
        background: #222;
        border-radius: 10px;
        cursor: pointer;
        position: relative;
      }

      .volume-slider-fill {
        height: 100%;
        width: 80%;
        background: var(--color-cyber-cyan, #00f0ff);
        border-radius: 10px;
      }

      @media (max-width: 768px) {
        .player-inner {
          flex-wrap: wrap;
          gap: 1rem;
        }
        .player-timeline {
          order: 4;
          flex: 1 0 100%;
        }
        .player-volume-container {
          display: none;
        }
      }

      /* ─── 13/10 DOM DESTRUCTION (BURN-ON-READ) ─── */
      @keyframes burnOut {
        0% { opacity: 1; filter: invert(0) blur(0px); transform: translateY(0) skewX(0); }
        40% { opacity: 0.9; filter: invert(1) blur(4px) contrast(300%); color: var(--color-amber); }
        100% { opacity: 0; filter: blur(20px); transform: translateY(-40px) skewX(30deg) scale(0.9); }
      }
      .burn-target {
        transition: opacity 0.3s ease;
      }
      .burn-target.burnt {
        animation: burnOut 0.7s cubic-bezier(0.19, 1, 0.22, 1) forwards;
        pointer-events: none;
      }

    </style>

  </body>
</html>
