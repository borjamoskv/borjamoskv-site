---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    
    <div id="audio-badge" transition:persist>
      <div class="audio-dot"></div>
      <span>SYSTEM AUDIO OFFLINE — CLICK TO INITIALIZE</span>
    </div>

    <div id="omega-progress" aria-hidden="true" transition:persist></div>

    <!-- Background Layer -->
    <div class="bg-video-container" transition:persist>
      <video class="bg-video" autoplay loop muted playsinline>
        <source src="/media/videos/no-sleep-in-my-city.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="overlay" transition:persist></div>

    <!-- Navigation -->
    <header transition:persist>
      <nav class="top-nav">
        <a href="/#musica" class="nav-link">Música</a>
        <a href="/#video" class="nav-link">Vídeo</a>
        <a href="/#blog" class="nav-link">Blog</a>
        <a href="https://www.youtube.com/@borjamoskv" target="_blank" rel="noopener" class="nav-link">YouTube</a>
      </nav>
    </header>

    <slot />

    <!-- Footer -->
    <footer class="site-footer" transition:persist>
      <p class="footer-text">© 2026 Borja Moskv · YInMn 2026</p>
    </footer>
  
    <div id="omega-cursor" transition:persist></div>
    <script>
      // ─── C5-REAL KINETICS ENGINE ───

      // ─── C5-REAL SPATIAL AUDIO ENGINE (Synthetic Industrial Drone) ───
      let audioCtx = null;
      let panner = null;
      let drone = null;
      let filter = null;
      let lfo = null;
      let isAudioInitialized = false;

      const initSpatialAudio = () => {
        if (isAudioInitialized) return;
        isAudioInitialized = true;

        const AudioContext = window.AudioContext || window.webkitAudioContext;
        audioCtx = new AudioContext();

        // 3D Spatial Panner
        panner = audioCtx.createPanner();
        panner.panningModel = 'HRTF';
        panner.distanceModel = 'inverse';
        panner.refDistance = 1;
        panner.maxDistance = 10000;
        panner.rolloffFactor = 1;
        panner.coneInnerAngle = 360;
        panner.coneOuterAngle = 0;
        panner.coneOuterGain = 0;

        // Base Drone Oscillator (55Hz - Deep Industrial Hum)
        drone = audioCtx.createOscillator();
        drone.type = 'sawtooth';
        drone.frequency.value = 55; 

        // Filter to shape the drone
        filter = audioCtx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.value = 400;
        filter.Q.value = 5;

        // LFO to modulate filter (Breathing effect)
        lfo = audioCtx.createOscillator();
        lfo.type = 'sine';
        lfo.frequency.value = 0.1; // 10 second cycle

        const lfoGain = audioCtx.createGain();
        lfoGain.gain.value = 300; // Modulation depth

        // Sub-bass layer
        const sub = audioCtx.createOscillator();
        sub.type = 'sine';
        sub.frequency.value = 27.5;

        // Master Gain
        const masterGain = audioCtx.createGain();
        masterGain.gain.value = 0.05; // Very low ambient volume

        // Routing
        lfo.connect(lfoGain);
        lfoGain.connect(filter.frequency);

        drone.connect(filter);
        filter.connect(panner);
        sub.connect(panner);
        
        panner.connect(masterGain);
        masterGain.connect(audioCtx.destination);

        // Start
        drone.start();
        sub.start();
        lfo.start();
        
        
        // ─── AUTODJ (Algorithmic Techno Sequencer) ───
        const tempo = 120; // BPM
        const lookahead = 25.0; // ms
        const scheduleAheadTime = 0.1; // s
        let currentNote = 0;
        let nextNoteTime = audioCtx.currentTime;

        // White Noise Buffer for Hi-Hats
        const bufferSize = audioCtx.sampleRate * 2;
        const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
        const output = noiseBuffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          output[i] = Math.random() * 2 - 1;
        }

        const playKick = (time) => {
          const osc = audioCtx.createOscillator();
          const gain = audioCtx.createGain();
          osc.connect(gain);
          gain.connect(panner); // Route through the 3D panner
          
          osc.frequency.setValueAtTime(150, time);
          osc.frequency.exponentialRampToValueAtTime(0.01, time + 0.5);
          
          gain.gain.setValueAtTime(1, time);
          gain.gain.exponentialRampToValueAtTime(0.01, time + 0.5);
          
          osc.start(time);
          osc.stop(time + 0.5);
        };

        const playHat = (time, isClosed) => {
          const noiseSrc = audioCtx.createBufferSource();
          noiseSrc.buffer = noiseBuffer;
          
          const noiseFilter = audioCtx.createBiquadFilter();
          noiseFilter.type = 'highpass';
          noiseFilter.frequency.value = 5000;
          
          const noiseGain = audioCtx.createGain();
          noiseGain.gain.setValueAtTime(isClosed ? 0.2 : 0.4, time);
          noiseGain.gain.exponentialRampToValueAtTime(0.01, time + (isClosed ? 0.05 : 0.2));
          
          noiseSrc.connect(noiseFilter);
          noiseFilter.connect(noiseGain);
          noiseGain.connect(panner);
          
          noiseSrc.start(time);
        };
        
        const playSynth = (time, note) => {
           const osc = audioCtx.createOscillator();
           const gain = audioCtx.createGain();
           osc.type = 'square';
           osc.frequency.value = note;
           
           gain.gain.setValueAtTime(0.05, time);
           gain.gain.exponentialRampToValueAtTime(0.01, time + 0.15);
           
           osc.connect(gain);
           gain.connect(panner);
           osc.start(time);
           osc.stop(time + 0.2);
        };

        const nextNote = () => {
          const secondsPerBeat = 60.0 / tempo;
          nextNoteTime += 0.25 * secondsPerBeat; // 16th notes
          currentNote++;
          if (currentNote === 16) {
            currentNote = 0;
          }
        };

        const scheduleNote = (beatNumber, time) => {
          // Kick on 1, 5, 9, 13 (Four on the floor)
          if (beatNumber % 4 === 0) playKick(time);
          
          // Offbeat open hats
          if (beatNumber % 4 === 2) playHat(time, false);
          
          // Random closed hats
          if (Math.random() > 0.6) playHat(time, true);
          
          // Random dark industrial synth blips (G minor pentatonic low)
          if (Math.random() > 0.8) {
            const notes = [49.00, 58.27, 65.41, 73.42, 87.31];
            playSynth(time, notes[Math.floor(Math.random() * notes.length)]);
          }
        };

        let timerID;
        const scheduler = () => {
          while (nextNoteTime < audioCtx.currentTime + scheduleAheadTime) {
            scheduleNote(currentNote, nextNoteTime);
            nextNote();
          }
          timerID = setTimeout(scheduler, lookahead);
        };
        
        // Start AutoDJ Sequencer
        scheduler();

        // Hide activation UI
        const audioBadge = document.getElementById('audio-badge');
        if (audioBadge) {
          audioBadge.style.opacity = '0';
          setTimeout(() => audioBadge.remove(), 1000);
        }
      };

      document.addEventListener('click', () => {
        if (!isAudioInitialized) initSpatialAudio();
        else if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
      }, { once: true });

      const cursor = document.getElementById('omega-cursor');
      let mouseX = window.innerWidth / 2, mouseY = window.innerHeight / 2;
      let cursorX = mouseX, cursorY = mouseY;
      
      window.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      let currentScroll = window.scrollY;
      let targetSkew = 0;
      let currentSkew = 0;
      let contentLayer = null;

      const loop = () => {
        // Cursor interpolation
        cursorX += (mouseX - cursorX) * 0.25;
        cursorY += (mouseY - cursorY) * 0.25;
        if (cursor) cursor.style.transform = `translate3d(${cursorX}px, ${cursorY}px, 0)`;
        
        
        // Update Spatial Audio Panner Position
        if (panner && audioCtx) {
          // Map screen coordinates to 3D space (-1 to 1)
          const x = (cursorX / window.innerWidth) * 2 - 1;
          const y = (cursorY / window.innerHeight) * 2 - 1;
          
          // Spatial scaling factors
          const z = 1 - Math.abs(x) * 0.5 - Math.abs(y) * 0.5; // Closer in the center
          
          panner.positionX.setTargetAtTime(x * 5, audioCtx.currentTime, 0.1);
          panner.positionY.setTargetAtTime(-y * 5, audioCtx.currentTime, 0.1);
          panner.positionZ.setTargetAtTime(z * 5, audioCtx.currentTime, 0.1);
        }

        // Scroll Velocity Skew Physics
        if (!contentLayer) contentLayer = document.querySelector('.content-layer');
        const newScroll = window.scrollY;
        const scrollVelocity = newScroll - currentScroll;
        currentScroll = newScroll;
        
        targetSkew = Math.max(-2.5, Math.min(2.5, scrollVelocity * 0.03));
        currentSkew += (targetSkew - currentSkew) * 0.1;
        
        if (contentLayer) {
          contentLayer.style.transform = `skewY(${currentSkew}deg)`;
          contentLayer.style.transformOrigin = 'center';
        }
        
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);

      document.addEventListener('astro:page-load', () => {
        
      // ─── SOTA Fallbacks (Safari/Firefox) ───
      if (!CSS.supports('animation-timeline', 'scroll()')) {
        const progress = document.getElementById('omega-progress');
        const nav = document.querySelector('.top-nav');
        if (progress && nav) {
          window.addEventListener('scroll', () => {
            const scrollable = document.documentElement.scrollHeight - window.innerHeight;
            const scrolled = window.scrollY;
            const progressPercentage = scrollable > 0 ? (scrolled / scrollable) : 0;
            progress.style.transform = `scaleX(${progressPercentage})`;
            
            const shrinkRatio = Math.min(1, scrolled / 250);
            nav.style.padding = `${1.2 - shrinkRatio * 0.6}rem 2rem`;
            nav.style.background = `rgba(10, 10, 10, ${0.9 + shrinkRatio * 0.08})`;
            if (shrinkRatio > 0.5) {
                nav.style.borderBottom = '1px solid rgba(255, 159, 28, 0.2)';
            } else {
                nav.style.borderBottom = '1px solid transparent';
            }
          });
        }
      }

        // 3D Magnetic Physics on interactive elements
        const iteractives = document.querySelectorAll('.hero-btn, .view-all-btn, .thumb-card, .video-scroll-card, .blog-card');
        
        iteractives.forEach(el => {
          el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            
            // Calculate tilt
            const tiltX = (y / (rect.height / 2)) * -8;
            const tiltY = (x / (rect.width / 2)) * 8;

            el.style.transform = `perspective(1000px) translate3d(${x * 0.08}px, ${y * 0.08}px, 10px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) scale(1.03)`;
            el.style.transition = 'none';
            el.style.zIndex = '50';
            
            // Add dynamic ember glow on hover edges
            el.style.boxShadow = `0 20px 40px rgba(0,0,0,0.8), ${-tiltY * 2}px ${tiltX * 2}px 30px rgba(255, 159, 28, 0.2)`;
          });
          
                    el.addEventListener('mouseenter', () => {
            cursor.style.width = '50px';
            cursor.style.height = '50px';
            cursor.style.marginTop = '-25px';
            cursor.style.marginLeft = '-25px';
            cursor.style.background = 'rgba(43, 59, 229, 0.9)';
            cursor.style.mixBlendMode = 'difference';
          });
          el.addEventListener('mouseleave', () => {
            el.style.transform = '';
            el.style.transition = 'all 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
            el.style.zIndex = '1';
            el.style.boxShadow = '';
            
            // Restore cursor
            cursor.style.width = '400px';
            cursor.style.height = '400px';
            cursor.style.marginTop = '-200px';
            cursor.style.marginLeft = '-200px';
            cursor.style.background = 'radial-gradient(circle, rgba(43, 59, 229, 0.12) 0%, rgba(43, 59, 229, 0) 60%)';
            cursor.style.mixBlendMode = 'screen';
          });
        });
      });
    </script>
    <style is:global>
      #omega-cursor {
        position: fixed;
        top: 0; left: 0;
        width: 400px; height: 400px;
        margin-top: -200px; margin-left: -200px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(43, 59, 229, 0.12) 0%, rgba(43, 59, 229, 0) 60%);
        pointer-events: none;
        z-index: 99999;
        mix-blend-mode: screen;
        will-change: transform;
      }
      body:active #omega-cursor {
        background: radial-gradient(circle, rgba(255, 159, 28, 0.15) 0%, rgba(255, 159, 28, 0) 60%);
        transition: background 0.1s ease;
      }
    
      #audio-badge {
        position: fixed;
        bottom: 2rem; right: 2rem;
        z-index: 100000;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-secondary);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        color: rgba(243, 244, 246, 0.4);
        background: rgba(10, 10, 10, 0.8);
        padding: 0.5rem 1rem;
        border: 1px solid rgba(255, 159, 28, 0.2);
        border-radius: var(--radius-omega);
        backdrop-filter: blur(5px);
        transition: opacity 1s ease;
        pointer-events: none;
      }
      .audio-dot {
        width: 6px; height: 6px;
        background: var(--color-amber);
        border-radius: 50%;
        animation: blink 1s infinite alternate;
      }
      @keyframes blink { from { opacity: 0.2; } to { opacity: 1; box-shadow: 0 0 8px var(--color-amber); } }

    </style>

  </body>
</html>
