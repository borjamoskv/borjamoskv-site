        background: radial-gradient(circle, rgba(43, 59, 229, 0.12) 0%, rgba(43, 59, 229, 0) 60%);
        pointer-events: none;
        z-index: 99999;
        mix-blend-mode: screen;
        will-change: transform;
      }
      body:active #omega-cursor {
        background: radial-gradient(circle, rgba(255, 159, 28, 0.15) 0%, rgba(255, 159, 28, 0) 60%);
        transition: background 0.1s ease;
      }
    
      #audio-badge {
        position: fixed;
        bottom: 2rem; right: 2rem;
        z-index: 100000;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-secondary);
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        color: #fff;
        background: rgba(10, 10, 10, 0.95);
        padding: 0.6rem 1.2rem;
        border: 1px solid rgba(255, 159, 28, 0.4);
        border-radius: 4px;
        backdrop-filter: blur(8px);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        pointer-events: auto;
        cursor: pointer;
      }
      #audio-badge:hover {
        border-color: #00ff00;
        background: #000;
        box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
        transform: scale(1.05);
      }
      .audio-dot {
        width: 6px; height: 6px;
        background: var(--color-amber);
        border-radius: 50%;
        animation: blink 1s infinite alternate;
      }
      @keyframes blink { from { opacity: 0.2; } to { opacity: 1; box-shadow: 0 0 8px var(--color-amber); } }

    

      /* Global Cyber Player Styles */
      .cyber-player {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(5, 5, 8, 0.95);
        border-top: 1px solid rgba(0, 240, 255, 0.3);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 9999;
        padding: 1.2rem 2rem;
        transition: all 0.4s ease;
        transform: translateY(100%);
      }

      .cyber-player.active {
        transform: translateY(0);
      }

      .player-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      .player-cover {
        width: 50px;
        height: 50px;
        background: #111;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid rgba(0, 240, 255, 0.2);
        flex-shrink: 0;
      }

      .player-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .player-info {
        flex: 0 1 200px;
        min-width: 0;
      }

      .player-track-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .player-track-artist {
        font-size: 0.75rem;
        color: var(--color-cyber-cyan, #00f0ff);
      }

      .player-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .player-btn {
        background: none;
        border: none;
        color: var(--color-cyber-cyan, #00f0ff);
        cursor: pointer;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
      }

      .player-btn:hover {
        color: #fff;
        text-shadow: 0 0 8px var(--color-cyber-cyan, #00f0ff);
      }

      .player-play-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--color-cyber-cyan, #00f0ff);
        color: #000;
      }

      .player-play-btn:hover {
        background: #ffffff;
        transform: scale(1.05);
      }

      .player-timeline {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.7rem;
        font-family: var(--font-secondary);
        color: var(--color-muted);
      }

      .progress-bar-container {
        flex: 1;
        height: 4px;
        background: #222;
        border-radius: 10px;
        cursor: pointer;
        position: relative;
      }

      .progress-bar-fill {
        height: 100%;
        width: 0%;
        background: var(--color-cyber-cyan, #00f0ff);
        border-radius: 10px;
        position: absolute;
        top: 0;
        left: 0;
      }

      .player-volume-container {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .volume-slider {
        width: 80px;
        height: 4px;
        background: #222;
        border-radius: 10px;
        cursor: pointer;
        position: relative;
      }

      .volume-slider-fill {
        height: 100%;
        width: 80%;
        background: var(--color-cyber-cyan, #00f0ff);
        border-radius: 10px;
      }

      @media (max-width: 768px) {
        .player-inner {
          flex-wrap: wrap;
          gap: 1rem;
        }
        .player-timeline {
          order: 4;
          flex: 1 0 100%;
        }
        .player-volume-container {
          display: none;
        }
      }

      /* ─── 13/10 DOM DESTRUCTION (BURN-ON-READ) ─── */
      @keyframes burnOut {
        0% { opacity: 1; filter: invert(0) blur(0px); transform: translateY(0) skewX(0); }
        40% { opacity: 0.9; filter: invert(1) blur(4px) contrast(300%); color: var(--color-amber); }
        100% { opacity: 0; filter: blur(20px); transform: translateY(-40px) skewX(30deg) scale(0.9); }
      }
      .burn-target {
        transition: opacity 0.3s ease;
      }
      .burn-target.burnt {
        animation: burnOut 0.7s cubic-bezier(0.19, 1, 0.22, 1) forwards;
        pointer-events: none;
      }

    </style>

  </body>
</html>
